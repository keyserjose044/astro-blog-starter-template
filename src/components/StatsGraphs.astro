  }

  .metric-tab--active,
  .view-button--active {
    border-color: #111827;
    background: #111827;
    color: #fff;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.18);
  }

  .explorer-toolbar__row {
    display: grid;
    grid-template-columns: minmax(230px, 1fr) minmax(150px, 0.42fr) minmax(175px, 0.48fr);

---
const API_URL =
  'https://script.google.com/macros/s/AKfycbw2o8bsw-UGn-qizyftLnuFSUwqR_5RITxhmqkBBCS9YoGkMhIsx97wkzUtv99DoNBJsw/exec';

const metrics = [
  {
    key: 'guitar',
    label: 'Guitar',
    longLabel: 'Guitar Hours',
    icon: '🎸',
    unit: 'hours',
  },
  {
    key: 'audiobooks',
    label: 'Audiobooks',
    longLabel: 'Audiobook Hours',
    icon: '📚',
    unit: 'hours',
  },
  {
    key: 'running',
    label: 'Running',
    longLabel: 'Running Miles',
    icon: '🏃‍♂️',
    unit: 'miles',
  },
  {
    key: 'diary',
    label: 'Diary',
    longLabel: 'Average Diary Words',
    icon: '📓',
    unit: 'words/day',
  },
];
---

<section id="graphs" class="dashboard-section graph-explorer" aria-labelledby="graphs-heading">
  <div class="section-heading">
    <p class="eyebrow">Interactive archive explorer</p>
    <h2 id="graphs-heading">See how the habits changed</h2>
    <p>
      Choose a metric, switch between monthly and cumulative views, and compare one year against another. Every summary below is calculated from the same monthly archive that draws the graph.
    </p>
  </div>

  <div class="explorer-shell">
    <div class="explorer-toolbar">
      <div class="control-group control-group--metrics">
        <span class="control-label">Metric</span>
        <div class="metric-tabs" id="metric-tabs" role="tablist" aria-label="Select a metric">
          {metrics.map((metric, index) => (
            <button
              type="button"
              class={`metric-tab ${index === 0 ? 'metric-tab--active' : ''}`}
              data-metric={metric.key}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
            >
              <span aria-hidden="true">{metric.icon}</span>
              <span>{metric.label}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="explorer-toolbar__row">
        <div class="control-group">
          <span class="control-label">View</span>
          <div class="view-toggle" id="view-toggle" aria-label="Select chart view">
            <button type="button" class="view-button view-button--active" data-view="monthly" aria-pressed="true">
              Monthly
            </button>
            <button type="button" class="view-button" data-view="cumulative" aria-pressed="false">
              Cumulative
            </button>
          </div>
        </div>

        <label class="select-control">
          <span class="control-label">Period</span>
          <select id="graph-year" aria-label="Select year"></select>
        </label>

        <label class="select-control">
          <span class="control-label">Compare</span>
          <select id="graph-compare" aria-label="Compare with another year">
            <option value="">No comparison</option>
          </select>
        </label>
      </div>
    </div>

    <div class="graph-summary" aria-label="Selected graph summary">
      <article class="summary-stat">
        <span id="summary-primary-label">Selected total</span>
        <strong id="summary-primary">—</strong>
      </article>
      <article class="summary-stat">
        <span id="summary-average-label">Monthly average</span>
        <strong id="summary-average">—</strong>
      </article>
      <article class="summary-stat">
        <span>Peak month</span>
        <strong id="summary-peak">—</strong>
      </article>
      <article class="summary-stat">
        <span id="summary-change-label">Change from prior year</span>
        <strong id="summary-change">—</strong>
      </article>
    </div>

    <div class="chart-panel">
      <div class="chart-panel__heading">
        <div>
          <p class="chart-panel__eyebrow" id="chart-period-label">2026 monthly view</p>
          <h3>
            <span id="chart-title-icon" aria-hidden="true">🎸</span>
            <span id="chart-title">Guitar hours</span>
          </h3>
        </div>
        <p class="chart-panel__unit" id="chart-unit">Hours per month</p>
      </div>

      <div id="main-chart" class="chart-host" aria-label="Interactive LifeLoggerz chart">
        <div class="chart-skeleton" aria-hidden="true"></div>
      </div>

      <div id="main-legend" class="chart-legend" aria-label="Chart legend"></div>
      <p id="chart-text-summary" class="sr-only" aria-live="polite"></p>
    </div>

    <details class="pattern-note" id="pattern-note">
      <summary>
        <span>What this pattern means</span>
        <span class="pattern-note__hint">Open context</span>
      </summary>
      <div class="pattern-note__content">
        <h3 id="story-title">Guitar is the slow compound interest of practice.</h3>
        <p id="story-body">
          This explanation changes with the selected metric so the numbers remain connected to the life behind them.
        </p>
        <div class="pattern-note__facts" id="story-facts"></div>
      </div>
    </details>
  </div>
</section>

<section id="hobby-time" class="dashboard-section hobby-section" aria-labelledby="hobby-heading">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">One timeline, several priorities</p>
      <h2 id="hobby-heading">Where my hobby time went</h2>
    </div>
    <p>
      This chart compares activities on one time scale. Running miles are converted at an estimated 10 minutes per mile, while dance appears automatically once the public archive supplies monthly dance hours.
    </p>
  </div>

  <div class="hobby-shell">
    <div class="hobby-controls">
      <label class="select-control">
        <span class="control-label">Year</span>
        <select id="hobby-year" aria-label="Select year for hobby chart"></select>
      </label>
      <div>
        <span class="control-label">Activities shown</span>
        <div id="hobby-toggles" class="hobby-toggles"></div>
      </div>
    </div>

    <div class="hobby-summary">
      <span>Total hobby time</span>
      <strong id="hobby-total">—</strong>
      <p id="hobby-availability">Loading available hour-based activities…</p>
    </div>

    <div id="hobby-chart" class="chart-host chart-host--hobby" aria-label="Combined hobby hours chart">
      <div class="chart-skeleton" aria-hidden="true"></div>
    </div>
    <div id="hobby-legend" class="chart-legend" aria-label="Hobby chart legend"></div>
  </div>
</section>

<section id="records" class="dashboard-section records-section" aria-labelledby="records-heading">
  <div class="section-heading">
    <p class="eyebrow">Beyond lifetime totals</p>
    <h2 id="records-heading">Personal records in the monthly archive</h2>
    <p>
      These records are calculated automatically from the public monthly feed. They update whenever the underlying archive changes.
    </p>
  </div>

  <div id="records-grid" class="records-grid" aria-live="polite">
    {metrics.map((metric) => (
      <article class="record-card record-card--loading" data-record-metric={metric.key}>
        <div class="record-card__heading">
          <span aria-hidden="true">{metric.icon}</span>
          <h3>{metric.label}</h3>
        </div>
        <dl>
          <div>
            <dt>Best month</dt>
            <dd data-record-month>Loading…</dd>
          </div>
          <div>
            <dt>Best year</dt>
            <dd data-record-year>Loading…</dd>
          </div>
        </dl>
      </article>
    ))}
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js" defer></script>

<script>
  (() => {
    const API_URL =
      'https://script.google.com/macros/s/AKfycbw2o8bsw-UGn-qizyftLnuFSUwqR_5RITxhmqkBBCS9YoGkMhIsx97wkzUtv99DoNBJsw/exec';
    const CACHE_KEY = 'lifeloggerz-monthly-archive-v5';
    const RUNNING_MINUTES_PER_MILE = 10;
    const RUNNING_HOURS_PER_MILE = RUNNING_MINUTES_PER_MILE / 60;
    const CURRENT_YEAR = new Date().getFullYear();
    const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const MONTH_LOOKUP = {
      jan: 'Jan', january: 'Jan', '1': 'Jan', '01': 'Jan',
      feb: 'Feb', february: 'Feb', '2': 'Feb', '02': 'Feb',
      mar: 'Mar', march: 'Mar', '3': 'Mar', '03': 'Mar',
      apr: 'Apr', april: 'Apr', '4': 'Apr', '04': 'Apr',
      may: 'May', '5': 'May', '05': 'May',
      jun: 'Jun', june: 'Jun', '6': 'Jun', '06': 'Jun',
      jul: 'Jul', july: 'Jul', '7': 'Jul', '07': 'Jul',
      aug: 'Aug', august: 'Aug', '8': 'Aug', '08': 'Aug',
      sep: 'Sep', sept: 'Sep', september: 'Sep', '9': 'Sep', '09': 'Sep',
      oct: 'Oct', october: 'Oct', '10': 'Oct',
      nov: 'Nov', november: 'Nov', '11': 'Nov',
      dec: 'Dec', december: 'Dec', '12': 'Dec',
    };

    const COLORS = {
      selected: '#2457ff',
      comparison: '#d97706',
      guitar: '#2457ff',
      audiobooks: '#7c3aed',
      dance: '#db2777',
      runninghours: '#0f8a5f',
      total: '#111827',
    };

    const METRICS = {
      guitar: {
        key: 'guitar',
        label: 'Guitar',
        title: 'Guitar hours',
        icon: '🎸',
        unit: 'hours',
        unitLabel: 'Hours per month',
        decimals: 0,
        primaryLabel: 'Selected total',
        averageLabel: 'Monthly average',
        storyTitle: 'Guitar is the slow compound interest of practice.',
        storyBody:
          'I returned to guitar on September 27, 2023 after giving it up several times. A ten-minute daily minimum removed the pressure to make every session ambitious. The graph shows the result: long stretches of maintenance interrupted by periods when a song, technique, or performance goal caught fire. Lower months usually mean that research, illness, travel, dance, or another priority temporarily won the competition for time.',
      },
      audiobooks: {
        key: 'audiobooks',
        label: 'Audiobooks',
        title: 'Audiobook hours',
        icon: '📚',
        unit: 'hours',
        unitLabel: 'Hours per month',
        decimals: 0,
        primaryLabel: 'Selected total',
        averageLabel: 'Monthly average',
        storyTitle: 'Audiobook hours are my background university.',
        storyBody:
          'Audiobooks began on February 10, 2023 and transformed commuting, chores, walking, and other low-focus time into a steady reading practice. High months often reflect more movement or travel. Low months can mean that music, conversation, research, or deliberate silence took over. The important pattern is not maximizing every month; it is making otherwise disposable time available for learning.',
      },
      running: {
        key: 'running',
        label: 'Running',
        title: 'Running miles',
        icon: '🏃‍♂️',
        unit: 'miles',
        unitLabel: 'Miles per month',
        decimals: 0,
        primaryLabel: 'Selected total',
        averageLabel: 'Monthly average',
        storyTitle: 'Running miles show the condition of my physical foundation.',
        storyBody:
          'I started running on September 26, 2023 after years of being unable to run more than a mile. The graph records training blocks, interruptions, and restarts rather than a perfect upward line. Peaks can reflect renewed motivation or a specific distance goal. Troughs often reflect weather, illness, deadlines, or time moving toward another activity.',
      },
      diary: {
        key: 'diary',
        label: 'Diary',
        title: 'Average diary words',
        icon: '📓',
        unit: 'words/day',
        unitLabel: 'Average words per day',
        decimals: 0,
        primaryLabel: 'Selected average',
        averageLabel: 'Months recorded',
        storyTitle: 'Diary words show how much life I am processing.',
        storyBody:
          'Daily diary logging began on March 16, 2022 and became the first layer of LifeLoggerz. Longer entries can reflect rich experiences, difficult decisions, heavy reflection, or a strong desire to preserve detail. Shorter entries are not failures; they can signal a quieter period or simply a more concise way of recording it.',
      },
    };

    const HOBBY_METRICS = {
      guitar: { key: 'guitar', label: 'Guitar', icon: '🎸', color: COLORS.guitar },
      audiobooks: { key: 'audiobooks', label: 'Audiobooks', icon: '📚', color: COLORS.audiobooks },
      dance: { key: 'dance', label: 'Dance', icon: '💃', color: COLORS.dance },
      runninghours: { key: 'runninghours', label: 'Running time (estimated)', icon: '🏃‍♂️', color: COLORS.runninghours },
    };

    const state = {
      data: [],
      metric: 'guitar',
      year: null,
      compareYear: null,
      view: 'monthly',
      hobbyYear: null,
      hobbyMetrics: new Set(),
      dataSource: 'live',
    };

    let mainResizeTimer = null;
    let hobbyResizeTimer = null;

    function canonicalMetric(value) {
      const raw = String(value || '')
        .trim()
        .toLowerCase()
        .replace(/[\s_-]+/g, '');

      if (['guitar', 'guitarhours'].includes(raw)) return 'guitar';
      if (['audiobook', 'audiobooks', 'audiobookhours', 'bookhours', 'books'].includes(raw)) return 'audiobooks';
      if (['running', 'run', 'runningmiles', 'milesran'].includes(raw)) return 'running';
      if (['diary', 'diarywords', 'averagediarywords'].includes(raw)) return 'diary';
      if (['dance', 'dancehours', 'dancing'].includes(raw)) return 'dance';
      if (['runninghours', 'runhours', 'runningtime'].includes(raw)) return 'runninghours';
      return raw;
    }

    function canonicalMonth(value) {
      const raw = String(value || '').trim().toLowerCase();
      return MONTH_LOOKUP[raw] || null;
    }

    function normalizeData(rawData) {
      const source = Array.isArray(rawData) ? rawData : Object.values(rawData || {});

      const normalized = source
        .map((row) => {
          const metric = canonicalMetric(row?.metric ?? row?.Metric ?? row?.category);
          const year = Number(row?.year ?? row?.Year);
          const month = canonicalMonth(row?.month ?? row?.Month);
          const value = Number(row?.value ?? row?.Value ?? row?.total);

          return {
            metric,
            year,
            month,
            value: Number.isFinite(value) ? value : 0,
            estimated: false,
          };
        })
        .filter((row) => row.metric && row.year && row.month && row.year <= CURRENT_YEAR);

      // Running is logged as distance. Derive an hour-based companion series for
      // the hobby-time graph using the stated assumption of 10 minutes per mile.
      // If measured running-hour rows are supplied later, they take precedence.
      const explicitRunningHours = new Set(
        normalized
          .filter((row) => row.metric === 'runninghours')
          .map((row) => `${row.year}-${row.month}`)
      );
      const derivedRunningHours = normalized
        .filter((row) => row.metric === 'running')
        .filter((row) => !explicitRunningHours.has(`${row.year}-${row.month}`))
        .map((row) => ({
          ...row,
          metric: 'runninghours',
          value: row.value * RUNNING_HOURS_PER_MILE,
          estimated: true,
        }));

      return [...normalized, ...derivedRunningHours]
        .sort((a, b) => a.year - b.year || MONTHS.indexOf(a.month) - MONTHS.indexOf(b.month));
    }

    function formatNumber(value, decimals = 0) {
      if (!Number.isFinite(value)) return '—';
      return new Intl.NumberFormat('en-US', {
        minimumFractionDigits: 0,
        maximumFractionDigits: decimals,
      }).format(value);
    }

    function formatMetricValue(metricKey, value, includeUnit = true) {
      const metric = METRICS[metricKey] || METRICS.guitar;
      const formatted = formatNumber(value, metric.decimals);
      return includeUnit ? `${formatted} ${metric.unit}` : formatted;
    }

    function formatRunningWithEstimate(miles) {
      return `${formatMetricValue('running', miles)} · ≈ ${formatNumber(miles * RUNNING_HOURS_PER_MILE, 1)} hours`;
    }

    function monthsForYear(year) {
      if (year === CURRENT_YEAR) return MONTHS.slice(0, new Date().getMonth() + 1);
      return MONTHS;
    }

    function yearsForMetric(metricKey) {
      return Array.from(
        new Set(state.data.filter((row) => row.metric === metricKey).map((row) => row.year))
      ).sort((a, b) => a - b);
    }

    function valuesForYear(metricKey, year) {
      return monthsForYear(year).map((month) => {
        const record = state.data.find(
          (row) => row.metric === metricKey && row.year === year && row.month === month
        );
        return {
          month,
          value: record ? Number(record.value) || 0 : 0,
          recorded: Boolean(record),
          estimated: Boolean(record?.estimated),
        };
      });
    }

    function transformSeries(metricKey, values, view) {
      if (view !== 'cumulative') return values.map((item) => ({ ...item }));

      if (metricKey === 'diary') {
        let total = 0;
        let count = 0;
        return values.map((item) => {
          if (item.recorded && item.value > 0) {
            total += item.value;
            count += 1;
          }
          return { ...item, value: count ? total / count : 0 };
        });
      }

      let running = 0;
      return values.map((item) => {
        running += item.value;
        return { ...item, value: running };
      });
    }

    function summarizeYear(metricKey, year, throughMonthIndex = null) {
      let values = valuesForYear(metricKey, year);
      if (Number.isInteger(throughMonthIndex) && throughMonthIndex >= 0) {
        values = values.filter((item) => MONTHS.indexOf(item.month) <= throughMonthIndex);
      }

      const recorded = values.filter((item) => item.recorded);
      const positive = recorded.filter((item) => item.value > 0);
      const metric = METRICS[metricKey] || METRICS.guitar;

      if (!recorded.length) {
        return {
          primary: 0,
          average: 0,
          peak: null,
          count: 0,
          metric,
        };
      }

      const total = recorded.reduce((sum, item) => sum + item.value, 0);
      const averageBase = metricKey === 'diary' ? positive : recorded;
      const average = averageBase.length
        ? averageBase.reduce((sum, item) => sum + item.value, 0) / averageBase.length
        : 0;
      const peak = recorded.reduce((best, item) => (!best || item.value > best.value ? item : best), null);

      return {
        primary: metricKey === 'diary' ? average : total,
        average,
        peak,
        count: recorded.length,
        metric,
      };
    }

    function lastRecordedMonthIndex(metricKey, year) {
      const indices = state.data
        .filter((row) => row.metric === metricKey && row.year === year)
        .map((row) => MONTHS.indexOf(row.month))
        .filter((index) => index >= 0);

      if (!indices.length) return -1;
      const latest = Math.max(...indices);
      return year === CURRENT_YEAR ? Math.min(latest, new Date().getMonth()) : latest;
    }

    function percentageChange(current, previous) {
      if (!Number.isFinite(previous) || previous === 0) return null;
      return ((current - previous) / Math.abs(previous)) * 100;
    }

    function updateUrl() {
      const url = new URL(window.location.href);
      url.searchParams.set('metric', state.metric);
      url.searchParams.set('year', String(state.year));
      url.searchParams.set('view', state.view);
      if (state.compareYear) url.searchParams.set('compare', String(state.compareYear));
      else url.searchParams.delete('compare');
      url.hash = 'graphs';
      history.replaceState({}, '', url);
    }

    function initialStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const metric = canonicalMetric(params.get('metric'));
      const view = params.get('view');
      const year = Number(params.get('year'));
      const compare = Number(params.get('compare'));

      if (METRICS[metric]) state.metric = metric;
      if (view === 'monthly' || view === 'cumulative') state.view = view;
      if (Number.isFinite(year) && year > 2000) state.year = year;
      if (Number.isFinite(compare) && compare > 2000) state.compareYear = compare;
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function setArchiveStatus(text) {
      const status = document.getElementById('archive-status');
      if (status) status.textContent = text;
    }

    async function loadArchive() {
      let cached = null;
      try {
        cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null');
      } catch (_error) {
        cached = null;
      }

      try {
        const response = await fetch(API_URL, { cache: 'no-store' });
        if (!response.ok) throw new Error(`Archive request failed: ${response.status}`);
        const raw = await response.json();
        const normalized = normalizeData(raw);
        if (!normalized.length) throw new Error('Archive returned no monthly records.');

        try {
          localStorage.setItem(CACHE_KEY, JSON.stringify({ data: raw, savedAt: Date.now() }));
        } catch (_storageError) {
          // Live data is still usable when browser storage is unavailable.
        }
        state.dataSource = 'live';
        setArchiveStatus('Monthly archive loaded');
        return normalized;
      } catch (_error) {
        if (cached?.data) {
          const normalized = normalizeData(cached.data);
          if (normalized.length) {
            state.dataSource = 'cached';
            setArchiveStatus('Using saved archive');
            return normalized;
          }
        }
        state.dataSource = 'fallback';
        setArchiveStatus('Saved totals shown');
        return [];
      }
    }

    function configureMetricTabs() {
      const tabs = Array.from(document.querySelectorAll('[data-metric]'));

      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-metric') === state.metric;
        tab.classList.toggle('metric-tab--active', active);
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');

        tab.addEventListener('click', () => {
          const metric = tab.getAttribute('data-metric');
          if (!metric || !METRICS[metric]) return;
          setMetric(metric, true);
        });

        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          const currentIndex = tabs.indexOf(tab);
          let nextIndex = currentIndex;
          if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
          if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabs.length;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = tabs.length - 1;
          tabs[nextIndex].focus();
          tabs[nextIndex].click();
        });
      });
    }

    function configureViewButtons() {
      document.querySelectorAll('[data-view]').forEach((button) => {
        const active = button.getAttribute('data-view') === state.view;
        button.classList.toggle('view-button--active', active);
        button.setAttribute('aria-pressed', String(active));

        button.addEventListener('click', () => {
          const view = button.getAttribute('data-view');
          if (view !== 'monthly' && view !== 'cumulative') return;
          state.view = view;
          document.querySelectorAll('[data-view]').forEach((candidate) => {
            const selected = candidate === button;
            candidate.classList.toggle('view-button--active', selected);
            candidate.setAttribute('aria-pressed', String(selected));
          });
          renderMainExplorer();
          updateUrl();
        });
      });
    }

    function setMetric(metricKey, updateAddress) {
      state.metric = metricKey;
      const years = yearsForMetric(metricKey);

      if (!years.includes(state.year)) {
        state.year = years.includes(CURRENT_YEAR) ? CURRENT_YEAR : years[years.length - 1] || CURRENT_YEAR;
      }
      if (!years.includes(state.compareYear) || state.compareYear === state.year) {
        state.compareYear = null;
      }

      document.querySelectorAll('[data-metric]').forEach((tab) => {
        const active = tab.getAttribute('data-metric') === state.metric;
        tab.classList.toggle('metric-tab--active', active);
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
      });

      updateYearControls();
      renderMainExplorer();
      if (updateAddress) updateUrl();
    }

    function updateYearControls() {
      const yearSelect = document.getElementById('graph-year');
      const compareSelect = document.getElementById('graph-compare');
      if (!yearSelect || !compareSelect) return;

      const years = yearsForMetric(state.metric);
      if (!years.length) {
        yearSelect.innerHTML = '<option>No years available</option>';
        compareSelect.innerHTML = '<option value="">No comparison</option>';
        yearSelect.disabled = true;
        compareSelect.disabled = true;
        return;
      }

      yearSelect.disabled = false;
      yearSelect.innerHTML = years
        .slice()
        .reverse()
        .map((year) => `<option value="${year}">${year}</option>`)
        .join('');
      yearSelect.value = String(state.year);

      const comparisonYears = years.filter((year) => year !== state.year).slice().reverse();
      compareSelect.disabled = !comparisonYears.length;
      compareSelect.innerHTML =
        '<option value="">No comparison</option>' +
        comparisonYears.map((year) => `<option value="${year}">${year}</option>`).join('');
      compareSelect.value = state.compareYear ? String(state.compareYear) : '';
    }

    function configureYearControls() {
      const yearSelect = document.getElementById('graph-year');
      const compareSelect = document.getElementById('graph-compare');

      yearSelect?.addEventListener('change', () => {
        state.year = Number(yearSelect.value);
        if (state.compareYear === state.year) state.compareYear = null;
        updateYearControls();
        renderMainExplorer();
        updateUrl();
      });

      compareSelect?.addEventListener('change', () => {
        state.compareYear = compareSelect.value ? Number(compareSelect.value) : null;
        renderMainExplorer();
        updateUrl();
      });
    }

    function updateSummaryCards() {
      const metric = METRICS[state.metric] || METRICS.guitar;
      const priorYear = state.year - 1;
      const throughMonthIndex = lastRecordedMonthIndex(state.metric, state.year);
      const summary = summarizeYear(state.metric, state.year, throughMonthIndex);
      const prior = summarizeYear(state.metric, priorYear, throughMonthIndex);
      const change = summary.count && prior.count ? percentageChange(summary.primary, prior.primary) : null;

      const primaryLabel = document.getElementById('summary-primary-label');
      const averageLabel = document.getElementById('summary-average-label');
      const changeLabel = document.getElementById('summary-change-label');
      const primary = document.getElementById('summary-primary');
      const average = document.getElementById('summary-average');
      const peak = document.getElementById('summary-peak');
      const changeElement = document.getElementById('summary-change');

      if (primaryLabel) primaryLabel.textContent = metric.primaryLabel;
      if (averageLabel) averageLabel.textContent = metric.averageLabel;
      if (changeLabel) {
        const throughLabel = throughMonthIndex >= 0 && throughMonthIndex < 11
          ? ` through ${MONTHS[throughMonthIndex]}`
          : '';
        changeLabel.textContent = `Change vs ${priorYear}${throughLabel}`;
      }
      if (primary) primary.textContent = formatMetricValue(state.metric, summary.primary);
      if (average) {
        average.textContent = state.metric === 'diary'
          ? `${summary.count} month${summary.count === 1 ? '' : 's'}`
          : formatMetricValue(state.metric, summary.average);
      }
      if (peak) {
        peak.textContent = summary.peak
          ? `${summary.peak.month} · ${formatMetricValue(state.metric, summary.peak.value)}`
          : 'No data';
      }
      if (changeElement) {
        if (change === null) {
          changeElement.textContent = 'No comparable baseline';
          changeElement.dataset.direction = 'neutral';
        } else {
          const sign = change > 0 ? '+' : '';
          changeElement.textContent = `${sign}${formatNumber(change, 1)}%`;
          changeElement.dataset.direction = change > 0 ? 'up' : change < 0 ? 'down' : 'neutral';
        }
      }
    }

    function updateStory() {
      const metric = METRICS[state.metric] || METRICS.guitar;
      const summary = summarizeYear(state.metric, state.year);
      const title = document.getElementById('story-title');
      const body = document.getElementById('story-body');
      const facts = document.getElementById('story-facts');

      if (title) title.textContent = metric.storyTitle;
      if (body) body.textContent = metric.storyBody;
      if (facts) {
        const viewText = state.view === 'cumulative'
          ? state.metric === 'diary' ? 'Running average' : 'Cumulative total'
          : 'Monthly values';
        const runningEstimate = state.metric === 'running'
          ? `<span>Estimated running time <strong>${escapeHtml(formatNumber(summary.primary * RUNNING_HOURS_PER_MILE, 1))} hours</strong></span>`
          : '';
        facts.innerHTML = `
          <span>Selected period <strong>${escapeHtml(state.year)}</strong></span>
          <span>View <strong>${escapeHtml(viewText)}</strong></span>
          <span>Months recorded <strong>${escapeHtml(summary.count)}</strong></span>
          ${runningEstimate}
        `;
      }
    }

    function renderMainExplorer() {
      const host = document.getElementById('main-chart');
      if (!host) return;

      const metric = METRICS[state.metric] || METRICS.guitar;
      const selectedRaw = valuesForYear(state.metric, state.year);
      const selected = transformSeries(state.metric, selectedRaw, state.view);
      const comparisonRaw = state.compareYear ? valuesForYear(state.metric, state.compareYear) : null;
      const comparison = comparisonRaw ? transformSeries(state.metric, comparisonRaw, state.view) : null;

      const title = document.getElementById('chart-title');
      const titleIcon = document.getElementById('chart-title-icon');
      const unit = document.getElementById('chart-unit');
      const period = document.getElementById('chart-period-label');

      if (title) title.textContent = metric.title;
      if (titleIcon) titleIcon.textContent = metric.icon;
      if (unit) {
        unit.textContent = state.view === 'cumulative'
          ? state.metric === 'diary' ? 'Running average words per day' : `Cumulative ${metric.unit}`
          : metric.unitLabel;
      }
      if (period) {
        period.textContent = `${state.year} ${state.view === 'cumulative' ? 'cumulative' : 'monthly'} view`;
      }

      updateSummaryCards();
      updateStory();
      drawLineChart(host, {
        metricKey: state.metric,
        selectedYear: state.year,
        selected,
        comparisonYear: state.compareYear,
        comparison,
        view: state.view,
      });
      updateMainLegend();
      updateTextSummary(selectedRaw);
    }

    function updateMainLegend() {
      const legend = document.getElementById('main-legend');
      if (!legend) return;
      legend.innerHTML = `
        <span><i style="--legend-color:${COLORS.selected}"></i>${escapeHtml(state.year)}</span>
        ${state.compareYear ? `<span><i class="legend-dashed" style="--legend-color:${COLORS.comparison}"></i>${escapeHtml(state.compareYear)}</span>` : ''}
      `;
    }

    function updateTextSummary(values) {
      const output = document.getElementById('chart-text-summary');
      if (!output) return;
      const metric = METRICS[state.metric] || METRICS.guitar;
      const readable = values
        .filter((item) => item.recorded)
        .map((item) => `${item.month}: ${formatMetricValue(state.metric, item.value)}`)
        .join('; ');
      output.textContent = `${metric.label}, ${state.year}. ${readable || 'No monthly records available.'}`;
    }

    function drawLineChart(host, options) {
      const d3 = window.d3;
      if (!d3) return;
      if (!state.data.length) {
        host.innerHTML = '<div class="chart-message">The monthly archive is unavailable. Saved headline totals remain visible above.</div>';
        return;
      }

      const width = Math.max(320, host.clientWidth || 900);
      const height = width < 560 ? 320 : 410;
      const margin = width < 560
        ? { top: 22, right: 14, bottom: 42, left: 46 }
        : { top: 28, right: 28, bottom: 48, left: 58 };

      host.innerHTML = '';
      const tooltip = document.createElement('div');
      tooltip.className = 'chart-tooltip';
      tooltip.hidden = true;
      host.appendChild(tooltip);

      const svg = d3
        .select(host)
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('role', 'img')
        .attr('aria-label', `${METRICS[options.metricKey].label} chart for ${options.selectedYear}`)
        .style('width', '100%')
        .style('height', 'auto');

      const allSeries = [options.selected, options.comparison || []];
      const maximum = d3.max(allSeries.flat(), (item) => Number(item.value) || 0) || 1;
      const yMaximum = maximum <= 10 ? 10 : maximum * 1.12;

      const x = d3
        .scalePoint()
        .domain(MONTHS)
        .range([margin.left, width - margin.right])
        .padding(0.3);

      const y = d3
        .scaleLinear()
        .domain([0, yMaximum])
        .nice()
        .range([height - margin.bottom, margin.top]);

      const visibleTicks = width < 520 ? MONTHS.filter((_month, index) => index % 2 === 0) : MONTHS;

      svg
        .append('g')
        .attr('class', 'chart-grid')
        .attr('transform', `translate(${margin.left},0)`)
        .call(d3.axisLeft(y).ticks(5).tickSize(-(width - margin.left - margin.right)).tickFormat(''))
        .call((group) => group.select('.domain').remove());

      svg
        .append('g')
        .attr('class', 'chart-axis')
        .attr('transform', `translate(0,${height - margin.bottom})`)
        .call(d3.axisBottom(x).tickValues(visibleTicks).tickSizeOuter(0));

      svg
        .append('g')
        .attr('class', 'chart-axis')
        .attr('transform', `translate(${margin.left},0)`)
        .call(d3.axisLeft(y).ticks(5).tickSizeOuter(0))
        .call((group) => group.select('.domain').remove());

      const line = d3
        .line()
        .x((item) => x(item.month))
        .y((item) => y(item.value))
        .curve(d3.curveMonotoneX);

      const area = d3
        .area()
        .x((item) => x(item.month))
        .y0(y(0))
        .y1((item) => y(item.value))
        .curve(d3.curveMonotoneX);

      svg
        .append('path')
        .datum(options.selected)
        .attr('class', 'chart-area')
        .attr('d', area);

      svg
        .append('path')
        .datum(options.selected)
        .attr('class', 'chart-line chart-line--selected')
        .attr('d', line);

      if (options.comparison?.length) {
        svg
          .append('path')
          .datum(options.comparison)
          .attr('class', 'chart-line chart-line--comparison')
          .attr('d', line);
      }

      function addPoints(series, color, year, comparison = false) {
        const points = svg
          .append('g')
          .selectAll('circle')
          .data(series)
          .join('circle')
          .attr('class', comparison ? 'chart-point chart-point--comparison' : 'chart-point')
          .attr('cx', (item) => x(item.month))
          .attr('cy', (item) => y(item.value))
          .attr('r', comparison ? 3.2 : 4.2)
          .attr('fill', color)
          .attr('tabindex', 0)
          .attr('aria-label', (item) => `${item.month} ${year}: ${formatMetricValue(options.metricKey, item.value)}`);

        function show(event, item) {
          tooltip.hidden = false;
          tooltip.innerHTML = `<strong>${escapeHtml(item.month)} ${escapeHtml(year)}</strong><span>${escapeHtml(formatMetricValue(options.metricKey, item.value))}</span>`;
          const hostRect = host.getBoundingClientRect();
          const targetRect = event.currentTarget.getBoundingClientRect();
          tooltip.style.left = `${targetRect.left - hostRect.left + targetRect.width / 2}px`;
          tooltip.style.top = `${targetRect.top - hostRect.top - 8}px`;
        }

        function hide() {
          tooltip.hidden = true;
        }

        points
          .on('mouseenter focus', show)
          .on('mouseleave blur', hide)
          .on('touchstart', (event, item) => {
            event.preventDefault();
            show(event, item);
          });
      }

      addPoints(options.selected, COLORS.selected, options.selectedYear, false);
      if (options.comparison?.length) addPoints(options.comparison, COLORS.comparison, options.comparisonYear, true);
    }

    function updateSnapshotCards() {
      Object.keys(METRICS).forEach((metricKey) => {
        const card = document.querySelector(`[data-dashboard-metric="${metricKey}"]`);
        if (!card) return;

        const currentSummary = summarizeYear(metricKey, CURRENT_YEAR);
        const allRows = state.data.filter((row) => row.metric === metricKey);
        const peak = allRows.reduce((best, row) => (!best || row.value > best.value ? row : best), null);
        const yearOutput = card.querySelector('[data-card-year]');
        const peakOutput = card.querySelector('[data-card-peak]');

        if (yearOutput) {
          if (!currentSummary.count) yearOutput.textContent = 'No 2026 data yet';
          else if (metricKey === 'diary') yearOutput.textContent = `${formatNumber(currentSummary.primary)} words/day`;
          else if (metricKey === 'running') yearOutput.textContent = formatRunningWithEstimate(currentSummary.primary);
          else yearOutput.textContent = formatMetricValue(metricKey, currentSummary.primary);
        }

        if (peakOutput) {
          peakOutput.textContent = peak
            ? `${peak.month} ${peak.year} · ${metricKey === 'running' ? formatRunningWithEstimate(peak.value) : formatMetricValue(metricKey, peak.value)}`
            : 'No monthly data';
        }
      });

      document.querySelectorAll('[data-open-metric]').forEach((button) => {
        if (button.dataset.listenerAttached === 'true') return;
        button.dataset.listenerAttached = 'true';
        button.addEventListener('click', () => {
          const metric = button.getAttribute('data-open-metric');
          if (!metric || !METRICS[metric]) return;
          setMetric(metric, true);
          document.getElementById('graphs')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    function updateRecords() {
      Object.keys(METRICS).forEach((metricKey) => {
        const card = document.querySelector(`[data-record-metric="${metricKey}"]`);
        if (!card) return;

        const rows = state.data.filter((row) => row.metric === metricKey);
        const bestMonth = rows.reduce((best, row) => (!best || row.value > best.value ? row : best), null);
        const years = yearsForMetric(metricKey);
        const bestYear = years
          .map((year) => ({ year, ...summarizeYear(metricKey, year) }))
          .reduce((best, item) => (!best || item.primary > best.primary ? item : best), null);

        const monthOutput = card.querySelector('[data-record-month]');
        const yearOutput = card.querySelector('[data-record-year]');

        if (monthOutput) {
          monthOutput.textContent = bestMonth
            ? `${bestMonth.month} ${bestMonth.year} · ${metricKey === 'running' ? formatRunningWithEstimate(bestMonth.value) : formatMetricValue(metricKey, bestMonth.value)}`
            : 'No data';
        }
        if (yearOutput) {
          yearOutput.textContent = bestYear
            ? `${bestYear.year} · ${metricKey === 'running' ? formatRunningWithEstimate(bestYear.primary) : formatMetricValue(metricKey, bestYear.primary)}`
            : 'No data';
        }
        card.classList.remove('record-card--loading');
      });
    }

    function availableHobbyMetrics() {
      return Object.keys(HOBBY_METRICS).filter((key) => state.data.some((row) => row.metric === key));
    }

    function hobbyYears() {
      const available = availableHobbyMetrics();
      return Array.from(
        new Set(state.data.filter((row) => available.includes(row.metric)).map((row) => row.year))
      ).sort((a, b) => a - b);
    }

    function configureHobbyControls() {
      const years = hobbyYears();
      const yearSelect = document.getElementById('hobby-year');
      const toggles = document.getElementById('hobby-toggles');
      const available = availableHobbyMetrics();

      state.hobbyYear = years.includes(CURRENT_YEAR) ? CURRENT_YEAR : years[years.length - 1] || CURRENT_YEAR;
      state.hobbyMetrics = new Set(available);

      if (yearSelect) {
        yearSelect.innerHTML = years.length
          ? years.slice().reverse().map((year) => `<option value="${year}">${year}</option>`).join('')
          : '<option>No data</option>';
        yearSelect.value = String(state.hobbyYear);
        yearSelect.disabled = !years.length;
        yearSelect.addEventListener('change', () => {
          state.hobbyYear = Number(yearSelect.value);
          renderHobbyChart();
        });
      }

      if (toggles) {
        if (!available.length) {
          toggles.innerHTML = '<span class="hobby-empty">No hour-based monthly series are available.</span>';
        } else {
          toggles.innerHTML = available
            .map((key) => {
              const metric = HOBBY_METRICS[key];
              return `
                <label class="hobby-toggle">
                  <input type="checkbox" value="${escapeHtml(key)}" checked />
                  <span style="--toggle-color:${metric.color}">${metric.icon} ${escapeHtml(metric.label)}</span>
                </label>
              `;
            })
            .join('');

          toggles.querySelectorAll('input').forEach((input) => {
            input.addEventListener('change', () => {
              if (input.checked) state.hobbyMetrics.add(input.value);
              else state.hobbyMetrics.delete(input.value);
              renderHobbyChart();
            });
          });
        }
      }

      renderHobbyChart();
    }

    function renderHobbyChart() {
      const host = document.getElementById('hobby-chart');
      const totalOutput = document.getElementById('hobby-total');
      const availability = document.getElementById('hobby-availability');
      const legend = document.getElementById('hobby-legend');
      if (!host || !totalOutput || !availability || !legend) return;

      const available = availableHobbyMetrics();
      const selectedKeys = available.filter((key) => state.hobbyMetrics.has(key));
      const missingLabels = Object.keys(HOBBY_METRICS)
        .filter((key) => !available.includes(key))
        .map((key) => HOBBY_METRICS[key].label);

      const runningIsEstimated = available.includes('runninghours') && state.data.some((row) => row.metric === 'runninghours' && row.estimated);
      availability.textContent = available.length
        ? `${available.map((key) => HOBBY_METRICS[key].label).join(', ')} are available.${runningIsEstimated ? ` Running uses ${RUNNING_MINUTES_PER_MILE} minutes per mile.` : ''}${missingLabels.length ? ` Waiting for: ${missingLabels.join(', ')}.` : ''}`
        : 'The public archive does not yet contain hour-based hobby series.';

      if (!selectedKeys.length) {
        host.innerHTML = '<div class="chart-message">Select at least one activity to draw the chart.</div>';
        totalOutput.textContent = '0 hours';
        legend.innerHTML = '';
        return;
      }

      const series = selectedKeys.map((key) => ({
        key,
        config: HOBBY_METRICS[key],
        values: valuesForYear(key, state.hobbyYear),
      }));

      const totalSeries = monthsForYear(state.hobbyYear).map((month) => ({
        month,
        value: series.reduce((sum, item) => {
          const point = item.values.find((candidate) => candidate.month === month);
          return sum + (point?.value || 0);
        }, 0),
      }));
      const total = totalSeries.reduce((sum, item) => sum + item.value, 0);
      totalOutput.textContent = `${formatNumber(total, 1)} hours in ${state.hobbyYear}`;

      drawHobbyChart(host, series, totalSeries);
      legend.innerHTML =
        series
          .map((item) => `<span><i style="--legend-color:${item.config.color}"></i>${escapeHtml(item.config.label)}</span>`)
          .join('') +
        `<span><i style="--legend-color:${COLORS.total}"></i>Total</span>`;
    }

    function drawHobbyChart(host, series, totalSeries) {
      const d3 = window.d3;
      if (!d3) return;
      const width = Math.max(320, host.clientWidth || 900);
      const height = width < 560 ? 315 : 390;
      const margin = width < 560
        ? { top: 20, right: 14, bottom: 42, left: 44 }
        : { top: 26, right: 28, bottom: 48, left: 55 };

      host.innerHTML = '';
      const svg = d3
        .select(host)
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('role', 'img')
        .attr('aria-label', `Hobby-time chart for ${state.hobbyYear}; running time is estimated at ${RUNNING_MINUTES_PER_MILE} minutes per mile`)
        .style('width', '100%')
        .style('height', 'auto');

      const maximum = d3.max([...series.flatMap((item) => item.values), ...totalSeries], (item) => item.value) || 1;
      const x = d3.scalePoint().domain(MONTHS).range([margin.left, width - margin.right]).padding(0.3);
      const y = d3.scaleLinear().domain([0, maximum * 1.12]).nice().range([height - margin.bottom, margin.top]);
      const visibleTicks = width < 520 ? MONTHS.filter((_month, index) => index % 2 === 0) : MONTHS;

      svg
        .append('g')
        .attr('class', 'chart-grid')
        .attr('transform', `translate(${margin.left},0)`)
        .call(d3.axisLeft(y).ticks(5).tickSize(-(width - margin.left - margin.right)).tickFormat(''))
        .call((group) => group.select('.domain').remove());

      svg
        .append('g')
        .attr('class', 'chart-axis')
        .attr('transform', `translate(0,${height - margin.bottom})`)
        .call(d3.axisBottom(x).tickValues(visibleTicks).tickSizeOuter(0));

      svg
        .append('g')
        .attr('class', 'chart-axis')
        .attr('transform', `translate(${margin.left},0)`)
        .call(d3.axisLeft(y).ticks(5).tickSizeOuter(0))
        .call((group) => group.select('.domain').remove());

      const line = d3
        .line()
        .x((item) => x(item.month))
        .y((item) => y(item.value))
        .curve(d3.curveMonotoneX);

      series.forEach((item) => {
        svg
          .append('path')
          .datum(item.values)
          .attr('fill', 'none')
          .attr('stroke', item.config.color)
          .attr('stroke-width', 2.4)
          .attr('opacity', 0.9)
          .attr('d', line);
      });

      svg
        .append('path')
        .datum(totalSeries)
        .attr('fill', 'none')
        .attr('stroke', COLORS.total)
        .attr('stroke-width', 3.5)
        .attr('d', line);
    }

    function configureResizeObservers() {
      const main = document.getElementById('main-chart');
      const hobby = document.getElementById('hobby-chart');
      if (!('ResizeObserver' in window)) return;

      if (main) {
        new ResizeObserver(() => {
          clearTimeout(mainResizeTimer);
          mainResizeTimer = setTimeout(renderMainExplorer, 120);
        }).observe(main);
      }

      if (hobby) {
        new ResizeObserver(() => {
          clearTimeout(hobbyResizeTimer);
          hobbyResizeTimer = setTimeout(renderHobbyChart, 120);
        }).observe(hobby);
      }
    }

    function waitForD3(callback) {
      if (window.d3) callback();
      else setTimeout(() => waitForD3(callback), 50);
    }

    async function initialize() {
      initialStateFromUrl();
      state.data = await loadArchive();

      const years = yearsForMetric(state.metric);
      if (!years.includes(state.year)) {
        state.year = years.includes(CURRENT_YEAR) ? CURRENT_YEAR : years[years.length - 1] || CURRENT_YEAR;
      }
      if (!years.includes(state.compareYear) || state.compareYear === state.year) state.compareYear = null;

      waitForD3(() => {
        configureMetricTabs();
        configureViewButtons();
        configureYearControls();
        updateYearControls();
        updateSnapshotCards();
        updateRecords();
        renderMainExplorer();
        configureHobbyControls();
        configureResizeObservers();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initialize, { once: true });
    } else {
      initialize();
    }
  })();
</script>


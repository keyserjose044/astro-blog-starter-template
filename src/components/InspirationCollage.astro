---
const inspirations = [
  {
    number: '01',
    title: 'Phil Von Stade',
    subtitle: 'Spreadsheet life logging',
    href: '#phil-von-stade',
    src: '/images_webp/phil_von_stade.webp',
    alt: 'Phil Von Stade presenting a life-logging spreadsheet',
  },
  {
    number: '02',
    title: 'Michael Phelps',
    subtitle: 'Journaling discipline',
    href: '#michael-phelps',
    src: '/images_webp/michael_phelps.webp',
    alt: 'Michael Phelps journaling inspiration image',
  },
  {
    number: '03',
    title: 'Quantified Self',
    subtitle: 'Life in data',
    href: '#quantified-self',
    src: '/images_webp/dailyvis.webp',
    alt: 'Quantified Self article screenshot',
  },
  {
    number: '04',
    title: 'Perfice',
    subtitle: 'Tracking life as an app',
    href: '#perfice',
    src: '/images_webp/perfice.webp',
    alt: 'Perfice life-tracking app screenshot',
  },
  {
    number: '05',
    title: 'VeganTechNomad',
    subtitle: 'Lightweight reflection',
    href: '#vegantechnomad',
    src: '/images_webp/vegantechnomad.webp',
    alt: 'VeganTechNomad YouTube channel screenshot',
  },
  {
    number: '06',
    title: 'Efficiency Is Everything',
    subtitle: 'Time and optimization',
    href: '#efficiency-is-everything',
    src: '/images_webp/efficiency_is_everything.webp',
    alt: 'Efficiency Is Everything website screenshot',
  },
  {
    number: '07',
    title: 'Raptitude',
    subtitle: 'Experiments in living',
    href: '#raptitude',
    src: '/images_webp/raptitude.webp',
    alt: 'Raptitude blog screenshot',
  },
  {
    number: '08',
    title: 'Feltron',
    subtitle: 'Data storytelling',
    href: '#feltron',
    src: '/images_webp/feltron.webp',
    alt: 'Feltron annual report screenshot',
  },
  {
    number: '09',
    title: 'RYOT',
    subtitle: 'A browsable media archive',
    href: '#ryot',
    src: '/images_webp/ryot.webp',
    alt: 'RYOT GitHub project screenshot',
  },
];
---

<section id="idea-map" class="inspiration-collage-block" aria-labelledby="inspiration-collage-title">
  <div class="collage-heading">
    <p class="eyebrow">The idea map</p>
    <h2 id="inspiration-collage-title">Nine sparks behind LifeLoggerz</h2>
    <p>Select an influence to jump directly to the story and the idea I carried forward.</p>
  </div>

  <nav class="inspiration-collage" aria-label="Jump to an inspiration">
    {inspirations.map((item) => (
      <a class="inspiration-tile" href={item.href} aria-label={`Jump to ${item.title}`}>
        <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
        <span class="tile-number" aria-hidden="true">{item.number}</span>
        <span class="tile-copy">
          <strong>{item.title}</strong>
          <small>{item.subtitle}</small>
        </span>
      </a>
    ))}
  </nav>
</section>

<style>
  .inspiration-collage-block {
    width: 100%;
    max-width: 1160px;
    margin: 2.25rem auto 4.5rem;
    scroll-margin-top: 6rem;
  }

  .collage-heading {
    max-width: 760px;
    margin: 0 auto 1.35rem;
    text-align: center;
  }

  .collage-heading h2 {
    margin: 0.3rem 0 0.55rem;
    color: #0f172a;
    font-size: clamp(1.85rem, 3vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .collage-heading p {
    margin: 0;
    color: #475569;
  }

  .eyebrow {
    color: #166534 !important;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .inspiration-collage {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .inspiration-tile {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 188px;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 22px;
    background: #111827;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.14);
    text-decoration: none;
    isolation: isolate;
    transform: translateZ(0);
  }

  .inspiration-tile::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    content: '';
    background:
      linear-gradient(to top, rgba(2, 6, 23, 0.88), rgba(2, 6, 23, 0.08) 67%),
      linear-gradient(to right, rgba(15, 23, 42, 0.18), transparent 45%);
  }

  .inspiration-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.28s ease, filter 0.28s ease;
  }

  .tile-number {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2;
    display: inline-grid;
    place-items: center;
    min-width: 2.2rem;
    min-height: 2.2rem;
    padding: 0.3rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.58);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    backdrop-filter: blur(10px);
  }

  .tile-copy {
    position: absolute;
    right: 1rem;
    bottom: 0.95rem;
    left: 1rem;
    z-index: 2;
    color: #fff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7);
  }

  .tile-copy strong,
  .tile-copy small {
    display: block;
  }

  .tile-copy strong {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.08;
  }

  .tile-copy small {
    margin-top: 0.28rem;
    font-size: 0.8rem;
    line-height: 1.25;
    opacity: 0.9;
  }

  .inspiration-tile:hover img,
  .inspiration-tile:focus-visible img {
    transform: scale(1.055);
    filter: brightness(0.93) saturate(1.05);
  }

  .inspiration-tile:hover {
    box-shadow: 0 20px 46px rgba(15, 23, 42, 0.2);
  }

  .inspiration-tile:focus-visible {
    outline: 3px solid #2563eb;
    outline-offset: 4px;
  }

  @media (max-width: 900px) {
    .inspiration-collage-block {
      margin-bottom: 3.75rem;
    }

    .inspiration-collage {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .inspiration-tile {
      min-height: 160px;
      border-radius: 19px;
    }

    .inspiration-tile:last-child {
      grid-column: 1 / -1;
      aspect-ratio: 2.15 / 1;
    }
  }

  @media (max-width: 520px) {
    .inspiration-collage-block {
      margin: 1.75rem auto 3rem;
    }

    .collage-heading {
      margin-bottom: 1rem;
      padding-inline: 0.2rem;
    }

    .collage-heading h2 {
      font-size: clamp(1.65rem, 8vw, 2rem);
    }

    .collage-heading p {
      font-size: 0.94rem;
      line-height: 1.5;
    }

    .inspiration-collage {
      gap: 0.62rem;
    }

    .inspiration-tile {
      min-height: 142px;
      border-radius: 16px;
    }

    .tile-number {
      top: 0.55rem;
      left: 0.55rem;
      min-width: 1.85rem;
      min-height: 1.85rem;
      font-size: 0.64rem;
    }

    .tile-copy {
      right: 0.7rem;
      bottom: 0.68rem;
      left: 0.7rem;
    }

    .tile-copy strong {
      font-size: 0.94rem;
    }

    .tile-copy small {
      font-size: 0.73rem;
    }
  }

  @media (max-width: 405px) {
    .inspiration-collage {
      grid-template-columns: 1fr;
    }

    .inspiration-tile,
    .inspiration-tile:last-child {
      grid-column: auto;
      min-height: 176px;
      aspect-ratio: 16 / 9;
    }

    .tile-copy strong {
      font-size: 1.02rem;
    }

    .tile-copy small {
      font-size: 0.78rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inspiration-tile img {
      transition: none;
    }
  }
</style>

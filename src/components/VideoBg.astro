---
/**
 * Full-page animated background wrapper for LifeLoggerz.
 *
 * The poster paints immediately. The optimized MP4 is small enough to preload
 * and autoplay without holding up the rest of the page.
 */

const base = import.meta.env.BASE_URL || '/';
const backgroundVideoSrc = `${base}backgrounds/waves.mp4?v=4`;
const backgroundPosterSrc = `${base}backgrounds/waves-poster.webp`;
---

<div class="page-with-video-bg">
  <video
    src={backgroundVideoSrc}
    poster={backgroundPosterSrc}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
    tabindex="-1"
    class="page-with-video-bg__video"
    data-lifeloggerz-background
  ></video>

  <div class="page-with-video-bg__content">
    <slot />
  </div>
</div>

<script is:inline>
  if (typeof window !== 'undefined') {
    const playBackgrounds = () => {
      document
        .querySelectorAll('[data-lifeloggerz-background]')
        .forEach((element) => {
          if (!(element instanceof HTMLVideoElement)) return;
          element.muted = true;
          element.defaultMuted = true;
          if (document.visibilityState === 'visible') {
            element.play().catch(() => {});
          }
        });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', playBackgrounds, { once: true });
    } else {
      playBackgrounds();
    }

    document.addEventListener('visibilitychange', () => {
      document
        .querySelectorAll('[data-lifeloggerz-background]')
        .forEach((element) => {
          if (!(element instanceof HTMLVideoElement)) return;
          if (document.visibilityState === 'hidden') {
            element.pause();
          } else {
            element.play().catch(() => {});
          }
        });
    });

    window.addEventListener('pageshow', playBackgrounds);
  }
</script>

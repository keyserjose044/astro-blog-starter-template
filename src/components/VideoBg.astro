---
/**
 * Full-page animated background wrapper for LifeLoggerz.
 *
 * Performance notes:
 * - A lightweight poster paints immediately.
 * - The MP4 is attached only after the page has loaded and the browser is idle.
 * - Reduced-motion and data-saver users keep the poster and never download the video.
 */

const base = import.meta.env.BASE_URL || '/';
const backgroundVideoSrc = `${base}backgrounds/waves.mp4?v=2`;
const backgroundPosterSrc = `${base}backgrounds/waves-poster.webp`;
---

<div class="page-with-video-bg">
  <video
    data-src={backgroundVideoSrc}
    poster={backgroundPosterSrc}
    muted
    loop
    playsinline
    preload="none"
    aria-hidden="true"
    tabindex="-1"
    class="page-with-video-bg__video"
  ></video>

  <div class="page-with-video-bg__content">
    <slot />
  </div>
</div>

<script is:inline>
  if (typeof window !== 'undefined') {
    const video = document.querySelector('.page-with-video-bg__video');

    if (video) {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      const saveData = Boolean(connection && connection.saveData);
      let started = false;

      const startVideo = () => {
        if (started || prefersReducedMotion || saveData) return;

        const source = video.dataset.src;
        if (!source) return;

        started = true;
        video.src = source;
        video.load();
        video.play().catch(() => {
          // The poster remains visible when autoplay is unavailable.
        });
      };

      const scheduleStart = () => {
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(startVideo, { timeout: 1200 });
        } else {
          window.setTimeout(startVideo, 500);
        }
      };

      if (document.readyState === 'complete') {
        scheduleStart();
      } else {
        window.addEventListener('load', scheduleStart, { once: true });
      }

      document.addEventListener('visibilitychange', () => {
        if (!started) return;

        if (document.visibilityState === 'hidden') {
          video.pause();
        } else {
          video.play().catch(() => {});
        }
      });

      window.addEventListener('pageshow', () => {
        if (started && document.visibilityState === 'visible') {
          video.play().catch(() => {});
        }
      });
    }
  }
</script>

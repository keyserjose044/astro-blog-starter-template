---
/**
 * Full-page animated background wrapper for LifeLoggerz.
 *
 * The poster paints immediately, while the muted MP4 begins loading and
 * playing as soon as the browser can render it.
 */

const base = import.meta.env.BASE_URL || '/';
const backgroundVideoSrc = `${base}backgrounds/waves.mp4?v=3`;
const backgroundPosterSrc = `${base}backgrounds/waves-poster.webp`;
---

<div class="page-with-video-bg">
  <video
    src={backgroundVideoSrc}
    poster={backgroundPosterSrc}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-hidden="true"
    tabindex="-1"
    class="page-with-video-bg__video"
    data-lifeloggerz-background
  ></video>

  <div class="page-with-video-bg__content">
    <slot />
  </div>
</div>

<script is:inline>
  if (typeof window !== 'undefined') {
    const startBackgroundVideos = () => {
      document
        .querySelectorAll('[data-lifeloggerz-background]')
        .forEach((video) => {
          if (!(video instanceof HTMLVideoElement)) return;

          video.muted = true;
          video.defaultMuted = true;

          const tryPlay = () => {
            if (document.visibilityState === 'hidden') return;
            video.play().catch(() => {
              // The poster remains visible if a browser temporarily blocks playback.
            });
          };

          if (video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
            tryPlay();
          } else {
            video.addEventListener('canplay', tryPlay, { once: true });
          }
        });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', startBackgroundVideos, { once: true });
    } else {
      startBackgroundVideos();
    }

    document.addEventListener('visibilitychange', () => {
      document
        .querySelectorAll('[data-lifeloggerz-background]')
        .forEach((video) => {
          if (!(video instanceof HTMLVideoElement)) return;

          if (document.visibilityState === 'hidden') {
            video.pause();
          } else {
            video.play().catch(() => {});
          }
        });
    });

    window.addEventListener('pageshow', startBackgroundVideos);
  }
</script>

---
export interface Props {
  href: string;
  title: string;
  pubDate?: Date | null;
  heroImage?: string;
  heroVideo?: string;
  description?: string;
  tags?: string[];
  category?: string;
  featured?: boolean;
  mediaFit?: 'cover' | 'contain';
}

const {
  href,
  title,
  pubDate,
  heroImage,
  heroVideo,
  description,
  tags = [],
  category,
  featured = false,
  mediaFit,
  ...rest
} = Astro.props;

const formattedDate =
  pubDate &&
  pubDate.toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const shouldContain =
  mediaFit === 'contain' ||
  heroImage?.includes('/templates/covers/') ||
  heroImage?.includes('template-cover');

const visibleTags = tags.slice(0, featured ? 4 : 3);
const isLcp = Boolean(rest['data-lcp']);
---

<li class:list={['blog-card', featured && 'blog-card--featured']} {...rest}>
  <a href={href} aria-label={title}>
    {(heroImage || heroVideo) && (
      <div class:list={['blog-card__media', shouldContain && 'blog-card__media--contain']}>
        {heroImage ? (
          <img
            src={heroImage}
            alt=""
            loading={isLcp ? 'eager' : 'lazy'}
            fetchpriority={isLcp ? 'high' : 'auto'}
            decoding={isLcp ? 'sync' : 'async'}
          />
        ) : heroVideo ? (
          <video autoplay muted loop playsinline preload={isLcp ? 'auto' : 'metadata'}>
            <source src={heroVideo} type="video/mp4" />
          </video>
        ) : null}
      </div>
    )}

    <div class="blog-card__body">
      <div class="blog-card__meta-row">
        {category && <span class="blog-card__category">{category}</span>}
        {pubDate ? (
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        ) : (
          <time aria-hidden="true">Undated</time>
        )}
      </div>

      <h3>{title}</h3>

      {description && <p>{description}</p>}

      {visibleTags.length > 0 && (
        <div class="blog-card__tags" aria-label="Post tags">
          {visibleTags.map((tag) => <span>{tag}</span>)}
        </div>
      )}
    </div>
  </a>
</li>

<style>
  .blog-card {
    list-style: none;
    min-width: 0;
  }

  .blog-card,
  .blog-card *,
  .blog-card *::before,
  .blog-card *::after {
    box-sizing: border-box;
  }

  .blog-card a {
    position: relative;
    display: flex;
    height: 100%;
    min-height: 100%;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(229, 233, 240, 0.95);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.97);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(15, 18, 25, 0.08);
    transform: translateY(0) scale(1);
    transition:
      transform 0.2s ease-out,
      box-shadow 0.2s ease-out,
      border-color 0.2s ease-out,
      filter 0.2s ease-out;
  }

  .blog-card__media {
    display: block;
    width: 100%;
    height: clamp(150px, 18vw, 190px);
    overflow: hidden;
    border-bottom: 1px solid rgba(229, 233, 240, 0.95);
    background: linear-gradient(135deg, rgba(248, 250, 252, 0.96), rgba(239, 246, 255, 0.8));
  }

  .blog-card__media img,
  .blog-card__media video {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 0;
    object-fit: cover;
    object-position: top left;
  }

  .blog-card__media--contain {
    padding: 0.7rem;
  }

  .blog-card__media--contain img,
  .blog-card__media--contain video {
    object-fit: contain;
    object-position: center;
    border-radius: 12px;
  }

  .blog-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1rem 1rem 1.1rem;
  }

  .blog-card__meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .blog-card__category {
    color: #0f4cff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .blog-card time {
    flex: 0 0 auto;
    color: #64748b;
    white-space: nowrap;
  }

  .blog-card h3 {
    min-width: 0;
    margin: 0;
    color: rgb(var(--black));
    font-size: clamp(1.05rem, 1.6vw, 1.28rem);
    letter-spacing: -0.025em;
    line-height: 1.16;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .blog-card p {
    display: -webkit-box;
    min-width: 0;
    overflow: hidden;
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 0.93rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.15rem;
  }

  .blog-card__tags span {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0.18rem 0.52rem;
    border: 1px solid rgba(15, 76, 255, 0.12);
    border-radius: 999px;
    background: rgba(15, 76, 255, 0.05);
    color: #334155;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .blog-card--featured a {
    border-radius: 24px;
  }

  .blog-card--featured .blog-card__media {
    height: clamp(210px, 28vw, 320px);
  }

  .blog-card--featured .blog-card__body {
    padding: clamp(1.1rem, 2vw, 1.35rem);
  }

  .blog-card--featured h3 {
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    letter-spacing: -0.04em;
  }

  .blog-card--featured p {
    max-width: 62ch;
    font-size: 1rem;
    -webkit-line-clamp: 4;
  }

  .blog-card a::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 70%;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.95) 35%,
      rgba(255, 255, 255, 0.6) 55%,
      rgba(255, 255, 255, 0) 100%
    );
    opacity: 0;
    transform: translateX(-150%) skewX(-20deg);
    transition:
      transform 0.7s ease-out,
      opacity 0.2s ease-out;
  }

  .blog-card a::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    padding: 2px;
    background: linear-gradient(
      120deg,
      rgba(56, 189, 248, 0) 0%,
      rgba(56, 189, 248, 1) 20%,
      rgba(37, 99, 235, 1) 50%,
      rgba(56, 189, 248, 1) 80%,
      rgba(56, 189, 248, 0) 100%
    );
    background-size: 250% 250%;
    background-position: 0% 50%;
    opacity: 0;
    transition:
      opacity 0.2s ease-out,
      background-position 0.6s ease-out;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  @keyframes border-pulse {
    0% {
      opacity: 0;
      background-position: 0% 50%;
    }
    15% {
      opacity: 1;
    }
    80% {
      opacity: 1;
      background-position: 200% 50%;
    }
    100% {
      opacity: 0;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .blog-card a:hover,
    .blog-card a:focus-visible {
      border-color: rgba(15, 76, 255, 0.28);
      box-shadow: 0 18px 44px rgba(15, 18, 25, 0.18);
      filter: brightness(1.02);
      outline: none;
      transform: translateY(-5px) scale(1.018);
    }

    .blog-card a:hover::before,
    .blog-card a:focus-visible::before {
      opacity: 1;
      transform: translateX(150%) skewX(-20deg);
    }

    .blog-card a:hover::after,
    .blog-card a:focus-visible::after {
      animation: border-pulse 0.6s ease-out;
    }

    .blog-card a:focus-visible {
      box-shadow:
        0 0 0 2px rgba(255, 255, 255, 0.9),
        0 0 0 4px rgba(94, 234, 212, 0.9),
        0 18px 44px rgba(15, 18, 25, 0.18);
    }
  }

  @media (max-width: 640px) {
    .blog-card a {
      border-radius: 16px;
    }

    .blog-card__media,
    .blog-card--featured .blog-card__media {
      height: 108px;
    }

    .blog-card__media--contain {
      padding: 0.45rem;
    }

    .blog-card__body,
    .blog-card--featured .blog-card__body {
      gap: 0.42rem;
      padding: 0.78rem 0.82rem 0.9rem;
    }

    .blog-card__meta-row {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 0.28rem 0.55rem;
      font-size: 0.7rem;
    }

    .blog-card h3,
    .blog-card--featured h3 {
      font-size: 1.02rem;
      line-height: 1.18;
    }

    .blog-card p,
    .blog-card--featured p {
      font-size: 0.86rem;
      line-height: 1.42;
      -webkit-line-clamp: 2;
    }

    .blog-card__tags span {
      min-height: 22px;
      padding-inline: 0.4rem;
      font-size: 0.66rem;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .blog-card a {
      transition: box-shadow 0.15s ease-out, border-color 0.15s ease-out;
      transform: none;
    }

    .blog-card a::before,
    .blog-card a::after {
      display: none;
    }

    .blog-card a:active {
      border-color: rgba(15, 76, 255, 0.25);
      box-shadow: 0 12px 28px rgba(15, 18, 25, 0.16);
    }
  }
</style>

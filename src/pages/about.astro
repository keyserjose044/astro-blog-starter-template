        transition-duration: 0.01ms !important;
      }
    }
  </style>

  <script>
    (() => {
      const el = document.getElementById('years-since');
      if (!el) return;

      const startString = el.dataset.start || '2023-01-01';
      const start = new Date(`${startString}T00:00:00`);
      const now = new Date();
      let elapsedYears = now.getFullYear() - start.getFullYear();
      const monthDifference = now.getMonth() - start.getMonth();
      const dayDifference = now.getDate() - start.getDate();

      if (monthDifference < 0 || (monthDifference === 0 && dayDifference < 0)) {
        elapsedYears--;
      }

      if (elapsedYears < 0) elapsedYears = 0;
      el.textContent = `${elapsedYears} year${elapsedYears === 1 ? '' : 's'}`;
    })();
  </script>
</AboutLayout>

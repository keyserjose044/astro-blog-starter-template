---
import AboutLayout from '../layouts/AboutLayout.astro';
import AboutPhotoBubble from '../components/AboutPhotoBubble.astro';

const trackingStart = new Date('2023-01-01T00:00:00');
const now = new Date();
let years = now.getFullYear() - trackingStart.getFullYear();
const monthDiff = now.getMonth() - trackingStart.getMonth();
const dayDiff = now.getDate() - trackingStart.getDate();

if (monthDiff < 0 || (monthDiff === 0 && dayDiff < 0)) years--;
if (years < 0) years = 0;

const yearsLabel = `${years} year${years === 1 ? '' : 's'}`;

const proofStats = [
  {
    value: 'Jan. 1, 2023',
    label: 'Tracking since',
    note: 'A continuous, evolving record',
  },
  {
    value: '150+',
    label: 'Variables tracked',
    note: 'From sleep to study to “blunders”',
  },
  {
    value: '≈ 5 min',
    label: 'Daily logging time',
    note: 'For the essential statistics',
  },
  {
    value: '4 tools',
    label: 'Core toolkit',
    note: 'Sheets, Apps Script, Python, and APIs',
  },
];

const timeline = [
  {
    year: '2023',
    title: 'Started tracking',
    text: 'I began with the basics: sleep, meals, work, study, routines, and the details I kept forgetting.',
  },
  {
    year: '2024',
    title: 'Connected the system',
    text: 'The spreadsheets grew into dashboards, formulas, scripts, APIs, and repeatable workflows.',
  },
  {
    year: '2025',
    title: 'Stopped optimizing everything',
    text: 'I reached the point where adding more data created less value. The system had to serve my life—not consume it.',
  },
  {
    year: 'Today',
    title: 'Sharing what survived',
    text: 'LifeLoggerz now collects the useful templates, code, public data, experiments, and lessons from the process.',
  },
];

const exploreCards = [
  {
    icon: '📊',
    title: 'See the Data',
    text: 'Explore the dashboards, long-term totals, records, and patterns behind the project.',
    href: '/stats/',
    cta: 'Open Stats',
  },
  {
    icon: '🧰',
    title: 'Use the Tools',
    text: 'Start with practical templates instead of rebuilding every spreadsheet and workflow from scratch.',
    href: '/templates/',
    cta: 'Browse Templates',
  },
  {
    icon: '📝',
    title: 'Read the Lessons',
    text: 'See what worked, what became excessive, and how the systems changed over time.',
    href: '/blog/',
    cta: 'Visit the Blog',
  },
  {
    icon: '🗂️',
    title: 'Explore the Archive',
    text: 'Browse the books, albums, art, and other pieces that make the data feel like a life rather than a ledger.',
    href: '/books/',
    cta: 'Start with Books',
  },
];

const lifeCards = [
  {
    icon: '🎸',
    title: 'Guitar',
    text: 'Practicing, singing, and learning music without turning every session into another optimization project.',
  },
  {
    icon: '💃',
    title: 'Dance',
    text: 'Making room for cumbia, bachata, salsa, and the uncomfortable work of being a beginner again.',
  },
  {
    icon: '🏃',
    title: 'Running',
    text: 'Using simple records to support consistency—not to make movement feel like homework.',
  },
  {
    icon: '🎧',
    title: 'Audiobooks',
    text: 'Turning commutes and chores into thousands of hours of reading and listening.',
  },
  {
    icon: '🌍',
    title: 'Languages',
    text: 'Learning slowly across years, with curiosity allowed to matter more than perfect efficiency.',
  },
  {
    icon: '👨‍👩‍👦',
    title: 'Family',
    text: 'Protecting time for the people and memories that no dashboard can replace.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About LifeLoggerz',
  description:
    'The story, philosophy, tools, and person behind LifeLoggerz, a public personal data and systems project by José.',
  dateModified: '2026-07-15',
  mainEntity: {
    '@type': 'Person',
    name: 'José',
    description:
      'Civil engineering PhD student, researcher, systems builder, and creator of LifeLoggerz.',
    email: 'mailto:lifeloggerz.official@gmail.com',
    knowsAbout: [
      'Personal data tracking',
      'Google Sheets',
      'Google Apps Script',
      'Python',
      'Data visualization',
      'Civil engineering research',
    ],
  },
};
---

<AboutLayout
  title="About LifeLoggerz"
  description="A personal operating system built from years of daily data—and the story of the person behind it."
  pubDate="2026-07-15"
  wide={true}
  showViews={false}
>
  <AboutPhotoBubble
    slot="hero"
    src="/images/about-lifeloggerz.gif"
    alt="Family gathered while young José draws at the table."
    bubbleText="Déjenme terminar esto..."
    hotspotBottom="8%"
    hotspotLeft="27%"
    hotspotWidth="24%"
    hotspotHeight="32%"
    bubbleBottom="40%"
    bubbleLeft="45%"
  />

  <main class="about-page">
    <section class="intro-panel" aria-labelledby="intro-title">
      <div class="section-kicker">The person and purpose behind the project</div>
      <h2 id="intro-title">A searchable record of a life in progress</h2>
      <p class="intro-lede">
        I’m <strong>José</strong>, the kid sitting with a pen and paper in the photo above. Today, I’m a civil engineering PhD student, researcher, and the person behind <strong>LifeLoggerz</strong>.
      </p>
      <p>
        I built this project by turning messy routines into repeatable systems: Google Sheets dashboards, Apps Script automations, Python tools, and small workflows that help research and daily life run more smoothly. What began as a few personal logs became part public dashboard, part personal archive, and part toolkit for anyone who wants to build a system of their own.
      </p>

      <div class="intro-actions" aria-label="Explore LifeLoggerz">
        <a class="button button-primary" href="/stats/">Explore the System <span aria-hidden="true">→</span></a>
        <a class="button button-secondary" href="/templates/">Use the Templates</a>
      </div>
    </section>

    <section class="proof-grid" aria-label="LifeLoggerz at a glance">
      {proofStats.map((stat) => (
        <article class="proof-card">
          <p class="proof-value">{stat.value}</p>
          <h3>{stat.label}</h3>
          <p>{stat.note}</p>
        </article>
      ))}
    </section>

    <section class="content-section origin-section" aria-labelledby="origin-title">
      <div class="section-heading">
        <div class="section-kicker">The origin story</div>
        <h2 id="origin-title">From one spreadsheet to a personal operating system</h2>
        <p>
          I started with no meaningful Excel or Google Sheets experience. I learned one formula at a time, then formatting, dashboards, Apps Script, APIs, and Python. The important part was never technical brilliance. It was showing up, improving one friction point, and keeping the system alive long enough for it to become useful.
        </p>
      </div>

      <ol class="timeline">
        {timeline.map((item) => (
          <li class="timeline-item">
            <div class="timeline-marker" aria-hidden="true"></div>
            <div class="timeline-card">
              <p class="timeline-year">{item.year}</p>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="origin-note">
        Today, logging the essential statistics takes about <strong>five minutes</strong>. Diary entries take longer. No matter how tired I am, <strong>I still log it.</strong>
      </p>

      <p class="origin-story-link">
        <a href="/blog/rawdatapost2025/">See how the 2023, 2024, and 2025 Raw Data systems evolved <span aria-hidden="true">→</span></a>
      </p>
    </section>

    <section class="content-section" aria-labelledby="what-title">
      <div class="section-heading compact-heading">
        <div class="section-kicker">What this site contains</div>
        <h2 id="what-title">LifeLoggerz is more than a collection of charts</h2>
        <p>
          It connects daily records, diary entries, hobbies, books, music, art, health, work, and research into a history that can be explored instead of forgotten.
        </p>
      </div>

      <div class="explore-grid">
        {exploreCards.map((card) => (
          <a class="explore-card" href={card.href}>
            <span class="card-icon" aria-hidden="true">{card.icon}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <span class="card-link">{card.cta} <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>

      <nav class="archive-links" aria-label="More archive sections">
        <span>More of the archive:</span>
        <a href="/albums/">Albums</a>
        <a href="/art/">Art</a>
        <a href="/faq/">FAQ</a>
      </nav>
    </section>

    <section class="philosophy-section" aria-labelledby="philosophy-title">
      <div class="philosophy-copy">
        <div class="section-kicker">The philosophy</div>
        <h2 id="philosophy-title">Tracking is a tool, not the goal</h2>
        <p>
          Small habits compound, but more data is not automatically better. I now track more than 150 variables—from sleep, food, health, work, and study to music, books, and “blunders.” That does <em>not</em> mean everyone should do the same.
        </p>
        <p>
          A good system should reduce mental load, preserve useful memories, and improve decisions. When it becomes another obligation that adds more friction than clarity, it needs to be simplified.
        </p>
      </div>

      <div class="principles-card">
        <h3>What I believe now</h3>
        <ul>
          <li>You do not need to track everything.</li>
          <li>Keep only the data that earns its place.</li>
          <li>Automation should remove repetition, not hide understanding.</li>
          <li>The system should make life easier to live—not harder to document.</li>
        </ul>
      </div>
    </section>

    <aside class="statement-card" aria-label="LifeLoggerz guiding principle">
      <span class="statement-mark" aria-hidden="true">“</span>
      <blockquote>
        The purpose was never to spend my entire life maintaining a spreadsheet. It was to build systems that returned time and attention to me.
      </blockquote>
    </aside>

    <section class="content-section" aria-labelledby="room-title">
      <div class="section-heading compact-heading">
        <div class="section-kicker">What the system makes room for</div>
        <h2 id="room-title">Optimization created the space. Now I use it.</h2>
        <p>
          For a while, improving these systems was nearly my only hobby. By May 2025, I had reached diminishing returns. The system no longer needed constant expansion, so I stepped back and redirected that energy toward living.
        </p>
      </div>

      <div class="life-grid">
        {lifeCards.map((card) => (
          <article class="life-card">
            <span class="life-icon" aria-hidden="true">{card.icon}</span>
            <div>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="profile-section" aria-labelledby="profile-title">
      <div class="profile-heading">
        <div class="section-kicker">The person behind the data</div>
        <h2 id="profile-title">About José</h2>
      </div>

      <div class="profile-grid">
        <div class="profile-copy">
          <p>
            I’m a civil engineering PhD student and researcher who became a systems builder out of necessity. I taught myself spreadsheets, automation, Python, and data visualization because I kept finding repetitive problems that could be solved once and reused.
          </p>
          <p>
            LifeLoggerz is the public side of that instinct: document the process, preserve what works, admit what did not, and make the useful parts easier for someone else to borrow.
          </p>
        </div>

        <ul class="profile-facts" aria-label="José's areas of work and interest">
          <li><span aria-hidden="true">🎓</span> Civil engineering PhD student</li>
          <li><span aria-hidden="true">🔬</span> Researcher and data-driven problem solver</li>
          <li><span aria-hidden="true">⚙️</span> Self-taught systems and automation builder</li>
          <li><span aria-hidden="true">📚</span> Lifelong learner, reader, and archivist</li>
        </ul>
      </div>
    </section>

    <section class="closing-section" aria-labelledby="closing-title">
      <div class="closing-copy">
        <div class="section-kicker">Start smaller than I did</div>
        <h2 id="closing-title">Build a system that fits your life</h2>
        <p>
          Start with one useful variable. Keep what helps. Remove what does not. Let the system grow only when it earns its place.
        </p>
      </div>

      <div class="closing-actions">
        <a class="button button-primary" href="/templates/">Browse the Templates</a>
        <a class="button button-secondary" href="/faq/">Read the FAQ</a>
        <a class="button button-quiet" href="mailto:lifeloggerz.official@gmail.com">Contact José</a>
      </div>

      <p class="contact-line">
        Questions, suggestions, or something interesting you are building?
        <a href="mailto:lifeloggerz.official@gmail.com">lifeloggerz.official@gmail.com</a>
      </p>

      <div class="page-meta">
        <span>Tracking for <strong id="years-since" data-start="2023-01-01">{yearsLabel}</strong></span>
        <span aria-hidden="true">•</span>
        <span>Last updated July 2026</span>
      </div>
    </section>
  </main>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <style is:global>
    .about-page,
    .about-page * {
      box-sizing: border-box;
    }

    .about-page {
      --about-ink: #15171b;
      --about-muted: #5a606b;
      --about-border: #dfe3e8;
      --about-surface: #ffffff;
      --about-soft: #f4f6f8;
      --about-accent: #245c46;
      --about-accent-dark: #174433;
      --about-accent-soft: #e9f2ed;
      --about-gold-soft: #fff6d8;
      --about-shadow: 0 14px 38px rgba(25, 33, 44, 0.09);

      width: min(1120px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 1.25rem 0 4rem;
      color: var(--about-ink);
      font-size: 1rem;
      line-height: 1.72;
    }

    .about-page h2,
    .about-page h3,
    .about-page p,
    .about-page blockquote {
      color: var(--about-ink);
    }

    .about-page h2,
    .about-page h3 {
      line-height: 1.16;
      margin: 0;
      text-wrap: balance;
    }

    .about-page h2 {
      font-size: clamp(1.8rem, 4vw, 2.75rem);
      letter-spacing: -0.035em;
    }

    .about-page h3 {
      font-size: 1.08rem;
      letter-spacing: -0.01em;
    }

    .about-page p {
      margin: 0;
    }

    .about-page a {
      color: inherit;
    }

    .section-kicker {
      margin-bottom: 0.65rem;
      color: var(--about-accent-dark);
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      line-height: 1.3;
      text-transform: uppercase;
    }

    .intro-panel {
      max-width: 940px;
      margin: 0 auto;
      padding: clamp(1.5rem, 4vw, 3rem);
      border: 1px solid var(--about-border);
      border-radius: 28px;
      background: var(--about-surface);
      box-shadow: var(--about-shadow);
      text-align: left;
    }

    .intro-panel h2 {
      max-width: 780px;
      margin-bottom: 1.15rem;
    }

    .intro-panel > p {
      max-width: 800px;
      color: var(--about-muted);
      font-size: clamp(1rem, 1.5vw, 1.08rem);
    }

    .intro-panel > p + p {
      margin-top: 0.9rem;
    }

    .intro-lede {
      font-size: clamp(1.08rem, 2vw, 1.25rem) !important;
    }

    .intro-actions,
    .closing-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .button {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      padding: 0.72rem 1rem;
      border: 1px solid transparent;
      border-radius: 12px;
      font-size: 0.94rem;
      font-weight: 750;
      line-height: 1.2;
      text-align: center;
      text-decoration: none !important;
      transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
    }

    .button:hover {
      transform: translateY(-2px);
    }

    .button-primary {
      background: var(--about-accent);
      color: #ffffff !important;
      box-shadow: 0 8px 18px rgba(36, 92, 70, 0.2);
    }

    .button-primary:hover {
      background: var(--about-accent-dark);
    }

    .button-secondary {
      border-color: #cbd2d9;
      background: #ffffff;
      color: var(--about-ink) !important;
    }

    .button-secondary:hover {
      background: var(--about-soft);
    }

    .button-quiet {
      border-color: transparent;
      background: transparent;
      color: var(--about-accent-dark) !important;
      text-decoration: underline !important;
      text-underline-offset: 0.25em;
    }

    .proof-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
      margin: 1rem auto 0;
    }

    .proof-card {
      min-width: 0;
      padding: 1.2rem;
      border: 1px solid var(--about-border);
      border-radius: 18px;
      background: var(--about-surface);
    }

    .proof-value {
      margin-bottom: 0.45rem !important;
      color: var(--about-accent-dark) !important;
      font-size: clamp(1.25rem, 2.2vw, 1.65rem);
      font-weight: 850;
      letter-spacing: -0.035em;
      line-height: 1.05;
    }

    .proof-card h3 {
      margin-bottom: 0.35rem;
      font-size: 0.96rem;
    }

    .proof-card > p:last-child {
      color: var(--about-muted);
      font-size: 0.83rem;
      line-height: 1.45;
    }

    .content-section,
    .philosophy-section,
    .profile-section,
    .closing-section {
      margin-top: clamp(3.75rem, 8vw, 6.5rem);
    }

    .section-heading {
      max-width: 790px;
      margin: 0 auto 2rem;
      text-align: center;
    }

    .section-heading h2 {
      margin-bottom: 1rem;
    }

    .section-heading p {
      color: var(--about-muted);
      font-size: 1.04rem;
    }

    .compact-heading {
      margin-bottom: 1.65rem;
    }

    .origin-section {
      max-width: 920px;
      margin-right: auto;
      margin-left: auto;
    }

    .timeline {
      position: relative;
      display: grid;
      gap: 1rem;
      margin: 2rem 0 0;
      padding: 0;
      list-style: none;
    }

    .timeline::before {
      position: absolute;
      top: 1rem;
      bottom: 1rem;
      left: 18px;
      width: 2px;
      background: #c9d9d0;
      content: '';
    }

    .timeline-item {
      position: relative;
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr);
      gap: 1rem;
      align-items: start;
    }

    .timeline-marker {
      position: relative;
      z-index: 1;
      width: 16px;
      height: 16px;
      margin: 1.22rem 0 0 11px;
      border: 4px solid #ffffff;
      border-radius: 50%;
      background: var(--about-accent);
      box-shadow: 0 0 0 1px #b9cfc3;
    }

    .timeline-card {
      padding: 1.15rem 1.25rem;
      border: 1px solid var(--about-border);
      border-radius: 16px;
      background: var(--about-surface);
    }

    .timeline-year {
      margin-bottom: 0.3rem !important;
      color: var(--about-accent-dark) !important;
      font-size: 0.75rem;
      font-weight: 850;
      letter-spacing: 0.1em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .timeline-card h3 {
      margin-bottom: 0.45rem;
    }

    .timeline-card p:last-child {
      color: var(--about-muted);
      font-size: 0.94rem;
    }

    .origin-note {
      max-width: 780px;
      margin: 1.15rem auto 0 !important;
      padding: 1rem 1.15rem;
      border-left: 4px solid var(--about-accent);
      border-radius: 0 12px 12px 0;
      background: var(--about-accent-soft);
      color: #26372f !important;
    }

    .origin-story-link {
      margin-top: 1rem !important;
      text-align: center;
    }

    .origin-story-link a {
      color: var(--about-accent-dark);
      font-size: 0.92rem;
      font-weight: 800;
      text-underline-offset: 0.22em;
    }

    .explore-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .explore-card {
      display: flex;
      min-width: 0;
      min-height: 260px;
      flex-direction: column;
      padding: 1.35rem;
      border: 1px solid var(--about-border);
      border-radius: 20px;
      background: var(--about-surface);
      box-shadow: 0 8px 26px rgba(25, 33, 44, 0.06);
      text-decoration: none !important;
      transition: transform 170ms ease, border-color 170ms ease, box-shadow 170ms ease;
    }

    .explore-card:hover {
      transform: translateY(-4px);
      border-color: #aabfb4;
      box-shadow: 0 14px 34px rgba(25, 33, 44, 0.11);
    }

    .card-icon {
      display: grid;
      width: 44px;
      height: 44px;
      place-items: center;
      margin-bottom: 1rem;
      border-radius: 13px;
      background: var(--about-accent-soft);
      font-size: 1.35rem;
    }

    .explore-card h3 {
      margin-bottom: 0.55rem;
    }

    .explore-card p {
      color: var(--about-muted);
      font-size: 0.93rem;
      line-height: 1.58;
    }

    .card-link {
      margin-top: auto;
      padding-top: 1rem;
      color: var(--about-accent-dark);
      font-size: 0.88rem;
      font-weight: 800;
    }

    .archive-links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.65rem 1rem;
      margin-top: 1.2rem;
      color: var(--about-muted);
      font-size: 0.9rem;
    }

    .archive-links a {
      color: var(--about-accent-dark);
      font-weight: 750;
      text-underline-offset: 0.2em;
    }

    .philosophy-section {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      gap: 1.25rem;
      align-items: stretch;
      padding: clamp(1.5rem, 4vw, 2.75rem);
      border: 1px solid #cddfd5;
      border-radius: 26px;
      background: var(--about-accent-soft);
    }

    .philosophy-copy h2 {
      margin-bottom: 1rem;
    }

    .philosophy-copy p {
      color: #33453c;
    }

    .philosophy-copy p + p {
      margin-top: 0.85rem;
    }

    .principles-card {
      align-self: stretch;
      padding: 1.35rem;
      border: 1px solid #bfd2c8;
      border-radius: 18px;
      background: #ffffff;
    }

    .principles-card h3 {
      margin-bottom: 0.85rem;
    }

    .principles-card ul {
      display: grid;
      gap: 0.65rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .principles-card li {
      position: relative;
      padding-left: 1.55rem;
      color: #38423d;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .principles-card li::before {
      position: absolute;
      top: 0.1rem;
      left: 0;
      color: var(--about-accent);
      font-weight: 900;
      content: '✓';
    }

    .statement-card {
      position: relative;
      max-width: 900px;

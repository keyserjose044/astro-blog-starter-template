---
import Layout from '../layouts/BlogPost.astro';
import StatsGraphs from '../components/StatsGraphs.astro';

const showProhibitions = false;
const showProjects = false;

const stats = [
  {
    icon: '🏃‍♂️',
    label: 'Running Miles',
    key: 'runningMiles',
    value: '445',
    note: 'Lifetime logged running distance.',
  },
  {
    icon: '📔',
    label: 'Diary Words',
    key: 'diaryWords',
    value: '100000',
    note: 'Words written in my diary.',
  },
  {
    icon: '🎸',
    label: 'Guitar Hours',
    key: 'guitarHours',
    value: '419',
    note: 'Deliberate practice hours.',
  },
  {
    icon: '📚',
    label: 'Audiobook Hours',
    key: 'booksCount',
    value: '400',
    note: 'Total listening hours.',
  },
];

const prohibitions = [
  {
    icon: '🚫',
    title: 'No Alcohol',
    subtitle: 'Clarity > Numbing',
    description: 'Alcohol blunts awareness, recovery, and discipline. I do not drink.',
  },
  {
    icon: '📵',
    title: 'No Social Media Scrolling',
    subtitle: 'Creation > Consumption',
    description: 'I use social media for posting, not for browsing feeds.',
  },
  {
    icon: '⚔️',
    title: 'No Drama or Gossip',
    subtitle: 'Focus > Noise',
    description: 'Interpersonal chaos kills deep work, so I stay clear of it.',
  },
  {
    icon: '🛌',
    title: 'No Oversleeping',
    subtitle: 'Structure > Drift',
    description: 'Morning momentum sets the tone, so I do not sleep in.',
  },
  {
    icon: '🥦',
    title: 'No Junk Food Bingeing',
    subtitle: 'Energy > Impulse',
    description: 'Clean fuel supports cleaner thinking and better performance.',
  },
  {
    icon: '🎮',
    title: 'No Mindless Entertainment',
    subtitle: 'Deliberate Leisure > Passive Dopamine',
    description: 'No bingewatching or doomscrolling, only intentional fun.',
  },
];

const projects = [
  {
    title: 'LifeLoggerz Blog & Systems',
    blurb: 'Documenting the Google Sheets and Python ecosystem that runs my life.',
    status: 'WIP',
    tags: ['Writing', 'Meta-Tracking', 'Systems'],
  },
  {
    title: 'Guitar & Music Study',
    blurb: 'Structured practice on flamenco, mariachi, and classical pieces.',
    status: 'WIP',
    tags: ['Guitar', 'Practice', 'Art'],
  },
  {
    title: 'Lab Automation Scripts',
    blurb: 'Python tools for calorimetry, TGA, Load-CMOD, and research workflows.',
    status: 'WIP',
    tags: ['Python', 'Research', 'Automation'],
  },
  {
    title: 'Research Paper Pipeline',
    blurb: 'From reading papers to databasing figures, mix designs, and results.',
    status: 'WIP',
    tags: ['Research', 'Knowledge Base'],
  },
];
---

<Layout
  title="Stats & Systems"
  description="A numbers-first snapshot of who I am, what I track, and the systems I use."
  heroImage="/images_webp/stilllife.webp"
  wide={true}
  showViews={false}
>
  <div class="stats-page">
    <p class="intro">
      This page is my extended About. It shows the numbers I track and the systems I actively build.
    </p>

    <section class="section" aria-labelledby="snapshot-heading">
      <h2 id="snapshot-heading">📊 Snapshot Stats</h2>
      <p class="section-hint">
        High-level stats pulled from my tracking sheets and logs. Not exhaustive, just a glimpse.
      </p>

      <div class="stats-grid">
        {stats.map((item) => (
          <article class="card card--stat">
            <div class="icon-bubble">{item.icon}</div>
            <div class="stat-label">{item.label}</div>
            <div class="stat-value" data-stat-key={item.key}>{item.value}</div>
            {item.note ? <p class="muted">{item.note}</p> : null}
          </article>
        ))}
      </div>
    </section>

    <StatsGraphs />

    {showProhibitions ? (
      <section class="section" aria-labelledby="prohibitions-heading">
        <h2 id="prohibitions-heading">🚫 Prohibitions</h2>
        <p class="section-hint">
          A lot of my productivity comes from what I do not do. These constraints protect my time, focus, and identity.
        </p>

        <div class="stats-grid">
          {prohibitions.map((item) => (
            <article class="card card--prohibition">
              <div class="icon-bubble">{item.icon}</div>
              <h3>{item.title}</h3>
              <p class="subtitle">{item.subtitle}</p>
              <p class="muted">{item.description}</p>
            </article>
          ))}
        </div>

        <p class="warning">
          Over time, strong systems can create a lot of free capacity. The hard part then becomes choosing what matters most.
        </p>
      </section>
    ) : null}

    {showProjects ? (
      <section class="section" aria-labelledby="projects-heading">
        <h2 id="projects-heading">🧪 Current Projects & Hobbies</h2>
        <p class="section-hint">
          What I am actively building or practicing outside of classes and lab work.
        </p>

        <div class="stats-grid">
          {projects.map((project) => (
            <article class="card card--project">
              <div class="project-header">
                <span class="status-badge">{project.status}</span>
              </div>
              <h3>{project.title}</h3>
              <p class="muted">{project.blurb}</p>
              {project.tags && project.tags.length > 0 ? (
                <p class="tags">#{project.tags.join('  #')}</p>
              ) : null}
            </article>
          ))}
        </div>
      </section>
    ) : null}
  </div>

  <script is:inline>
    (() => {
      const url =
        'https://script.google.com/macros/s/AKfycbyPQznk53znPQ8TgGTcK9tuwq-Vw5deN1YRpbmTHb0OOKHwTu9b1XBJqQuGh7PXh6pKHA/exec';

      async function loadStats() {
        try {
          const res = await fetch(url);
          if (!res.ok) return;

          const data = await res.json();
          if (!data) return;

          const elements = document.querySelectorAll('[data-stat-key]');
          elements.forEach((el) => {
            const key = el.getAttribute('data-stat-key');
            if (key && data[key] !== undefined && data[key] !== null) {
              el.textContent = String(data[key]);
            }
          });
        } catch (_err) {
          // silently ignore fetch failures on build/runtime
        }
      }

      if (typeof window !== 'undefined') {
        if (document.readyState === 'loading') {
          window.addEventListener('DOMContentLoaded', loadStats, { once: true });
        } else {
          loadStats();
        }
      }
    })();
  </script>
</Layout>

<style is:global>
  .stats-page {
    max-width: 960px;
    margin: 0 auto;
  }

  .stats-page .intro {
    text-align: center;
    margin-bottom: 2rem;
    color: #4b5563;
  }

  .section {
    margin-top: 3rem;
  }

  .section h2 {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-hint {
    text-align: center;
    margin: 0 auto 1.75rem;
    max-width: 640px;
    color: #6b7280;
    font-size: 0.95rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .section {
      margin-top: 2.25rem;
    }
  }

  .card {
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e5e7eb;
    padding: 18px 16px 16px;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.03);
    width: 100%;
    box-sizing: border-box;
  }

  .card--stat,
  .card--prohibition {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .icon-bubble {
    width: 60px;
    height: 60px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 0.35rem;
    background: #0f172a;
    color: #ffffff;
  }

  .stat-label {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .card--prohibition h3 {
    margin: 0.25rem 0 0.1rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .stat-value {
    font-size: 1.2rem;
    font-weight: 800;
  }

  .subtitle {
    font-size: 0.9rem;
    color: #6b7280;
    font-weight: 500;
    margin: 0;
  }

  .muted {
    margin-top: 0.4rem;
    font-size: 0.9rem;
    color: #4b5563;
  }

  .warning {
    margin-top: 2rem;
    text-align: center;
    font-style: italic;
    color: #6b7280;
    max-width: 640px;
    margin-inline: auto;
  }

  .card--project h3 {
    margin: 0.25rem 0 0.35rem;
    font-size: 1rem;
    font-weight: 700;
  }

  .tags {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    color: #6b7280;
  }

  .project-header {
    display: flex;
    justify-content: flex-end;
  }

  .status-badge {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: #e0ecff;
    color: #1d4ed8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>

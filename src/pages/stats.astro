---
import Layout from '../layouts/BlogPost.astro';
import StatsGraphs from '../components/StatsGraphs.astro';

const TRACKING_START = '2023-01-01';

function durationParts(startValue: string) {
  const start = new Date(`${startValue}T00:00:00`);
  const end = new Date();

  let years = end.getFullYear() - start.getFullYear();
  let months = end.getMonth() - start.getMonth();
  let days = end.getDate() - start.getDate();

  if (days < 0) {
    months -= 1;
    days += new Date(end.getFullYear(), end.getMonth(), 0).getDate();
  }

  if (months < 0) {
    years -= 1;
    months += 12;
  }

  return {
    years: Math.max(0, years),
    months: Math.max(0, months),
    days: Math.max(0, days),
  };
}

function formatDuration(parts: { years: number; months: number; days: number }) {
  const values = [
    `${parts.years} year${parts.years === 1 ? '' : 's'}`,
    `${parts.months} month${parts.months === 1 ? '' : 's'}`,
    `${parts.days} day${parts.days === 1 ? '' : 's'}`,
  ];

  return values.join(', ');
}

const trackingDuration = formatDuration(durationParts(TRACKING_START));

const snapshotStats = [
  {
    metric: 'running',
    icon: '🏃‍♂️',
    label: 'Running',
    fallback: '445',
    unit: 'miles',
    snapshotKeys: 'runningMiles',
    start: 'September 26, 2023',
    note: 'Logged distance, with time estimated at 10 minutes per mile.',
  },
  {
    metric: 'diary',
    icon: '📓',
    label: 'Diary',
    fallback: '100,000',
    unit: 'words',
    snapshotKeys: 'diaryWords',
    start: 'March 16, 2022',
    note: 'A searchable written record of ordinary days and major moments.',
  },
  {
    metric: 'guitar',
    icon: '🎸',
    label: 'Guitar',
    fallback: '419',
    unit: 'hours',
    snapshotKeys: 'guitarHours',
    start: 'September 27, 2023',
    note: 'Practice time, from ten-minute minimums to focused sessions.',
  },
  {
    metric: 'audiobooks',
    icon: '📚',
    label: 'Audiobooks',
    fallback: '400',
    unit: 'hours',
    snapshotKeys: 'audiobookHours,booksCount',
    start: 'February 10, 2023',
    note: 'Commutes, chores, walks, and exercise converted into reading time.',
  },
];

const trackingTimeline = [
  {
    date: 'March 16, 2022',
    title: 'Daily diary begins',
    text: 'Short daily notes became the first durable layer of the LifeLoggerz archive.',
    metric: 'Diary',
  },
  {
    date: 'January 1, 2023',
    title: 'Core tracking system begins',
    text: 'Sleep, food, routines, people, places, work, and other variables moved into a structured daily sheet.',
    metric: 'Core archive',
  },
  {
    date: 'February 10, 2023',
    title: 'Audiobook time begins',
    text: 'Passive travel and chore time became a measurable reading habit.',
    metric: 'Audiobooks',
  },
  {
    date: 'September 26–27, 2023',
    title: 'Running and guitar begin',
    text: 'Two habits started one day apart and developed through very different seasons of consistency.',
    metric: 'Running + guitar',
  },
  {
    date: 'June 2026',
    title: 'Dance enters the archive',
    text: 'Cumbia, bachata, and salsa added another competing—and complementary—use of hobby time.',
    metric: 'Dance',
  },
];

const systemSteps = [
  {
    number: '01',
    icon: '✍️',
    title: 'Daily entry',
    text: 'A compact Google Sheets routine captures the details worth preserving.',
  },
  {
    number: '02',
    icon: '⚙️',
    title: 'Automation',
    text: 'Formulas and Apps Script clean, classify, total, and archive the entries.',
  },
  {
    number: '03',
    icon: '🗂️',
    title: 'Long-term archive',
    text: 'Monthly and yearly records make separate days comparable across time.',
  },
  {
    number: '04',
    icon: '📈',
    title: 'Public dashboard',
    text: 'A small API sends selected, public-safe summaries to this Astro page.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'LifeLoggerz Public Statistics',
  description: 'Public-safe personal tracking totals, monthly trends, records, and system documentation.',
  creator: {
    '@type': 'Person',
    name: 'José',
  },
  temporalCoverage: '2022/..',
  url: 'https://lifeloggerz.com/stats/',
}).replace(/</g, '\\u003c');
---

<Layout
  title="Stats & Systems"
  description="Live public-safe totals, records, trends, and the system that turns daily LifeLoggerz entries into a long-term archive."
  wide={true}
  hideTitle={true}
  showViews={false}
>
  <script type="application/ld+json" is:inline set:html={jsonLd}></script>

  <div class="stats-dashboard" data-tracking-start={TRACKING_START}>
    <section class="stats-hero" aria-labelledby="stats-title">
      <div class="stats-hero__glow stats-hero__glow--one" aria-hidden="true"></div>
      <div class="stats-hero__glow stats-hero__glow--two" aria-hidden="true"></div>

      <div class="stats-hero__content">
        <p class="eyebrow">Live data from the LifeLoggerz archive</p>
        <h1 id="stats-title">A life, measured over time</h1>
        <p class="stats-hero__lede">
          Public totals, records, and patterns drawn from a system I have maintained since
          <strong>January 1, 2023</strong>—with diary records reaching back even further.
        </p>

        <div class="stats-hero__actions" aria-label="Stats page shortcuts">
          <a class="button button--primary" href="#graphs">Explore the graphs <span aria-hidden="true">↓</span></a>
          <a class="button button--secondary" href="#system">How the system works <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <div class="stats-hero__facts" aria-label="LifeLoggerz tracking summary">
        <article class="hero-fact hero-fact--wide">
          <span class="hero-fact__label">Tracking for</span>
          <strong id="tracking-duration">{trackingDuration}</strong>
        </article>
        <article class="hero-fact">
          <span class="hero-fact__label">Variables</span>
          <strong>150+</strong>
        </article>
        <article class="hero-fact">
          <span class="hero-fact__label">Daily logging</span>
          <strong>≈ 5 min</strong>
        </article>
        <article class="hero-fact hero-fact--status">
          <span class="live-dot" aria-hidden="true"></span>
          <span>
            <span class="hero-fact__label">Archive status</span>
            <strong id="archive-status">Connecting…</strong>
          </span>
        </article>
      </div>
    </section>

    <section class="dashboard-section snapshot-section" aria-labelledby="snapshot-heading">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">The current snapshot</p>
          <h2 id="snapshot-heading">Four windows into the archive</h2>
        </div>
        <p>
          The large figures come from the public summary feed. The smaller comparisons are calculated from the monthly archive below.
        </p>
      </div>

      <div class="snapshot-grid">
        {snapshotStats.map((item) => (
          <article
            class={`snapshot-card snapshot-card--${item.metric}`}
            data-dashboard-metric={item.metric}
          >
            <div class="snapshot-card__top">
              <span class="snapshot-card__icon" aria-hidden="true">{item.icon}</span>
              <div>
                <p class="snapshot-card__kicker">Lifetime logged</p>
                <h3>{item.label}</h3>
              </div>
            </div>

            <p class="snapshot-card__value">
              <strong
                data-stat-value
                data-snapshot-keys={item.snapshotKeys}
              >{item.fallback}</strong>
              <span data-stat-unit>{item.unit}</span>
            </p>

            <p class="snapshot-card__note">{item.note}</p>

            <dl class="snapshot-card__facts">
              <div>
                <dt>This year</dt>
                <dd data-card-year>Loading…</dd>
              </div>
              <div>
                <dt>Best month</dt>
                <dd data-card-peak>Loading…</dd>
              </div>
              {item.metric === 'running' ? (
                <div class="snapshot-card__fact--wide snapshot-card__fact--estimate">
                  <dt>Estimated running time</dt>
                  <dd data-running-time-estimate>≈ 74.2 hours at 10 min/mile</dd>
                </div>
              ) : null}
              <div class="snapshot-card__fact--wide">
                <dt>Tracking since</dt>
                <dd>{item.start}</dd>
              </div>
            </dl>

            <button class="snapshot-card__link" type="button" data-open-metric={item.metric}>
              Explore {item.label.toLowerCase()} <span aria-hidden="true">→</span>
            </button>
          </article>
        ))}
      </div>

      <p class="data-note" id="snapshot-note" role="status">
        Saved totals remain visible if the live summary feed is unavailable.
      </p>
    </section>

    <StatsGraphs />

    <section id="tracking-history" class="dashboard-section history-section" aria-labelledby="history-heading">
      <div class="section-heading">
        <p class="eyebrow">Context before comparison</p>
        <h2 id="history-heading">When each record began</h2>
        <p>
          A lifetime total means little without knowing how long it had to accumulate. These start dates explain why the timelines do not all cover the same years.
        </p>
      </div>

      <div class="history-timeline">
        {trackingTimeline.map((item, index) => (
          <article class="history-item">
            <div class="history-item__rail" aria-hidden="true">
              <span>{String(index + 1).padStart(2, '0')}</span>
            </div>
            <div class="history-item__content">
              <div class="history-item__meta">
                <time>{item.date}</time>
                <span>{item.metric}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="system" class="dashboard-section system-section" aria-labelledby="system-heading">
      <div class="section-heading">
        <p class="eyebrow">Stats and systems</p>
        <h2 id="system-heading">How the numbers reach this page</h2>
        <p>
          The public dashboard is the final layer. The real system is the quiet chain that turns a five-minute daily habit into years of searchable information.
        </p>
      </div>

      <div class="system-flow">
        {systemSteps.map((step, index) => (
          <article class="system-step">
            <div class="system-step__heading">
              <span class="system-step__number">{step.number}</span>
              <span class="system-step__icon" aria-hidden="true">{step.icon}</span>
            </div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
            {index < systemSteps.length - 1 ? <span class="system-step__arrow" aria-hidden="true">→</span> : null}
          </article>
        ))}
      </div>

      <div class="system-links">
        <a href="/blog/rawdatapost2025/">Read the raw-data story <span aria-hidden="true">→</span></a>
        <a href="/templates/">Use the templates <span aria-hidden="true">→</span></a>
        <a href="/faq/">Read the FAQ <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="stats-cta" aria-labelledby="stats-cta-heading">
      <div>
        <p class="eyebrow">The numbers are not the destination</p>
        <h2 id="stats-cta-heading">Build a system that returns attention to your life</h2>
        <p>
          Start with one question worth answering. Track only what helps. Automate the repetition. Let the archive grow without allowing it to become the point of living.
        </p>
      </div>
      <div class="stats-cta__actions">
        <a class="button button--primary" href="/templates/">Browse the templates</a>
        <a class="button button--secondary" href="/about/">About LifeLoggerz</a>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const SNAPSHOT_URL =
        'https://script.google.com/macros/s/AKfycbyPQznk53znPQ8TgGTcK9tuwq-Vw5deN1YRpbmTHb0OOKHwTu9b1XBJqQuGh7PXh6pKHA/exec';
      const CACHE_KEY = 'lifeloggerz-snapshot-stats-v4';
      const RUNNING_MINUTES_PER_MILE = 10;

      function plural(value, label) {
        return `${value} ${label}${value === 1 ? '' : 's'}`;
      }

      function updateTrackingDuration() {
        const root = document.querySelector('.stats-dashboard');
        const output = document.getElementById('tracking-duration');
        if (!root || !output) return;

        const startValue = root.getAttribute('data-tracking-start') || '2023-01-01';
        const start = new Date(`${startValue}T00:00:00`);
        const now = new Date();

        let years = now.getFullYear() - start.getFullYear();
        let months = now.getMonth() - start.getMonth();
        let days = now.getDate() - start.getDate();

        if (days < 0) {
          months -= 1;
          days += new Date(now.getFullYear(), now.getMonth(), 0).getDate();
        }
        if (months < 0) {
          years -= 1;
          months += 12;
        }

        output.textContent = [plural(Math.max(0, years), 'year'), plural(Math.max(0, months), 'month'), plural(Math.max(0, days), 'day')].join(', ');
      }

      function cleanSnapshotValue(value) {
        if (value === undefined || value === null) return null;
        const text = String(value).trim();
        if (!text) return null;

        const numberMatch = text.replace(/,/g, '').match(/-?\d+(?:\.\d+)?/);
        if (!numberMatch) return text;

        const numeric = Number(numberMatch[0]);
        if (!Number.isFinite(numeric)) return text;
        return new Intl.NumberFormat('en-US', {
          maximumFractionDigits: Number.isInteger(numeric) ? 0 : 1,
        }).format(numeric);
      }

      function updateRunningTimeEstimate(milesValue) {
        const output = document.querySelector('[data-running-time-estimate]');
        if (!output) return;

        const miles = Number(String(milesValue ?? '').replace(/,/g, '').match(/-?\d+(?:\.\d+)?/)?.[0]);
        if (!Number.isFinite(miles)) return;

        const hours = (miles * RUNNING_MINUTES_PER_MILE) / 60;
        output.textContent = `≈ ${new Intl.NumberFormat('en-US', { maximumFractionDigits: 1 }).format(hours)} hours at ${RUNNING_MINUTES_PER_MILE} min/mile`;
      }

      function applySnapshot(data) {
        let replacements = 0;

        document.querySelectorAll('[data-stat-value]').forEach((element) => {
          const keys = (element.getAttribute('data-snapshot-keys') || '')
            .split(',')
            .map((key) => key.trim())
            .filter(Boolean);

          for (const key of keys) {
            const cleaned = cleanSnapshotValue(data?.[key]);
            if (cleaned !== null) {
              element.textContent = cleaned;
              if (key === 'runningMiles') updateRunningTimeEstimate(data?.[key]);
              replacements += 1;
              break;
            }
          }
        });

        return replacements;
      }

      function setArchiveStatus(text, state = 'neutral') {
        const status = document.getElementById('archive-status');
        const note = document.getElementById('snapshot-note');
        if (status) status.textContent = text;
        if (note) note.dataset.state = state;
      }

      async function loadSnapshot() {
        let cached = null;
        try {
          cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null');
        } catch (_error) {
          cached = null;
        }

        try {
          const response = await fetch(SNAPSHOT_URL, { cache: 'no-store' });
          if (!response.ok) throw new Error(`Snapshot request failed: ${response.status}`);

          const data = await response.json();
          const replacements = applySnapshot(data);

          try {
            localStorage.setItem(CACHE_KEY, JSON.stringify({ data, savedAt: Date.now() }));
          } catch (_storageError) {
            // Live data is still usable when browser storage is unavailable.
          }
          setArchiveStatus(replacements ? 'Live totals loaded' : 'Archive connected', 'live');
        } catch (_error) {
          if (cached?.data) {
            applySnapshot(cached.data);
            setArchiveStatus('Using saved totals', 'cached');
          } else {
            setArchiveStatus('Saved totals shown', 'fallback');
          }
        }
      }

      function start() {
        updateTrackingDuration();
        const runningValue = document.querySelector('[data-dashboard-metric="running"] [data-stat-value]');
        if (runningValue) updateRunningTimeEstimate(runningValue.textContent);
        loadSnapshot();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start, { once: true });
      } else {
        start();
      }
    })();
  </script>
</Layout>

<style is:global>
  :root {
    --stats-ink: #111827;
    --stats-muted: #566174;
    --stats-line: rgba(15, 23, 42, 0.12);
    --stats-blue: #2457ff;
    --stats-green: #0f8a5f;
    --stats-gold: #b7791f;
    --stats-panel: rgba(255, 255, 255, 0.86);
    --stats-shadow: 0 20px 55px rgba(15, 23, 42, 0.09);
  }

  article.wrap.prose--wide {
    width: 100% !important;
    max-width: none !important;
    padding-inline: 0 !important;
  }

  article.wrap.prose--wide > .prose {
    width: 100% !important;
    max-width: none !important;
    padding-inline: 0 !important;
  }

  .stats-dashboard,
  .stats-dashboard * {
    box-sizing: border-box;
  }

  .stats-dashboard {
    width: min(calc(100% - 2rem), 1240px);
    margin: 1.1rem auto 4rem;
    color: var(--stats-ink);
  }

  .stats-dashboard a {
    color: inherit;
  }

  .stats-dashboard p {
    color: var(--stats-muted);
  }

  .eyebrow {
    margin: 0 0 0.65rem;
    color: #0f5132 !important;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stats-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(340px, 0.75fr);
    gap: clamp(2rem, 5vw, 5rem);
    overflow: hidden;
    padding: clamp(2rem, 5vw, 4.6rem);
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 32px;
    background:
      linear-gradient(130deg, rgba(222, 250, 237, 0.83), rgba(255, 247, 221, 0.72) 48%, rgba(225, 237, 255, 0.82));
    box-shadow: var(--stats-shadow);
    isolation: isolate;
  }

  .stats-hero__glow {
    position: absolute;
    z-index: -1;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    filter: blur(12px);
    opacity: 0.52;
  }

  .stats-hero__glow--one {
    top: -150px;
    right: 23%;
    background: rgba(36, 87, 255, 0.16);
  }

  .stats-hero__glow--two {
    bottom: -190px;
    left: 8%;
    background: rgba(15, 138, 95, 0.18);
  }

  .stats-hero__content {
    align-self: center;
  }

  .stats-hero h1 {
    max-width: 790px;
    margin: 0;
    color: var(--stats-ink);
    font-size: clamp(2.8rem, 6vw, 5.7rem);
    line-height: 0.95;
    letter-spacing: -0.065em;
  }

  .stats-hero__lede {
    max-width: 720px;
    margin: 1.5rem 0 0;
    color: #344054 !important;
    font-size: clamp(1.02rem, 1.6vw, 1.24rem);
    line-height: 1.75;
  }

  .stats-hero__lede strong {
    color: var(--stats-ink);
  }

  .stats-hero__actions,
  .stats-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.72rem 1.05rem;
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 850;
    line-height: 1.2;
    text-decoration: none !important;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
    border-color: var(--stats-ink);
    background: var(--stats-ink);
    color: white !important;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.2);
  }

  .button--secondary {
    background: rgba(255, 255, 255, 0.67);
    color: var(--stats-ink) !important;
  }

  .stats-hero__facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    align-content: center;
  }

  .hero-fact {
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.67);
    box-shadow: 0 12px 35px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(12px);
  }

  .hero-fact--wide,
  .hero-fact--status {
    grid-column: 1 / -1;
  }

  .hero-fact--status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-fact__label {
    display: block;
    margin-bottom: 0.2rem;
    color: #667085;
    font-size: 0.73rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .hero-fact strong {
    display: block;
    overflow-wrap: anywhere;
    color: var(--stats-ink);
    font-size: clamp(1rem, 1.6vw, 1.26rem);
    line-height: 1.3;
  }

  .live-dot {
    flex: 0 0 auto;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #16a34a;
    box-shadow: 0 0 0 7px rgba(22, 163, 74, 0.13);
  }

  .dashboard-section {
    margin-top: clamp(4rem, 8vw, 7rem);
    scroll-margin-top: 6rem;
  }

  .section-heading {
    max-width: 820px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .section-heading--split {
    display: grid;
    max-width: none;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.7fr);
    gap: 2rem;
    align-items: end;
    text-align: left;
  }

  .section-heading h2 {
    margin: 0;
    color: var(--stats-ink);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .section-heading > p:last-child,
  .section-heading--split > p {
    margin: 0.85rem auto 0;
    color: var(--stats-muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .section-heading--split > p {
    margin: 0;
  }

  .snapshot-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .snapshot-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex-direction: column;
    padding: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--stats-line);
    border-radius: 24px;
    background: var(--stats-panel);
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.065);
  }

  .snapshot-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: linear-gradient(90deg, #2f6bff, #0f9f70);
  }

  .snapshot-card--diary::before {
    background: linear-gradient(90deg, #b7791f, #f0b429);
  }

  .snapshot-card--running::before {
    background: linear-gradient(90deg, #0f8a5f, #4dc69a);
  }


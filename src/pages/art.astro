---
// src/pages/art.astro
// Revision: responsive List/Quilt views, richer filters and sorting, live counts, and safer artwork framing — July 2026
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoBg from '../components/VideoBg.astro';
import { SITE_TITLE } from '../consts';
import { fetchAllRaindrops } from '../utils/raindrop';

const RAINDROP_TOKEN = import.meta.env.RAINDROP_TOKEN;
const COLLECTION_ID = import.meta.env.RAINDROP_COLLECTION_ART_ID || '58506976';

const art = await fetchAllRaindrops({
  token: RAINDROP_TOKEN,
  collectionId: COLLECTION_ID,
  label: 'art',
  placeholder: '/images_webp/art-placeholder.webp',
});

const looksLikeArtworkYear = (value?: string | null) => {
  const raw = String(value || '').trim();
  return /(?:\b(?:bc|bce|ad|ce)\b|\b\d{1,2}(?:st|nd|rd|th)\s+century\b|(?:^|\s)(?:c(?:irca)?\.?\s*)?-?\d{1,4}(?:\s|$|[–—/.,-]))/i.test(raw);
};

const getArtMeta = (note?: string | null) => {
  const parts = String(note || '')
    .split('·')
    .map((part) => part.trim());

  // Both note orders have appeared in this page's earlier documentation:
  // Date · Title · Artist · Country · Medium · Movement · Year · Source
  // Date · Title · Artist · Year · Medium · Movement · Country · Source
  // Detect the fourth field so either structure continues to work.
  const yearComesFourth = looksLikeArtworkYear(parts[3]);

  return {
    dateViewed: parts[0] || '',
    artist: parts[2] || '',
    artworkYear: yearComesFourth ? (parts[3] || '') : (parts[6] || ''),
    medium: parts[4] || '',
    movement: parts[5] || '',
    country: yearComesFourth ? (parts[6] || '') : (parts[3] || ''),
    source: parts.slice(7).join(' · ') || '',
  };
};

const getViewedYear = (dateViewed?: string | null) => {
  const raw = String(dateViewed || '').trim();
  const numericDate = raw.match(/\b\d{1,2}[\/-]\d{1,2}[\/-](\d{2}|\d{4})\b/);

  if (numericDate) {
    const year = numericDate[1];
    return year.length === 2 ? String(2000 + Number(year)) : year;
  }

  return raw.match(/\b(?:19|20)\d{2}\b/)?.[0] || '';
};

const getArtworkYear = (value?: string | null): number | null => {
  const raw = String(value || '').trim().toLowerCase().replace(/,/g, '');
  if (!raw) return null;

  const isBce = /\b(?:bc|bce)\b/.test(raw);
  const centuryMatch = raw.match(/\b(\d{1,2})(?:st|nd|rd|th)\s+century\b/);

  if (centuryMatch) {
    const century = Number(centuryMatch[1]);
    if (!Number.isFinite(century) || century <= 0) return null;
    return isBce ? -(century * 100 - 50) : (century - 1) * 100 + 50;
  }

  const bceMatch = raw.match(/\b(\d{1,4})\s*(?:bc|bce)\b/);
  if (bceMatch) return -Number(bceMatch[1]);

  const ceMatch = raw.match(/\b(\d{1,4})\s*(?:ad|ce)\b/);
  if (ceMatch) return Number(ceMatch[1]);

  const yearMatch = raw.match(/(?:^|\s)(-?\d{1,4})(?=\s|$|[–—/.,-])/);
  if (!yearMatch) return null;

  const year = Number(yearMatch[1]);
  return Number.isFinite(year) ? year : null;
};

const getOrdinal = (value: number) => {
  const mod100 = value % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${value}th`;

  const mod10 = value % 10;
  if (mod10 === 1) return `${value}st`;
  if (mod10 === 2) return `${value}nd`;
  if (mod10 === 3) return `${value}rd`;
  return `${value}th`;
};

const getArtworkPeriod = (value?: string | null) => {
  const year = getArtworkYear(value);

  if (year === null) {
    return { key: 'unknown', label: 'Unknown date', order: -1 };
  }

  if (year < 500) {
    return { key: 'ancient', label: 'Ancient (before 500)', order: 0 };
  }

  if (year < 1400) {
    return { key: 'medieval', label: 'Medieval (500–1399)', order: 1 };
  }

  const century = Math.max(1, Math.ceil(year / 100));
  return {
    key: `century-${century}`,
    label: `${getOrdinal(century)} century`,
    order: century,
  };
};

const artMetadata = art.map((item) => getArtMeta(item.note));
const artistCount = new Set(
  artMetadata.map((meta) => meta.artist.trim().toLowerCase()).filter(Boolean),
).size;
---

<BaseHead
  title={`${SITE_TITLE} — Art`}
  description="A searchable, auto-updated visual diary of the artworks I view through DailyArt."
/>

<style>
  :root{--gap:18px;--ink:#0e121b;--muted:#5e6573;--border:#e6e9ef;--surface:#fff}
  *{box-sizing:border-box}
  .wrap{margin:0 auto;padding-block:28px 48px;padding-inline:clamp(16px,3vw,48px);max-width:100%}
  .wrap--wide{width:100dvw;margin-left:calc(50% - 50dvw);margin-right:calc(50% - 50dvw);padding-inline:0}
  .intro{max-width:1180px;margin:0 auto 22px;text-align:center;padding-inline:clamp(16px,3vw,48px)}
  h1{margin:0 0 12px;font-weight:800;letter-spacing:-.02em;display:flex;gap:.6rem;align-items:center;justify-content:center}
  .hint{color:var(--muted);margin:6px 0 20px}
  .hint a{color:inherit;text-underline-offset:2px}

  .toolbar{display:flex;align-items:center;justify-content:center;gap:8px;margin:6px 0 13px;flex-wrap:wrap}
  .toolbar input[type="search"]{flex:1 1 235px;width:100%;max-width:285px;margin-inline:0;padding:12px 14px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.95rem;box-shadow:0 1px 2px rgba(0,0,0,.03)}
  .toolbar select{flex:0 1 145px;min-width:116px;padding:10px 11px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.88rem;box-shadow:0 1px 2px rgba(0,0,0,.03)}
  .toolbar #movement-filter{flex-basis:165px}
  .toolbar #viewed-year-filter{flex-basis:118px}
  .toolbar #period-filter{flex-basis:145px}
  .toolbar #sort-art{flex-basis:174px}

  @media (min-width:901px){
    .toolbar{flex-wrap:nowrap}
    .toolbar > .info-toggle{flex:0 0 40px}
  }

  .info-toggle{width:40px;height:40px;border-radius:999px;border:1px solid #838796;background:#a8adbd;color:var(--ink);display:inline-flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;box-shadow:0 1px 2px rgba(0,0,0,.04);transition:background .15s ease,box-shadow .15s ease,transform .08s ease,border-color .15s ease,color .15s ease}
  .info-toggle span{position:relative;top:-1px;font-weight:600}
  .info-toggle:hover{background:#f0f2ff;box-shadow:0 4px 10px rgba(0,0,0,.08);transform:translateY(-1px)}
  .info-toggle[aria-pressed="true"]{background:#405cf5;color:#fff;border-color:#405cf5}
  .info-toggle:focus-visible{outline:2px solid #405cf5;outline-offset:2px}

  .view-toggle{display:inline-flex;align-items:center;justify-content:center;gap:3px;margin:0 auto 9px;padding:3px;border:1px solid var(--border);border-radius:999px;background:rgba(255,255,255,.9);box-shadow:0 6px 16px rgba(15,23,42,.06)}
  .view-button{display:inline-flex;align-items:center;justify-content:center;gap:6px;min-height:36px;padding:7px 12px;border:0;border-radius:999px;background:transparent;color:var(--muted);font:inherit;font-size:.82rem;font-weight:700;line-height:1;cursor:pointer}
  .view-button[aria-pressed="true"]{background:#405cf5;color:#fff;box-shadow:0 5px 12px rgba(64,92,245,.22)}
  .view-button:focus-visible{outline:2px solid #405cf5;outline-offset:2px}

  .results-row{display:flex;align-items:center;justify-content:center;gap:9px;min-height:30px;margin:0 auto 15px;color:var(--muted);font-size:.82rem}
  .results-row p{margin:0}
  .clear-filters{border:0;background:transparent;color:#314bd8;font:inherit;font-weight:700;cursor:pointer;text-decoration:underline;text-underline-offset:3px}
  .clear-filters:hover{color:#1e34b8}
  .clear-filters:focus-visible{outline:2px solid #405cf5;outline-offset:3px;border-radius:3px}

  .info-panel{max-width:920px;margin:0 auto 24px;padding:16px 18px 14px;border-radius:14px;background:rgba(255,255,255,.9);border:1px solid var(--border);box-shadow:0 10px 24px rgba(15,23,42,.04);font-size:.94rem;line-height:1.5;color:var(--muted);text-align:left;display:none}
  .info-panel--visible{display:block}
  .info-panel h2{font-size:1.02rem;margin:0 0 .4rem;font-weight:700;color:var(--ink)}
  .info-panel p{margin:.35rem 0}
  .info-panel a{color:#314bd8;font-weight:700;text-underline-offset:2px}

  .grid{display:grid;gap:var(--gap);align-items:start;width:100%;max-width:1800px;margin-inline:auto}
  .grid:is([data-art-view="auto"],[data-art-view="quilt"]){grid-template-columns:repeat(auto-fit,minmax(185px,1fr))}
  .fullbleed{padding-inline:clamp(16px,3vw,48px)}
  .card{position:relative;display:flex;min-width:0;flex-direction:column;gap:7px;text-decoration:none;color:inherit;border-radius:12px}
  .thumb{width:100%;aspect-ratio:4/5;object-fit:contain;border-radius:12px;box-shadow:0 9px 22px rgba(0,0,0,.12);background:rgba(246,247,250,.96);border:1px solid var(--border)}
  .title{display:-webkit-box;overflow:hidden;font-weight:700;font-size:.94rem;line-height:1.28;-webkit-box-orient:vertical;-webkit-line-clamp:2}
  .external-link-cue{display:inline-block;margin-left:.2em;color:var(--muted);font-size:.8em;font-weight:700;vertical-align:.08em}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .card:focus-visible{outline:2px solid #405cf5;outline-offset:4px;border-radius:12px}
  .card-meta{display:none}

  .note-bubble{position:absolute;left:50%;top:-10px;transform:translate(calc(-50% + var(--shift,0px)),-100%);width:max-content;max-width:min(600px,90vw);white-space:normal;background:rgba(20,23,31,.96);color:#fff;font-size:.9rem;line-height:1.35;padding:10px 12px;border-radius:10px;box-shadow:0 10px 24px rgba(0,0,0,.25);z-index:10;pointer-events:none;opacity:0;visibility:hidden;transition:opacity .15s ease,visibility .15s ease;text-align:left;text-wrap:pretty;hyphens:auto;word-break:break-word}
  .note-bubble::after{content:"";position:absolute;left:50%;top:100%;transform:translateX(-50%);border:8px solid transparent;border-top-color:rgba(20,23,31,.96)}
  .card:hover .note-bubble,.card:focus-within .note-bubble,.card.show-note .note-bubble{opacity:1;visibility:visible}
  .empty{text-align:center;color:var(--muted);padding:40px 16px 24px}

  @media (min-width:901px){
    .grid[data-art-view="list"]{max-width:1700px;grid-template-columns:repeat(auto-fit,minmax(420px,1fr));grid-auto-rows:190px;gap:15px}
    .grid[data-art-view="list"] .card{display:grid;width:100%;height:100%;grid-template-columns:132px minmax(0,1fr);grid-template-rows:auto 1fr;gap:7px 14px;align-items:start;overflow:hidden;padding:12px;border:1px solid rgba(230,233,239,.95);border-radius:14px;background:rgba(255,255,255,.9);box-shadow:0 8px 20px rgba(15,23,42,.07);transition:transform .15s ease,box-shadow .15s ease,border-color .15s ease}
    .grid[data-art-view="list"] .card:hover{transform:translateY(-2px);border-color:rgba(64,92,245,.28);box-shadow:0 12px 28px rgba(15,23,42,.11)}
    .grid[data-art-view="list"] .thumb{grid-column:1;grid-row:1 / span 2;width:132px;height:166px;aspect-ratio:4/5;object-fit:contain;border-radius:9px;box-shadow:0 6px 15px rgba(0,0,0,.13)}
    .grid[data-art-view="list"] .title{grid-column:2;grid-row:1;min-height:2.55em;margin-top:1px;font-size:1rem;line-height:1.28;-webkit-line-clamp:2}
    .grid[data-art-view="list"] .card-meta{display:flex;grid-column:2;grid-row:2;flex-direction:column;gap:4px;min-width:0;color:var(--muted);font-size:.8rem;line-height:1.3}
    .grid[data-art-view="list"] .card-meta span{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .grid[data-art-view="list"] .card-meta .source{display:-webkit-box;white-space:normal;-webkit-box-orient:vertical;-webkit-line-clamp:2}
    .grid[data-art-view="list"] .note-bubble{display:none}
  }

  @media (max-width:900px){
    .wrap{padding-block:18px 36px}
    .intro{margin-bottom:12px;padding-inline:12px}
    h1{margin-bottom:6px;font-size:2rem}
    .hint{max-width:39ch;margin:4px auto 12px;font-size:.86rem;line-height:1.42}

    .toolbar{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr) 40px;gap:7px;margin-bottom:10px}
    .toolbar input[type="search"]{grid-column:1 / -1;max-width:none;padding:10px 12px;font-size:.88rem}
    .toolbar select{width:100%;min-width:0;padding:9px 8px;font-size:.78rem}
    #movement-filter{grid-column:1;grid-row:2}
    #viewed-year-filter{grid-column:2;grid-row:2}
    #info-toggle{grid-column:3;grid-row:2}
    #period-filter{grid-column:1;grid-row:3}
    #sort-art{grid-column:2 / 4;grid-row:3}

    .view-toggle{margin-bottom:7px}
    .results-row{margin-bottom:12px;font-size:.78rem}
    .fullbleed{padding-inline:10px}

    .grid[data-art-view="quilt"]{grid-template-columns:repeat(2,minmax(0,1fr));gap:15px 10px}
    .grid[data-art-view="quilt"] .card{gap:5px}
    .grid[data-art-view="quilt"] .thumb{border-radius:9px;box-shadow:0 6px 14px rgba(0,0,0,.12)}
    .grid[data-art-view="quilt"] .title{font-size:.78rem;line-height:1.24;-webkit-line-clamp:2}

    .grid:is([data-art-view="auto"],[data-art-view="list"]){max-width:680px;grid-template-columns:minmax(0,1fr);grid-auto-rows:166px;gap:10px}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .card{display:grid;width:100%;height:100%;grid-template-columns:104px minmax(0,1fr);grid-template-rows:auto 1fr;gap:6px 12px;align-items:start;overflow:hidden;padding:10px;border:1px solid rgba(230,233,239,.95);border-radius:14px;background:rgba(255,255,255,.9);box-shadow:0 7px 18px rgba(15,23,42,.06)}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .thumb{grid-column:1;grid-row:1 / span 2;width:104px;height:130px;aspect-ratio:4/5;object-fit:contain;border-radius:8px;box-shadow:0 5px 12px rgba(0,0,0,.12)}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .title{grid-column:2;grid-row:1;min-height:2.35em;margin-top:1px;font-size:.94rem;line-height:1.25;-webkit-line-clamp:2}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .card-meta{display:flex;grid-column:2;grid-row:2;flex-direction:column;gap:3px;min-width:0;color:var(--muted);font-size:.75rem;line-height:1.28}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .card-meta span{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .card-meta .source{display:-webkit-box;white-space:normal;-webkit-box-orient:vertical;-webkit-line-clamp:2}
    .grid:is([data-art-view="auto"],[data-art-view="list"]) .note-bubble{display:none}

    .note-bubble{top:auto;bottom:-10px;transform:translate(calc(-50% + var(--shift,0px)),100%);max-width:min(310px,88vw);padding:8px 10px;font-size:.78rem;line-height:1.32}
    .note-bubble::after{top:auto;bottom:100%;border-top-color:transparent;border-bottom-color:rgba(20,23,31,.96)}
    .info-panel{margin-bottom:16px;padding:13px;font-size:.84rem}
  }

  @media (min-width:560px) and (max-width:900px){
    .grid[data-art-view="quilt"]{grid-template-columns:repeat(3,minmax(0,1fr));gap:18px 12px}
    .grid[data-art-view="quilt"] .title{font-size:.84rem}
  }
</style>

<VideoBg>
  <Header />
  <main class="wrap wrap--wide">
    <div class="intro" role="region" aria-label="Art header">
      <h1>🎨 Art</h1>
      <p class="hint">
        One small museum visit a day through
        <a href="https://getdailyart.com" target="_blank" rel="noopener noreferrer"><strong>DailyArt</strong></a>:
        {(art.length).toLocaleString('en-US')} works by {artistCount.toLocaleString('en-US')} artists so far.
      </p>

      <div class="toolbar">
        <input id="q" type="search" placeholder="Search artwork, artist, or note…" aria-label="Filter art" />

        <select id="movement-filter" aria-label="Filter by movement">
          <option value="">All movements</option>
        </select>

        <select id="viewed-year-filter" aria-label="Filter by year viewed">
          <option value="">All viewed years</option>
        </select>

        <select id="period-filter" aria-label="Filter by artwork period">
          <option value="">All periods</option>
        </select>

        <select id="sort-art" aria-label="Sort artworks">
          <option value="date-desc">Newest viewed</option>
          <option value="date-asc">Oldest viewed</option>
          <option value="title-asc">Artwork A–Z</option>
          <option value="artist-asc">Artist A–Z</option>
          <option value="artwork-desc">Artwork: newest first</option>
          <option value="artwork-asc">Artwork: oldest first</option>
        </select>

        <button
          type="button"
          id="info-toggle"
          class="info-toggle"
          aria-label="About my art viewing"
          aria-expanded="false"
          aria-pressed="false"
        >
          <span>?</span>
        </button>
      </div>

      {art.length > 0 ? (
        <>
          <div id="art-view-toggle" class="view-toggle" role="group" aria-label="Choose art layout">
            <button type="button" class="view-button" data-art-view="list" aria-pressed="false">
              <span aria-hidden="true">▤</span>
              <span>List</span>
            </button>
            <button type="button" class="view-button" data-art-view="quilt" aria-pressed="false">
              <span aria-hidden="true">▦</span>
              <span>Quilt</span>
            </button>
          </div>

          <div class="results-row">
            <p id="results-summary" aria-live="polite">
              Showing {art.length.toLocaleString('en-US')} of {art.length.toLocaleString('en-US')} artworks
            </p>
            <button type="button" id="clear-filters" class="clear-filters" hidden>Clear filters</button>
          </div>
        </>
      ) : null}

      <section id="art-info" class="info-panel" hidden>
        <h2>Why I Log Art</h2>
        <p>
          This is a visual diary rather than a feed. I look at one work at a time, pause long enough to notice it,
          read its story, and save a structured record of the encounter.
        </p>

        <h2>The Collection</h2>
        <p>
          The archive currently contains <strong>{art.length.toLocaleString('en-US')} works</strong> by
          <strong>{artistCount.toLocaleString('en-US')} artists</strong>, drawn mostly from the
          <a href="https://getdailyart.com" target="_blank" rel="noopener noreferrer">DailyArt</a> app.
        </p>

        <h2>How to Browse</h2>
        <p>
          Filter by movement, the year I viewed the piece, or its historical period. Sort by viewing date, artist,
          title, or the artwork's age. List view exposes the key metadata; Quilt view keeps the visual archive central.
        </p>

        <h2>Notes</h2>
        <p>My entries support either of these structured formats:</p>
        <p>
          <strong>Date · Title · Artist · Country · Medium · Movement · Year · Source</strong><br />
          <strong>Date · Title · Artist · Year · Medium · Movement · Country · Source</strong>
        </p>
        <p>
          On desktop, hover over a work in Quilt view to see the complete note. On a phone, tap once to reveal it and
          tap again to open its DailyArt, museum, or reference page. In List view, the main details are already visible.
        </p>
      </section>
    </div>

    {art.length === 0 ? (
      <div class="empty">No art found in this collection.</div>
    ) : (
      <>
        <p id="filter-empty" class="empty" aria-live="polite" hidden>
          No artworks match these filters. Use “Clear filters” to restore the collection.
        </p>

        <div class="grid fullbleed" id="grid" role="list" data-art-view="auto">
          {art.map((item, index) => {
            const meta = getArtMeta(item.note);
            const viewedYear = getViewedYear(meta.dateViewed);
            const artworkYear = getArtworkYear(meta.artworkYear);
            const artworkPeriod = getArtworkPeriod(meta.artworkYear);

            return (
              <a
                class="card"
                role="listitem"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                title={`${item.title} — opens in a new tab`}
                data-title={item.title.toLowerCase()}
                data-artist={meta.artist.toLowerCase()}
                data-date-viewed={meta.dateViewed}
                data-viewed-year={viewedYear}
                data-artwork-year={artworkYear ?? ''}
                data-artwork-period={artworkPeriod.key}
                data-artwork-period-label={artworkPeriod.label}
                data-artwork-period-order={artworkPeriod.order}
                data-movement-raw={meta.movement}
                data-original-index={index}
                data-note={(item.note || '').toLowerCase()}
                data-note-raw={item.note || ''}
              >
                <img
                  class="thumb"
                  src={item.cover}
                  alt={item.title}
                  loading="lazy"
                  decoding="async"
                  sizes="(max-width: 559px) 46vw, (max-width: 900px) 31vw, (min-width: 1800px) 230px, 20vw"
                />

                <div class="title">
                  {item.title}<span class="external-link-cue" aria-hidden="true">↗</span>
                  <span class="sr-only"> (opens in a new tab)</span>
                </div>

                <div class="card-meta">
                  {meta.artist ? <span><strong>{meta.artist}</strong></span> : null}
                  {meta.movement || meta.artworkYear ? (
                    <span>{[meta.movement, meta.artworkYear].filter(Boolean).join(' · ')}</span>
                  ) : null}
                  {meta.medium || meta.country ? (
                    <span>{[meta.medium, meta.country].filter(Boolean).join(' · ')}</span>
                  ) : null}
                  {meta.dateViewed ? <span>Viewed {meta.dateViewed}</span> : null}
                  {meta.source ? <span class="source">{meta.source}</span> : null}
                </div>

                {item.note ? <div class="note-bubble" role="tooltip">{item.note}</div> : null}
              </a>
            );
          })}
        </div>
      </>
    )}
  </main>
  <Footer />
</VideoBg>

<script>
  (function(){
    const $ = (selector, root = document) => root.querySelector(selector);
    const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));
    const debounce = (fn, ms) => {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), ms);
      };
    };
    const norm = value => (value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

    const grid = $('#grid');
    const input = $('#q');
    const movementSelect = $('#movement-filter');
    const viewedYearSelect = $('#viewed-year-filter');
    const periodSelect = $('#period-filter');
    const sortSelect = $('#sort-art');
    const resultsSummary = $('#results-summary');
    const clearFiltersButton = $('#clear-filters');
    const filterEmpty = $('#filter-empty');

    if (!grid || !input) return;

    const cards = $$('.card', grid);
    const haystack = new Map(
      cards.map(card => [
        card,
        norm(`${card.dataset.title || ''} ${card.dataset.artist || ''} ${card.dataset.note || ''}`),
      ]),
    );

    // Quilt is the visual default on desktop; List is the information-rich default on mobile.
    // The "auto" CSS state prevents the wrong layout from flashing before this script runs.
    const MOBILE_VIEW_QUERY = window.matchMedia('(max-width: 900px)');
    const VIEW_STORAGE_KEYS = {
      mobile: 'lifeloggerz-art-mobile-view',
      desktop: 'lifeloggerz-art-desktop-view',
    };
    const viewButtons = $$('.view-button[data-art-view]');

    function viewMode(){
      return MOBILE_VIEW_QUERY.matches ? 'mobile' : 'desktop';
    }

    function defaultView(){
      return viewMode() === 'mobile' ? 'list' : 'quilt';
    }

    function setArtView(view, persist = true){
      const nextView = view === 'list' ? 'list' : 'quilt';
      grid.dataset.artView = nextView;

      viewButtons.forEach(button => {
        button.setAttribute(
          'aria-pressed',
          button.dataset.artView === nextView ? 'true' : 'false',
        );
      });

      cards.forEach(card => card.classList.remove('show-note'));

      if (persist) {
        try {
          localStorage.setItem(VIEW_STORAGE_KEYS[viewMode()], nextView);
        } catch (_error) {
          // Keep the selection for this visit when browser storage is unavailable.
        }
      }
    }

    function restoreViewForCurrentScreen(){
      let savedView = defaultView();

      try {
        savedView = localStorage.getItem(VIEW_STORAGE_KEYS[viewMode()]) || defaultView();
      } catch (_error) {
        savedView = defaultView();
      }

      setArtView(savedView, false);
    }

    restoreViewForCurrentScreen();

    viewButtons.forEach(button => {
      button.addEventListener('click', () => setArtView(button.dataset.artView));
    });

    if (typeof MOBILE_VIEW_QUERY.addEventListener === 'function') {
      MOBILE_VIEW_QUERY.addEventListener('change', restoreViewForCurrentScreen);
    } else {
      MOBILE_VIEW_QUERY.addListener(restoreViewForCurrentScreen);
    }

    // Keep common labels consistent while preserving unusual movements instead of hiding them in "Other."
    const CANONICAL_MOVEMENTS = [
      'Byzantine',
      'Romanesque',
      'Gothic',
      'Proto-Renaissance',
      'Italian Renaissance',
      'Northern Renaissance',
      'Mannerism',
      'Baroque',
      'Flemish Baroque',
      'Dutch Golden Age',
      'Rococo',
      'Neoclassicism',
      'Romanticism',
      'Realism',
      'Pre-Raphaelite',
      'Impressionism',
      'Post-Impressionism',
      'Symbolism',
      'Art Nouveau',
      'Ukiyo-e',
      'Rinpa',
      'Fauvism',
      'Expressionism',
      'Cubism',
      'Futurism',
      'Dada',
      'Surrealism',
      'Constructivism',
      'Bauhaus',
      'Modernism',
      'Art Deco',
      'Abstract Expressionism',
      'Pop Art',
      'Minimalism',
      'Contemporary',
    ];

    const MOVEMENT_ALIAS_MAP = {};
    MOVEMENT_ALIAS_MAP[norm('Dutch Golden Age Painting')] = 'Dutch Golden Age';
    MOVEMENT_ALIAS_MAP[norm('Proto Renaissance')] = 'Proto-Renaissance';
    MOVEMENT_ALIAS_MAP[norm('Post Impressionism')] = 'Post-Impressionism';
    MOVEMENT_ALIAS_MAP[norm('Pre Raphaelite')] = 'Pre-Raphaelite';
    MOVEMENT_ALIAS_MAP[norm('Ukiyo-e/Rinpa')] = 'Ukiyo-e / Rinpa';
    MOVEMENT_ALIAS_MAP[norm('Ukiyo-e / Rinpa')] = 'Ukiyo-e / Rinpa';
    MOVEMENT_ALIAS_MAP[norm('Art-Nouveau')] = 'Art Nouveau';
    MOVEMENT_ALIAS_MAP[norm('Abstract expressionism')] = 'Abstract Expressionism';

    const canonicalByKey = new Map(
      CANONICAL_MOVEMENTS.map(movement => [norm(movement), movement]),
    );
    const movementOrder = new Map(
      CANONICAL_MOVEMENTS.map((movement, index) => [movement, index]),
    );
    const movementsInUse = new Set();

    cards.forEach(card => {
      const rawMovement = (card.dataset.movementRaw || '').trim();
      if (!rawMovement) return;

      const rawKey = norm(rawMovement);
      const canonical = canonicalByKey.get(rawKey) || MOVEMENT_ALIAS_MAP[rawKey] || rawMovement;

      card.dataset.movement = canonical;
      card.dataset.movementKey = norm(canonical);
      movementsInUse.add(canonical);
    });

    if (movementSelect) {
      [...movementsInUse]
        .sort((a, b) => {
          const aOrder = movementOrder.has(a) ? movementOrder.get(a) : Number.MAX_SAFE_INTEGER;
          const bOrder = movementOrder.has(b) ? movementOrder.get(b) : Number.MAX_SAFE_INTEGER;
          return aOrder - bOrder || a.localeCompare(b);
        })
        .forEach(movement => {
          const option = document.createElement('option');
          option.value = movement;
          option.textContent = movement;
          movementSelect.appendChild(option);
        });
    }

    if (viewedYearSelect) {
      [...new Set(cards.map(card => card.dataset.viewedYear).filter(Boolean))]
        .sort((a, b) => Number(b) - Number(a))
        .forEach(year => {
          const option = document.createElement('option');
          option.value = year;
          option.textContent = year;
          viewedYearSelect.appendChild(option);
        });
    }

    if (periodSelect) {
      const periodsInUse = new Map();

      cards.forEach(card => {
        const key = card.dataset.artworkPeriod || 'unknown';
        const label = card.dataset.artworkPeriodLabel || 'Unknown date';
        const order = Number(card.dataset.artworkPeriodOrder || -1);

        if (!periodsInUse.has(key)) periodsInUse.set(key, { key, label, order });
      });

      [...periodsInUse.values()]
        .sort((a, b) => b.order - a.order || a.label.localeCompare(b.label))
        .forEach(period => {
          const option = document.createElement('option');
          option.value = period.key;
          option.textContent = period.label;
          periodSelect.appendChild(option);
        });
    }

    const collator = new Intl.Collator(undefined, { sensitivity: 'base', numeric: true });

    function parseViewedDate(value){
      const cleaned = String(value || '')
        .replace(/(\d)(st|nd|rd|th)\b/gi, '$1')
        .trim();

      const numericDate = cleaned.match(/^\s*(\d{1,2})[\/-](\d{1,2})[\/-](\d{2}|\d{4})\s*$/);
      if (numericDate) {
        const month = Number(numericDate[1]);
        const day = Number(numericDate[2]);
        const rawYear = numericDate[3];
        const year = rawYear.length === 2 ? 2000 + Number(rawYear) : Number(rawYear);
        const timestamp = Date.UTC(year, month - 1, day);
        return Number.isNaN(timestamp) ? null : timestamp;
      }

      const timestamp = Date.parse(cleaned);
      return Number.isNaN(timestamp) ? null : timestamp;
    }

    function compareNullableNumbers(a, b, direction){
      const aMissing = a === null;
      const bMissing = b === null;
      if (aMissing && bMissing) return 0;
      if (aMissing) return 1;
      if (bMissing) return -1;
      return direction === 'asc' ? a - b : b - a;
    }

    function sortArt(){
      const mode = sortSelect ? sortSelect.value : 'date-desc';

      const orderedCards = [...cards].sort((a, b) => {
        let comparison = 0;

        if (mode === 'date-desc' || mode === 'date-asc') {
          comparison = compareNullableNumbers(
            parseViewedDate(a.dataset.dateViewed),
            parseViewedDate(b.dataset.dateViewed),
            mode === 'date-asc' ? 'asc' : 'desc',
          );
        } else if (mode === 'title-asc') {
          comparison = collator.compare(a.dataset.title || '', b.dataset.title || '');
        } else if (mode === 'artist-asc') {
          comparison = collator.compare(a.dataset.artist || '', b.dataset.artist || '');
        } else if (mode === 'artwork-desc' || mode === 'artwork-asc') {
          const aYear = a.dataset.artworkYear === '' ? null : Number(a.dataset.artworkYear);
          const bYear = b.dataset.artworkYear === '' ? null : Number(b.dataset.artworkYear);

          comparison = compareNullableNumbers(
            Number.isFinite(aYear) ? aYear : null,
            Number.isFinite(bYear) ? bYear : null,
            mode === 'artwork-asc' ? 'asc' : 'desc',
          );
        }

        if (comparison !== 0) return comparison;
        return Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0);
      });

      orderedCards.forEach(card => grid.appendChild(card));
    }

    function hasActiveFilters(){
      return Boolean(
        input.value.trim() ||
        movementSelect?.value ||
        viewedYearSelect?.value ||
        periodSelect?.value
      );
    }

    function filter(){
      const search = norm(input.value.trim());
      const words = search ? search.split(/\s+/) : [];
      const selectedMovement = movementSelect ? movementSelect.value : '';
      const selectedMovementKey = norm(selectedMovement);
      const selectedViewedYear = viewedYearSelect ? viewedYearSelect.value : '';
      const selectedPeriod = periodSelect ? periodSelect.value : '';
      let visibleCount = 0;

      cards.forEach(card => {
        const textMatches = !words.length || words.every(word => haystack.get(card).includes(word));
        const movementMatches = !selectedMovement || card.dataset.movementKey === selectedMovementKey;
        const viewedYearMatches = !selectedViewedYear || card.dataset.viewedYear === selectedViewedYear;
        const periodMatches = !selectedPeriod || card.dataset.artworkPeriod === selectedPeriod;
        const isVisible = textMatches && movementMatches && viewedYearMatches && periodMatches;

        card.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount += 1;
      });

      if (resultsSummary) {
        resultsSummary.textContent = `Showing ${visibleCount.toLocaleString()} of ${cards.length.toLocaleString()} artworks`;
      }

      if (clearFiltersButton) clearFiltersButton.hidden = !hasActiveFilters();
      if (filterEmpty) filterEmpty.hidden = visibleCount !== 0;
    }

    function clearFilters(){
      input.value = '';
      if (movementSelect) movementSelect.value = '';
      if (viewedYearSelect) viewedYearSelect.value = '';
      if (periodSelect) periodSelect.value = '';
      filter();
    }

    input.addEventListener('input', debounce(filter, 80));
    if (movementSelect) movementSelect.addEventListener('change', filter);
    if (viewedYearSelect) viewedYearSelect.addEventListener('change', filter);
    if (periodSelect) periodSelect.addEventListener('change', filter);
    if (sortSelect) sortSelect.addEventListener('change', sortArt);
    if (clearFiltersButton) clearFiltersButton.addEventListener('click', clearFilters);

    window.addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        clearFilters();
        if (sortSelect) sortSelect.value = 'date-desc';
        sortArt();
        input.focus();
      } else if (event.key === '/' && event.target === document.body) {
        event.preventDefault();
        input.focus();
      }
    });

    sortArt();
    filter();

    function adjust(bubble){
      if (!bubble) return;
      bubble.style.setProperty('--shift', '0px');
      const rect = bubble.getBoundingClientRect();
      const margin = 8;
      let shift = 0;

      if (rect.left < margin) shift = margin - rect.left;
      else if (rect.right > innerWidth - margin) shift = (innerWidth - margin) - rect.right;

      if (shift) bubble.style.setProperty('--shift', `${shift}px`);
    }

    grid.addEventListener('mouseenter', event => {
      const bubble = event.target.closest('.card')?.querySelector('.note-bubble');
      if (!bubble) return;
      requestAnimationFrame(() => adjust(bubble));
    }, true);

    grid.addEventListener('focusin', event => {
      const bubble = event.target.closest('.card')?.querySelector('.note-bubble');
      if (!bubble) return;
      requestAnimationFrame(() => adjust(bubble));
    });

    addEventListener('resize', () => $$('.note-bubble').forEach(adjust));

    document.addEventListener('click', event => {
      const card = event.target.closest('.card');

      if (!card) {
        cards.forEach(item => item.classList.remove('show-note'));
        return;
      }

      if (!card.querySelector('.note-bubble')) return;

      const isMobileQuiltView =
        MOBILE_VIEW_QUERY.matches && grid.dataset.artView === 'quilt';

      if (!isMobileQuiltView) return;
      if (card.classList.contains('show-note')) return;

      event.preventDefault();
      cards.forEach(item => item.classList.remove('show-note'));
      card.classList.add('show-note');
      requestAnimationFrame(() => adjust(card.querySelector('.note-bubble')));
      setTimeout(() => card.classList.remove('show-note'), 2500);
    }, true);

    const infoButton = $('#info-toggle');
    const infoPanel = $('#art-info');

    if (infoButton && infoPanel) {
      infoButton.addEventListener('click', () => {
        const isOpen = infoPanel.classList.toggle('info-panel--visible');
        infoPanel.hidden = !isOpen;
        infoButton.setAttribute('aria-pressed', isOpen ? 'true' : 'false');
        infoButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        if (isOpen) infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }
  })();
</script>

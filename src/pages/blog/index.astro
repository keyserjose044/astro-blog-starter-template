---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import VideoBg from '../../components/VideoBg.astro';
import BlogCard from '../../components/BlogCard.astro';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const link = (p: string = '') => `${base}${p}`;

function inferCategory(tags: readonly string[] = [], title = '') {
  const haystack = `${title} ${tags.join(' ')}`.toLowerCase();
  if (haystack.includes('template')) return 'Templates';
  if (haystack.includes('automation') || haystack.includes('python') || haystack.includes('autohotkey')) return 'Automation';
  if (haystack.includes('google sheets') || haystack.includes('raw data') || haystack.includes('daily snapshot')) return 'Life Archive';
  if (haystack.includes('research')) return 'Research';
  return 'Field Notes';
}

const posts = (await getCollection('blog', ({ data }) => data?.draft !== true))
  .map((p) => ({
    ...p,
    _pub: p.data?.pubDate instanceof Date
      ? p.data.pubDate
      : new Date(p.data?.pubDate ?? 0),
    _tags: p.data.tags ?? [],
    _category: p.data.category ?? inferCategory(p.data.tags ?? [], p.data.title),
  }))
  .sort((a, b) => (b._pub?.getTime?.() ?? 0) - (a._pub?.getTime?.() ?? 0));

const slugKey = (slug: string) => slug.toLowerCase();
const bySlug = new Map(posts.map((post) => [slugKey(post.slug), post]));
const startHereSlugs = ['rawdatapost2025', 'daily-snapshot', '2026interactivegstemplate'];
const startHerePosts = startHereSlugs
  .map((slug) => bySlug.get(slugKey(slug)))
  .filter((post): post is (typeof posts)[number] => Boolean(post));
const displayedStartHerePosts = startHerePosts.length ? startHerePosts : posts.slice(0, 3);
const morePosts = posts.filter((post) => !startHereSlugs.includes(slugKey(post.slug)));

const filterChips = [
  { label: 'All', value: 'all' },
  { label: 'Templates', value: 'templates' },
  { label: 'Automation', value: 'automation' },
  { label: 'Google Sheets', value: 'google sheets' },
  { label: 'Stats & Graphs', value: 'stats graphs' },
  { label: 'Research', value: 'research' },
];

const upcomingPosts = [
  { title: 'How My Google Apps Script System Works', category: 'Automation' },
  { title: 'AutoHotkey for Workflow Automations', category: 'Workflow' },
  { title: 'Condensing Diary Logs using AI in Google Sheets', category: 'AI + Sheets' },
  { title: 'What I Track and What I Refuse to Track', category: 'Philosophy' },
  { title: 'How to Build a $10/Year Website Like This One', category: 'Web' },
  { title: 'Conquering the Western Classical Music Canon: One Composer at a Time', category: 'Music' },
  { title: 'Why You Need a Treadmill Desk', category: 'Habits' },
  { title: 'Close Your Eyes = 30% Brainpower Boost', category: 'Focus' },
  { title: 'My Daily Non-Negotiables: Bare Minimums for Habits', category: 'Habits' },
  { title: 'LifeLoggerz StudyTimer: Turning Focus into Feedback Loops', category: 'Automation' },
  { title: 'Lab Automation: Turning Months of Manual Work Into Minutes', category: 'Research' },
  { title: 'Graph Gallery: What the Archive Can Show', category: 'Stats' },
];

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const postSearchPayload = (post: (typeof posts)[number]) =>
  [post.data.title, post.data.description, post._category, ...(post._tags ?? [])]
    .join(' ')
    .toLowerCase();

const postTagPayload = (post: (typeof posts)[number]) => {
  const tokens = new Set<string>();
  const title = post.data.title.toLowerCase();
  const description = post.data.description.toLowerCase();
  const joinedTags = (post._tags ?? []).join(' ').toLowerCase();
  const all = `${title} ${description} ${joinedTags} ${post._category.toLowerCase()}`;

  tokens.add('all');
  if (all.includes('template')) tokens.add('templates');
  if (all.includes('automation') || all.includes('python') || all.includes('autohotkey') || all.includes('script')) tokens.add('automation');
  if (all.includes('google sheets') || all.includes('raw data') || all.includes('sheet')) tokens.add('google sheets');
  if (all.includes('stat') || all.includes('graph') || all.includes('snapshot')) tokens.add('stats graphs');
  if (all.includes('research') || all.includes('paper')) tokens.add('research');

  return Array.from(tokens).join('|');
};
---

<!doctype html>
<html lang="en" data-blog-layout="cards">
  <head>
    <BaseHead
      title={`${SITE_TITLE} — Field Notes`}
      description="Essays, templates, scripts, screenshots, and experiments from building LifeLoggerz: a searchable archive of daily life."
      image="/images_webp/daily_snapshot.webp"
    />
    <style>
      :root {
        --blog-max: min(1120px, calc(100% - 2rem));
        --border: rgba(229, 233, 240, 0.95);
        --blue: #0f4cff;
        --ink: rgb(var(--black));
        --muted: #64748b;
        --card-bg: rgba(255, 255, 255, 0.9);
        --soft-shadow: 0 14px 34px rgba(15, 18, 25, 0.08);
      }

      html,
      body {
        max-width: 100%;
        overflow-x: hidden;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      main.blog-main {
        width: var(--blog-max);
        max-width: 1120px;
        margin: 0 auto;
        padding: clamp(1.4rem, 4vw, 4rem) 0 3.5rem;
      }

      .blog-hero,
      .archive-shell,
      .upcoming-shell,
      .path-card,
      .upcoming-item {
        border: 1px solid var(--border);
        background: var(--card-bg);
        box-shadow: var(--soft-shadow);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .blog-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(330px, 1.1fr);
        gap: clamp(1.1rem, 3.4vw, 2.5rem);
        align-items: start;
        margin: 0 0 clamp(1.5rem, 4vw, 3rem);
        padding: clamp(1.05rem, 3.5vw, 2.2rem);
        border-radius: 30px;
      }

      .eyebrow {
        margin: 0 0 0.55rem;
        color: var(--blue);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      .blog-hero h1 {
        max-width: 10ch;
        margin: 0;
        font-size: clamp(2.45rem, 7vw, 5.2rem);
        letter-spacing: -0.07em;
        line-height: 0.94;
      }

      .hero-lede {
        max-width: 60ch;
        margin: 1rem 0 0.75rem;
        color: var(--ink);
        font-size: clamp(1.16rem, 2.2vw, 1.48rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.16;
      }

      .hero-subcopy {
        max-width: 62ch;
        margin: 0;
        color: rgb(var(--gray-dark));
        font-size: clamp(0.98rem, 1.4vw, 1.06rem);
        line-height: 1.62;
      }

      .reading-path {
        min-width: 0;
      }

      .reading-path__header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .reading-path__header h2 {
        margin: 0;
        font-size: clamp(1.35rem, 2.7vw, 2.15rem);
        letter-spacing: -0.05em;
        line-height: 1;
      }

      .path-list,
      .upcoming-list,
      ul#grid {
        list-style: none;
        padding: 0;
      }

      .path-list {
        display: grid;
        gap: 0.75rem;
        margin: 0;
      }

      .path-card {
        display: grid;
        grid-template-columns: 112px minmax(0, 1fr);
        gap: 0.85rem;
        min-width: 0;
        padding: 0.65rem;
        overflow: hidden;
        border-radius: 20px;
        color: inherit;
        text-decoration: none;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .path-card:hover,
      .path-card:focus-visible,
      .upcoming-item:hover,
      .upcoming-item:focus-visible {
        border-color: rgba(15, 76, 255, 0.22);
        box-shadow: 0 18px 36px rgba(15, 18, 25, 0.12);
        outline: none;
        transform: translateY(-2px);
      }

      .path-card img {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 112px;
        border-radius: 15px;
        background: #f8fafc;
        object-fit: cover;
        object-position: top left;
      }

      .path-card__copy {
        min-width: 0;
        align-self: center;
      }

      .path-card__step {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--blue);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        line-height: 1.1;
        text-transform: uppercase;
      }

      .path-card strong {
        display: block;
        margin-bottom: 0.3rem;
        color: var(--ink);
        font-size: clamp(1rem, 1.5vw, 1.12rem);
        letter-spacing: -0.025em;
        line-height: 1.16;
        overflow-wrap: anywhere;
      }

      .path-card p {
        display: -webkit-box;
        margin: 0 0 0.45rem;
        overflow: hidden;
        color: rgb(var(--gray-dark));
        font-size: 0.9rem;
        line-height: 1.42;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
      }

      .path-card time {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 700;
      }

      .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-heading h2 {
        margin: 0;
        font-size: clamp(1.7rem, 3.7vw, 2.75rem);
        letter-spacing: -0.055em;
        line-height: 1;
      }

      .section-heading p:not(.eyebrow) {
        max-width: 62ch;
        margin: 0.45rem 0 0;
        color: rgb(var(--gray-dark));
        font-size: 1rem;
        line-height: 1.55;
      }

      .archive-shell,
      .upcoming-shell {
        margin-bottom: clamp(1.7rem, 5vw, 3.4rem);
        padding: clamp(1rem, 3vw, 1.35rem);
        border-radius: 28px;
      }

      .upcoming-shell {
        margin-bottom: 0;
      }

      .archive-topbar {
        display: grid;
        grid-template-columns: minmax(240px, 420px) 1fr;
        gap: 0.9rem;
        align-items: start;
        margin: 0 0 1.15rem;
      }

      .toolbar input[type='search'] {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: #ffffff;
        color: #111111;
        font-size: 1rem;
        line-height: 1.4;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
        transition:
          border-color 0.2s ease,
          box-shadow 0.2s ease;
      }

      .toolbar input[type='search']::placeholder {
        color: #9ca3af;
      }

      .toolbar input[type='search']:focus {
        outline: none;
        border-color: #38bdf8;
        box-shadow:
          0 0 0 1px rgba(56, 189, 248, 0.7),
          0 0 18px rgba(56, 189, 248, 0.25);
      }

      .filter-chips {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .filter-chip {
        min-height: 39px;
        padding: 0.48rem 0.78rem;
        border: 1px solid rgba(15, 76, 255, 0.12);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.82);
        color: #334155;
        cursor: pointer;
        font: inherit;
        font-size: 0.86rem;
        font-weight: 800;
        line-height: 1.1;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease, transform 0.16s ease;
      }

      .filter-chip:hover,
      .filter-chip:focus-visible {
        border-color: rgba(15, 76, 255, 0.3);
        color: var(--blue);
        outline: none;
        transform: translateY(-1px);
      }

      .filter-chip.is-active {
        border-color: var(--blue);
        background: var(--blue);
        color: #fff;
      }

      .empty,
      .more-empty {
        display: none;
        margin: 1rem 0 0;
        padding: 1rem;
        border: 1px dashed rgba(15, 76, 255, 0.22);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.72);
        color: #475569;
        text-align: center;
      }

      .more-empty {
        display: block;
      }

      ul#grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin: 0;
      }

      .upcoming-intro {
        max-width: 72ch;
        margin: 0 0 1rem;
        color: rgb(var(--gray-dark));
        font-size: 0.98rem;
        line-height: 1.55;
      }

      .upcoming-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 245px), 1fr));
        gap: 0.62rem;
        margin: 0;
      }

      .upcoming-item {
        min-width: 0;
        padding: 0.78rem 0.82rem;
        overflow: hidden;
        border-radius: 16px;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .upcoming-item span {
        display: block;
        margin-bottom: 0.28rem;
        color: var(--blue);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        line-height: 1.1;
        text-transform: uppercase;
        overflow-wrap: anywhere;
      }

      .upcoming-item strong {
        display: block;
        color: var(--ink);
        font-size: 0.94rem;
        letter-spacing: -0.018em;
        line-height: 1.18;
        overflow-wrap: anywhere;
        hyphens: auto;
      }

      @media (max-width: 960px) {
        .blog-hero,
        .archive-topbar {
          grid-template-columns: 1fr;
        }

        .filter-chips {
          justify-content: flex-start;
        }

        ul#grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 720px) {
        main.blog-main {
          width: min(100% - 1rem, 1120px);
          padding-top: 0.7rem;
          padding-bottom: 2.25rem;
        }

        .blog-hero,
        .archive-shell,
        .upcoming-shell {
          border-radius: 22px;
        }

        .blog-hero {
          gap: 1rem;
          padding: 0.82rem;
        }

        .blog-hero h1 {
          max-width: 12ch;
          font-size: clamp(2rem, 10.5vw, 2.95rem);
        }

        .hero-lede {
          margin-top: 0.65rem;
          font-size: 1.02rem;
          line-height: 1.22;
        }

        .hero-subcopy,
        .section-heading p:not(.eyebrow),
        .upcoming-intro {
          font-size: 0.92rem;
          line-height: 1.52;
        }

        .reading-path__header {
          display: block;
          margin-bottom: 0.65rem;
        }

        .reading-path__header h2,
        .section-heading h2 {
          font-size: clamp(1.42rem, 6.5vw, 2rem);
        }

        .path-list,
        .upcoming-list,
        ul#grid {
          grid-template-columns: 1fr;
        }

        .path-card {
          grid-template-columns: 88px minmax(0, 1fr);
          gap: 0.66rem;
          padding: 0.55rem;
          border-radius: 16px;
        }

        .path-card img {
          min-height: 90px;
          border-radius: 12px;
        }

        .path-card strong {
          font-size: 0.96rem;
        }

        .path-card p {
          font-size: 0.82rem;
          line-height: 1.35;
          -webkit-line-clamp: 2;
        }

        .path-card time {
          font-size: 0.72rem;
        }

        .section-heading {
          display: block;
        }

        .archive-shell,
        .upcoming-shell {
          padding: 0.72rem;
        }

        .archive-topbar {
          gap: 0.7rem;
          margin-bottom: 0.9rem;
        }

        .filter-chips {
          flex-wrap: nowrap;
          justify-content: flex-start;
          overflow-x: auto;
          padding-bottom: 0.18rem;
          scrollbar-width: thin;
        }

        .filter-chip {
          flex: 0 0 auto;
          min-height: 36px;
          padding-inline: 0.68rem;
          font-size: 0.78rem;
        }

        .upcoming-list {
          gap: 0.5rem;
        }

        .upcoming-item {
          padding: 0.68rem 0.72rem;
          border-radius: 14px;
        }

        .upcoming-item strong {
          font-size: 0.9rem;
        }
      }

      @media (max-width: 430px) {
        main.blog-main {
          width: min(100% - 0.75rem, 1120px);
        }

        .blog-hero,
        .archive-shell,
        .upcoming-shell {
          border-radius: 18px;
        }

        .toolbar input[type='search'] {
          padding: 10px 12px;
          border-radius: 13px;
          font-size: 0.92rem;
        }

        .eyebrow {
          font-size: 0.7rem;
          letter-spacing: 0.1em;
        }

        .path-card {
          grid-template-columns: 76px minmax(0, 1fr);
        }

        .path-card img {
          min-height: 82px;
        }
      }
    </style>
  </head>

  <body>
    <VideoBg>
      <Header />
      <main class="blog-main">
        {posts.length === 0 ? (
          <section class="archive-shell">
            <p>No posts yet. Add markdown files to <code>src/content/blog/</code>.</p>
          </section>
        ) : (
          <>
            <section class="blog-hero" aria-labelledby="blog-title">
              <div class="blog-hero__copy">
                <p class="eyebrow">Start here</p>
                <h1 id="blog-title">Field Notes</h1>
                <p class="hero-lede">
                  The written manual behind LifeLoggerz: templates, scripts, workflows, and reflections on turning daily life into searchable data.
                </p>
                <p class="hero-subcopy">
                  Read the three core posts first. They explain the raw data backbone, the day-level output,
                  and the copyable template before you branch into the rest of the archive.
                </p>
              </div>

              <aside class="reading-path" aria-labelledby="reading-path-heading">
                <div class="reading-path__header">
                  <div>
                    <p class="eyebrow">Clearest path</p>
                    <h2 id="reading-path-heading">Read these first</h2>
                  </div>
                </div>

                <ol class="path-list">
                  {displayedStartHerePosts.map((post, index) => (
                    <li>
                      <a class="path-card" href={link(`blog/${post.slug}/`)}>
                        {post.data.heroImage && (
                          <img
                            src={post.data.heroImage}
                            alt=""
                            loading={index === 0 ? 'eager' : 'lazy'}
                            fetchpriority={index === 0 ? 'high' : 'auto'}
                          />
                        )}
                        <div class="path-card__copy">
                          <span class="path-card__step">
                            {index + 1} · {index === 0 ? 'Foundation' : index === 1 ? 'Output' : 'Try it'}
                          </span>
                          <strong>{post.data.title}</strong>
                          <p>{post.data.description}</p>
                          <time datetime={post._pub.toISOString()}>{dateFormatter.format(post._pub)}</time>
                        </div>
                      </a>
                    </li>
                  ))}
                </ol>
              </aside>
            </section>

            <section class="archive-shell" aria-labelledby="more-posts-heading">
              <div class="section-heading">
                <div>
                  <p class="eyebrow">Archive</p>
                  <h2 id="more-posts-heading">More posts</h2>
                  <p>
                    The three foundation posts stay fixed above. Search the remaining templates, notes, and process posts here.
                  </p>
                </div>
              </div>

              {morePosts.length > 0 ? (
                <>
                  <div class="archive-topbar" aria-label="Blog filters">
                    <div class="toolbar">
                      <input
                        id="q"
                        type="search"
                        placeholder="Search more posts"
                        aria-label="Filter blog posts"
                      />
                    </div>

                    <div class="filter-chips" aria-label="Filter by topic">
                      {filterChips.map((chip) => (
                        <button
                          class:list={['filter-chip', chip.value === 'all' && 'is-active']}
                          type="button"
                          data-filter={chip.value}
                          aria-pressed={chip.value === 'all' ? 'true' : 'false'}
                        >
                          {chip.label}
                        </button>
                      ))}
                    </div>
                  </div>

                  <div class="empty" id="empty">No posts match your search.</div>

                  <ul id="grid">
                    {morePosts.map((post) => (
                      <BlogCard
                        href={link(`blog/${post.slug}/`)}
                        title={post.data.title}
                        description={post.data.description}
                        pubDate={post._pub}
                        heroImage={post.data.heroImage}
                        heroVideo={post.data.heroVideo}
                        tags={post._tags}
                        category={post._category}
                        data-search={postSearchPayload(post)}
                        data-tags={postTagPayload(post)}
                      />
                    ))}
                  </ul>
                </>
              ) : (
                <p class="more-empty">More posts are coming soon. The core reading path above is the best place to start.</p>
              )}
            </section>
          </>
        )}

        <section class="upcoming-shell" aria-labelledby="upcoming-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Coming next</p>
              <h2 id="upcoming-heading">Upcoming blog posts</h2>
              <p>
                A compact roadmap of the automation, habit, website, and archive-writing posts planned next.
              </p>
            </div>
          </div>

          <ul class="upcoming-list">
            {upcomingPosts.map((post) => (
              <li class="upcoming-item">
                <span>{post.category}</span>
                <strong>{post.title}</strong>
              </li>
            ))}
          </ul>
        </section>
      </main>
      <Footer />
    </VideoBg>

    <script>
      (function () {
        const $ = (s, r = document) => r.querySelector(s);
        const $$ = (s, r = document) => Array.from(r.querySelectorAll(s));
        const norm = (s) =>
          (s || '')
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');
        const debounce = (fn, ms) => {
          let t;
          return (...a) => {
            clearTimeout(t);
            t = setTimeout(() => fn(...a), ms);
          };
        };

        const input = $('#q');
        const empty = $('#empty');
        const items = $$('#grid [data-search]');
        const chips = $$('.filter-chip');
        let activeFilter = 'all';

        function setActiveChip(value) {
          activeFilter = value || 'all';
          chips.forEach((chip) => {
            const isActive = chip.getAttribute('data-filter') === activeFilter;
            chip.classList.toggle('is-active', isActive);
            chip.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
          applyFilter();
        }

        function applyFilter() {
          if (!items.length) return;

          const query = norm(input?.value || '');
          let visibleCount = 0;

          items.forEach((el) => {
            const search = norm(el.getAttribute('data-search') || '');
            const tags = norm(el.getAttribute('data-tags') || '');
            const matchesText = !query || search.includes(query);
            const matchesChip = activeFilter === 'all' || tags.includes(norm(activeFilter));
            const matches = matchesText && matchesChip;
            const li = el.closest('li') || el;

            if (matches) {
              li.style.display = '';
              visibleCount += 1;
            } else {
              li.style.display = 'none';
            }
          });

          if (empty) {
            empty.style.display = visibleCount ? 'none' : 'block';
          }
        }

        if (input) {
          input.addEventListener('input', debounce(applyFilter, 80));
          window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
              input.value = '';
              setActiveChip('all');
              input.focus();
            } else if (e.key === '/' && e.target === document.body) {
              e.preventDefault();
              input.focus();
            }
          });
        }

        chips.forEach((chip) => {
          chip.addEventListener('click', () => setActiveChip(chip.getAttribute('data-filter') || 'all'));
        });

        applyFilter();
      })();
    </script>
  </body>
</html>

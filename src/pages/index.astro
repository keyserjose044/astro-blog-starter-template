---
/* src/pages/index.astro */
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoBg from '../components/VideoBg.astro';
import HeroTitleRipple from '../components/HeroTitleRipple.astro';
import SeeAllPill from '../components/SeeAllPill.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE } from '../consts';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const link = (p: string = '') => `${base}${p}`;

// Load non-draft posts and sort newest → oldest
const rawPosts = await getCollection('blog', ({ data }) => data?.draft !== true);

const posts = rawPosts
  .map((p) => {
    const raw = p.data?.pubDate;
    const asDate = raw instanceof Date ? raw : raw ? new Date(raw) : null;
    const validDate = asDate && !Number.isNaN(asDate.valueOf()) ? asDate : null;
    return { ...p, _pub: validDate };
  })
  .sort((a, b) => (b._pub?.getTime?.() ?? 0) - (a._pub?.getTime?.() ?? 0));

const featuredPosts = posts.slice(0, 4);

const MS_PER_DAY = 24 * 60 * 60 * 1000;
const trackingStart = new Date('2023-01-01T00:00:00');
const today = new Date();
const daysTracked = Math.max(0, Math.floor((today.getTime() - trackingStart.getTime()) / MS_PER_DAY) + 1);

const projectStats = [
  { value: `${daysTracked.toLocaleString()}+`, label: 'days of structured tracking since Jan 2023' },
  { value: '150+', label: 'daily-life variables across the full system' },
  { value: '5 min', label: 'to log the core data on a normal day' },
  { value: '2023 → now', label: 'raw sheets, summaries, graphs, and templates' },
];

const startHere = [
  {
    eyebrow: 'Foundation',
    title: 'Raw Data Sheets',
    body: 'The daily Google Sheets system where sleep, food, work, hobbies, diary notes, places, people, and small life details become searchable data.',
    href: link('blog/rawdatapost2025/'),
  },
  {
    eyebrow: 'Output',
    title: 'Daily Snapshot',
    body: 'A single-page summary that pulls a whole day together: the numbers, diary context, images, quotes, blunders, and memorable details.',
    href: link('blog/daily-snapshot/'),
  },
  {
    eyebrow: 'Try it',
    title: 'Templates',
    body: 'Downloadable Google Sheets and workflow templates for people who want to build their own version instead of starting from zero.',
    href: link('templates/'),
  },
];

const systemSteps = [
  { step: '01', title: 'Track', body: 'Log the day while it is still fresh: sleep, meals, work, hobbies, diary notes, media, health, and context.' },
  { step: '02', title: 'Process', body: 'Use formulas, Apps Script, dashboards, and small automations to turn raw entries into clean summaries.' },
  { step: '03', title: 'Study', body: 'Use graphs, blog posts, and yearly comparisons to notice patterns that memory alone would miss.' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description="LifeLoggerz is a public experiment in turning daily life into searchable, visual, useful data through Google Sheets, dashboards, templates, and essays."
      image="/images_webp/daily_snapshot.webp"
    />
  </head>

  <body>
    <VideoBg>
      <Header />

      <main class="home-main">
        <!-- Hero -->
        <section class="hero" aria-labelledby="home-title">
          <div class="hero-copy">
            <p class="eyebrow">Life as a living archive</p>
            <HeroTitleRipple as="h1" class="hero-title" id="home-title">
              LifeLoggerz
            </HeroTitleRipple>

            <p class="hero-lede">
              A multi-year public experiment in turning ordinary days into
              <strong>searchable, visual, useful data</strong>.
            </p>

            <p class="hero-subcopy">
              I track the raw details of daily life, process them through Google Sheets and automation,
              then publish the systems, templates, graphs, and lessons so others can build higher.
            </p>

            <div class="hero-actions" aria-label="Primary homepage links">
              <a class="button button-primary" href={link('stats/')}>Explore the data</a>
              <a class="button button-secondary" href={link('blog/rawdatapost2025/')}>Start with the sheets</a>
              <a class="button button-ghost" href={link('templates/')}>Use the templates</a>
            </div>
          </div>

          <aside class="hero-preview" aria-label="LifeLoggerz system preview">
            <div class="preview-image-wrap">
              <img
                src="/images_webp/daily_snapshot.webp"
                alt="Daily Snapshot spreadsheet preview from the LifeLoggerz system"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <div class="preview-body">
              <p class="preview-kicker">System preview</p>
              <h2>Raw data becomes a readable day.</h2>
              <p>
                Sheets are the input. Daily snapshots, graphs, templates, and essays are the output.
              </p>
            </div>
          </aside>
        </section>

        <!-- Proof / scale -->
        <section class="proof-strip" aria-label="LifeLoggerz project scale">
          {projectStats.map((stat) => (
            <article class="proof-card">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </section>

        <!-- Start Here -->
        <section class="home-section" aria-labelledby="start-heading">
          <div class="section-heading centered">
            <p class="eyebrow">Start here</p>
            <h2 id="start-heading">The fastest way to understand the project</h2>
            <p>
              LifeLoggerz is not just a blog index. It is a public tour through the data system,
              the thinking behind it, and the tools that make it reusable.
            </p>
          </div>

          <div class="start-grid">
            {startHere.map((item) => (
              <a class="start-card" href={item.href}>
                <span class="card-eyebrow">{item.eyebrow}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <span class="card-link">Open →</span>
              </a>
            ))}
          </div>
        </section>

        <!-- Featured data + interaction -->
        <section class="home-section feature-band" aria-labelledby="data-heading">
          <div class="feature-copy">
            <p class="eyebrow">Data, not vibes</p>
            <h2 id="data-heading">See the graphs behind the story</h2>
            <p>
              The stats page turns years of logging into visual feedback: guitar practice,
              audiobook hours, running miles, diary word counts, and more as the system grows.
            </p>
            <a class="text-link" href={link('stats/')}>Go to the stats dashboard →</a>
          </div>

          <div class="feature-cards" aria-label="Featured project areas">
            <a class="mini-card" href={link('stats/')}>
              <span class="mini-icon">📈</span>
              <strong>Stats Dashboard</strong>
              <span>Graphs built from the archive.</span>
            </a>
            <a class="mini-card" href={link('templates/')}>
              <span class="mini-icon">📄</span>
              <strong>Templates</strong>
              <span>Sheets and workflows to copy.</span>
            </a>
            <a class="mini-card" href={link('faq/')}>
              <span class="mini-icon">❓</span>
              <strong>FAQ</strong>
              <span>Why I track the way I do.</span>
            </a>
            <a class="mini-card" href={link('inspirations/')}>
              <span class="mini-icon">💡</span>
              <strong>Inspirations</strong>
              <span>The lineage behind the idea.</span>
            </a>
          </div>
        </section>

        <!-- How it works -->
        <section class="home-section" aria-labelledby="system-heading">
          <div class="section-heading centered">
            <p class="eyebrow">How it works</p>
            <h2 id="system-heading">Input → processing → useful memory</h2>
          </div>

          <div class="system-grid">
            {systemSteps.map((item) => (
              <article class="system-card">
                <span class="system-step">{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </section>

        <!-- Latest posts -->
        <section class="home-section" aria-labelledby="blog-heading">
          <div class="home-section-header">
            <div>
              <p class="eyebrow">Featured reading</p>
              <h2 class="home-section-title" id="blog-heading">Latest from the Blog</h2>
            </div>
            <SeeAllPill href={link('blog/')} />
          </div>

          {featuredPosts.length === 0 ? (
            <p>No posts yet. Add some markdown files to <code>src/content/blog/</code>!</p>
          ) : (
            <ul class="post-grid">
              {featuredPosts.map((post, i) => (
                <BlogCard
                  href={link(`blog/${post.slug}/`)}
                  title={post.data.title}
                  pubDate={post._pub}
                  heroImage={post.data.heroImage}
                  heroVideo={post.data.heroVideo}
                  {...(i === 0 ? { 'data-lcp': true } : {})}
                />
              ))}
            </ul>
          )}
        </section>

        <!-- Mission -->
        <section class="home-section mission-card" aria-labelledby="mission-heading">
          <p class="eyebrow">Why this exists</p>
          <h2 id="mission-heading">The point is not to optimize every minute.</h2>
          <p>
            The point is to remember life clearly, study habits honestly, and leave a trail
            that another curious person can build from. Even if one person creates a better
            system after seeing this, LifeLoggerz has done its job.
          </p>
        </section>
      </main>

      <Footer />
    </VideoBg>
  </body>
</html>

<style>
  .home-main {
    width: min(1120px, calc(100% - 2rem));
    max-width: 1120px;
    padding: clamp(1.5rem, 4vw, 4rem) 0 3.5rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    margin: 1rem 0 clamp(1.5rem, 4vw, 3rem);
  }

  .hero-copy {
    text-align: left;
  }

  .eyebrow {
    margin: 0 0 0.55rem;
    color: #0f4cff;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.07em;
    line-height: 0.95;
  }

  .hero-lede {
    max-width: 13ch;
    margin: 1rem 0 1rem;
    color: rgb(var(--black));
    font-size: clamp(1.55rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.02;
  }

  .hero-subcopy {
    max-width: 62ch;
    margin: 0 0 1.35rem;
    color: rgb(var(--gray-dark));
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .button,
  .text-link,
  .start-card,
  .mini-card {
    text-decoration: none;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.62rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 76, 255, 0.18);
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.1;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease;
  }

  .button:hover,
  .button:focus-visible,
  .start-card:hover,
  .start-card:focus-visible,
  .mini-card:hover,
  .mini-card:focus-visible {
    transform: translateY(-2px);
  }

  .button-primary {
    background: #0f4cff;
    color: #ffffff;
    box-shadow: 0 14px 28px rgba(15, 76, 255, 0.22);
  }

  .button-primary:hover,
  .button-primary:focus-visible {
    color: #ffffff;
    box-shadow: 0 18px 38px rgba(15, 76, 255, 0.28);
  }

  .button-secondary {
    background: #ffffff;
    color: #0f4cff;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
  }

  .button-ghost {
    background: rgba(255, 255, 255, 0.55);
    color: rgb(var(--gray-dark));
  }

  .hero-preview,
  .mission-card,
  .feature-band,
  .proof-card,
  .start-card,
  .system-card,
  .mini-card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(var(--gray-light), 0.95);
    box-shadow: 0 14px 34px rgba(15, 18, 25, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero-preview {
    overflow: hidden;
    border-radius: 28px;
  }

  .preview-image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid rgba(var(--gray-light), 0.95);
  }

  .preview-image-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 0;
    object-fit: cover;
    object-position: top left;
  }

  .preview-body {
    padding: 1.15rem 1.25rem 1.3rem;
  }

  .preview-body h2 {
    margin: 0 0 0.45rem;
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    letter-spacing: -0.035em;
  }

  .preview-body p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .preview-kicker {
    color: #0f4cff;
    font-size: 0.78rem !important;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 0 0 clamp(2.2rem, 6vw, 4.5rem);
  }

  .proof-card {
    border-radius: 18px;
    padding: 1rem;
  }

  .proof-card strong {
    display: block;
    color: rgb(var(--black));
    font-size: clamp(1.45rem, 3vw, 2rem);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .proof-card span {
    display: block;
    margin-top: 0.45rem;
    color: rgb(var(--gray-dark));
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .home-section {
    margin-block: clamp(2.5rem, 7vw, 5rem);
  }

  .section-heading {
    max-width: 760px;
    margin: 0 auto 1.5rem;
  }

  .centered {
    text-align: center;
  }

  .section-heading h2,
  .feature-copy h2,
  .mission-card h2,
  .home-section-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.35rem);
    letter-spacing: -0.055em;
    line-height: 1.02;
  }

  .section-heading p:not(.eyebrow),
  .feature-copy p,
  .mission-card p {
    margin: 0.9rem 0 0;
    color: rgb(var(--gray-dark));
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .start-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .start-card {
    display: flex;
    min-height: 245px;
    flex-direction: column;
    border-radius: 24px;
    padding: 1.25rem;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .start-card:hover,
  .start-card:focus-visible {
    color: inherit;
    border-color: rgba(15, 76, 255, 0.35);
    box-shadow: 0 20px 42px rgba(15, 18, 25, 0.13);
  }

  .card-eyebrow {
    color: #0f4cff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .start-card h3,
  .system-card h3 {
    margin: 0.65rem 0 0.55rem;
    font-size: clamp(1.3rem, 2vw, 1.65rem);
    letter-spacing: -0.035em;
  }

  .start-card p,
  .system-card p,
  .mini-card span {
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .card-link {
    margin-top: auto;
    padding-top: 1rem;
    color: #0f4cff;
    font-weight: 800;
  }

  .feature-band {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: center;
    border-radius: 30px;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .feature-copy p {
    margin-bottom: 1rem;
  }

  .text-link {
    color: #0f4cff;
    font-weight: 800;
  }

  .feature-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .mini-card {
    display: grid;
    gap: 0.25rem;
    min-height: 145px;
    align-content: start;
    border-radius: 20px;
    padding: 1rem;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .mini-card:hover,
  .mini-card:focus-visible {
    color: inherit;
    border-color: rgba(15, 76, 255, 0.35);
    box-shadow: 0 16px 34px rgba(15, 18, 25, 0.12);
  }

  .mini-icon {
    font-size: 1.55rem !important;
    line-height: 1 !important;
  }

  .mini-card strong {
    color: rgb(var(--black));
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .system-card {
    border-radius: 24px;
    padding: 1.25rem;
  }

  .system-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: #0f4cff;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .home-section-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }

  .home-section-header .eyebrow {
    margin-bottom: 0.35rem;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 2.25rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }

  .mission-card {
    max-width: 900px;
    margin-inline: auto;
    border-radius: 30px;
    padding: clamp(1.25rem, 4vw, 2rem);
    text-align: center;
  }

  .mission-card p {
    max-width: 70ch;
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .hero,
    .feature-band {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      text-align: center;
    }

    .hero-lede,
    .hero-subcopy {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .proof-strip,
    .start-grid,
    .system-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-main {
      width: min(100% - 1rem, 1120px);
      padding-top: 1.25rem;
    }

    .hero {
      gap: 1.2rem;
      margin-top: 0.5rem;
    }

    .hero-title {
      font-size: clamp(2.7rem, 16vw, 4.2rem);
    }

    .hero-lede {
      max-width: 12ch;
      font-size: clamp(1.9rem, 10vw, 2.6rem);
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
      box-sizing: border-box;
    }

    .proof-strip,
    .start-grid,
    .system-grid,
    .feature-cards,
    .post-grid {
      grid-template-columns: 1fr;
    }

    .proof-card,
    .start-card,
    .system-card,
    .mini-card {
      text-align: left;
    }

    .home-section-header {
      align-items: center;
      flex-direction: column;
      text-align: center;
    }
  }
</style>

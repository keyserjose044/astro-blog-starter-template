---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredSlugs = [
  'daily-snapshot',
  'rawdatapost2025',
  '2026interactivegstemplate',
  'original-to-do-list-template',
];

const featuredPosts = featuredSlugs
  .map((slug) => posts.find((post) => post.slug === slug))
  .filter(Boolean);

const daysLogged = Math.max(
  0,
  Math.floor((Date.now() - Date.UTC(2023, 0, 1)) / 86_400_000) + 1,
);

const systemCards = [
  {
    eyebrow: 'Foundation',
    title: 'Raw Data Sheets',
    copy: 'The daily Google Sheets system where sleep, food, work, hobbies, diary notes, places, people, and small life details become searchable data.',
    href: '/blog/rawdatapost2025/',
    cta: 'Open the foundation →',
  },
  {
    eyebrow: 'Output',
    title: 'Daily Snapshot',
    copy: 'A single-page summary that pulls one day together: numbers, diary context, images, quotes, blunders, people, places, and memory.',
    href: '/blog/daily-snapshot/',
    cta: 'See one day →',
  },
  {
    eyebrow: 'Stats',
    title: 'Stats Dashboard',
    copy: 'Live graphs from the archive: guitar practice, audiobook hours, running miles, diary word counts, and more as the system grows.',
    href: '/stats/',
    cta: 'Explore the graphs →',
  },
  {
    eyebrow: 'Try it',
    title: 'Templates',
    copy: 'Downloadable sheets and workflows for people who want to build their own version instead of starting from zero.',
    href: '/templates/',
    cta: 'Use the templates →',
  },
];

const archiveCards = [
  {
    eyebrow: 'Books',
    title: '352 audiobooks logged',
    copy: 'Genres, dates, notes, and listening context from years of turning drives, chores, and walks into reading time.',
    href: '/books/',
    cta: 'Open books →',
  },
  {
    eyebrow: 'Albums',
    title: '568 albums logged',
    copy: 'A listening archive built around full albums, not shuffled fragments, with covers and listening history preserved.',
    href: '/albums/',
    cta: 'Open albums →',
  },
  {
    eyebrow: 'Art',
    title: '765 daily artworks logged',
    copy: 'A visual diary of paintings and images that shaped the archive one daily artwork at a time.',
    href: '/art/',
    cta: 'Open art →',
  },
];

const storyCards = [
  {
    eyebrow: 'About',
    title: 'Who built this?',
    copy: 'The person behind LifeLoggerz and the habits that turned messy routines into repeatable systems.',
    href: '/about/',
    cta: 'Read the about page →',
  },
  {
    eyebrow: 'Timeline',
    title: 'How did it evolve?',
    copy: 'The public timeline of the project, the routines, and the years of work behind the archive.',
    href: '/timeline/',
    cta: 'View the timeline →',
  },
  {
    eyebrow: 'Inspirations',
    title: 'Where did the idea come from?',
    copy: 'Nine sparks behind the project, from life logging and data storytelling to experiments in living.',
    href: '/inspirations/',
    cta: 'See the influences →',
  },
  {
    eyebrow: 'FAQ',
    title: 'Still curious?',
    copy: 'Answers about privacy, what to track first, how long logging takes, and why the system works this way.',
    href: '/faq/',
    cta: 'Read the FAQ →',
  },
];

const proofStats = [
  { value: `${daysLogged.toLocaleString()}+`, label: 'days logged since Jan 2023' },
  { value: '150+', label: 'daily fields across life, work, habits, and media' },
  { value: '10 min', label: 'to log the core day when the system is flowing' },
  { value: '4', label: 'main outputs: sheets, snapshots, graphs, and templates' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="home-main">
      <section class="hero-section" aria-labelledby="hero-title">
        <div class="home-shell hero-inner">
          <p class="eyebrow hero-eyebrow">Life as a living archive</p>
          <h1 id="hero-title">LifeLoggerz</h1>
          <p class="hero-kicker">
            A multi-year public experiment in turning ordinary days into searchable, visual, useful data.
          </p>
          <p class="hero-copy">
            I track daily life through structured sheets, automation, graphs, and essays — then share the system so others can build higher.
          </p>
          <p class="privacy-note">I share the system — not private raw logs.</p>
          <div class="hero-actions" aria-label="Primary homepage actions">
            <a class="button button-primary" href="/stats/">Explore the data</a>
            <a class="button button-secondary" href="/templates/">Use the templates</a>
          </div>
        </div>
      </section>

      <section class="section section-first" aria-labelledby="system-preview-title">
        <div class="home-shell">
          <article class="system-preview-card">
            <div class="preview-media">
              <img
                src="/images_webp/daily_snapshot.webp"
                alt="Daily Snapshot spreadsheet preview from the LifeLoggerz system"
                loading="eager"
                decoding="async"
              />
            </div>
            <div class="preview-copy">
              <p class="eyebrow">System preview</p>
              <h2 id="system-preview-title">Raw data becomes a readable day.</h2>
              <p>
                Sheets are the input. Daily snapshots, graphs, templates, and essays are the output.
              </p>
              <div class="proof-grid" aria-label="LifeLoggerz proof points">
                {proofStats.map((stat) => (
                  <div class="proof-item">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))}
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class="section" aria-labelledby="start-title">
        <div class="home-shell">
          <div class="section-heading">
            <p class="eyebrow">Start here</p>
            <h2 id="start-title">Four doors into the project.</h2>
            <p>
              LifeLoggerz has systems, outputs, graphs, and tools. Pick the door that matches what you came for.
            </p>
          </div>

          <div class="card-grid card-grid-four">
            {systemCards.map((card) => (
              <a class="link-card system-card" href={card.href}>
                <span class="card-eyebrow">{card.eyebrow}</span>
                <h3>{card.title}</h3>
                <p>{card.copy}</p>
                <span class="card-cta">{card.cta}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-muted" aria-labelledby="archive-title">
        <div class="home-shell">
          <div class="section-heading section-heading-split">
            <div>
              <p class="eyebrow">Data, not vibes</p>
              <h2 id="archive-title">Explore the archive.</h2>
            </div>
            <p>
              The project is not only about the tracking system. It also preserves the books, albums, and art that shaped the years being tracked.
            </p>
          </div>

          <div class="card-grid card-grid-three">
            {archiveCards.map((card) => (
              <a class="link-card archive-card" href={card.href}>
                <span class="card-eyebrow">{card.eyebrow}</span>
                <h3>{card.title}</h3>
                <p>{card.copy}</p>
                <span class="card-cta">{card.cta}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="story-title">
        <div class="home-shell">
          <div class="section-heading">
            <p class="eyebrow">Story behind the system</p>
            <h2 id="story-title">The map beyond the data.</h2>
            <p>
              These pages explain the person, timeline, influences, and practical questions behind LifeLoggerz.
            </p>
          </div>

          <div class="card-grid card-grid-four">
            {storyCards.map((card) => (
              <a class="link-card story-card" href={card.href}>
                <span class="card-eyebrow">{card.eyebrow}</span>
                <h3>{card.title}</h3>
                <p>{card.copy}</p>
                <span class="card-cta">{card.cta}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-muted" aria-labelledby="reading-title">
        <div class="home-shell">
          <div class="section-heading section-heading-split">
            <div>
              <p class="eyebrow">Featured reading</p>
              <h2 id="reading-title">Best starting posts.</h2>
            </div>
            <a class="text-link" href="/blog/">See all posts →</a>
          </div>

          {featuredPosts.length > 0 && (
            <div class="featured-list">
              {featuredPosts.map((post) => (
                <a class="featured-post" href={`/blog/${post.slug}/`}>
                  <div>
                    <h3>{post.data.title}</h3>
                    {post.data.description && <p>{post.data.description}</p>}
                  </div>
                  <time datetime={post.data.pubDate.toISOString()}>
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="section why-section" aria-labelledby="why-title">
        <div class="home-shell why-grid">
          <figure class="why-image-card">
            <img
              src="/images/about-lifeloggerz.gif"
              alt="Family gathered while young José draws at the table"
              loading="lazy"
              decoding="async"
            />
            <figcaption>Déjenme terminar esto...</figcaption>
          </figure>

          <div class="why-copy">
            <p class="eyebrow">Why this exists</p>
            <h2 id="why-title">The point is not to optimize every minute.</h2>
            <p>
              The point is to remember life clearly, study habits honestly, and leave a trail that another curious person can build from.
            </p>
            <p>
              Even if one person creates a better system after seeing this, LifeLoggerz has done its job.
            </p>
            <div class="why-actions">
              <a class="button button-primary" href="/about/">Read the about page</a>
              <a class="button button-secondary" href="/faq/">Read the FAQ</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  :root {
    --ll-blue: #1155f5;
    --ll-blue-dark: #0b3fc0;
    --ll-ink: #070b14;
    --ll-text: #293241;
    --ll-muted: #667085;
    --ll-border: rgba(15, 23, 42, 0.12);
    --ll-soft-border: rgba(17, 85, 245, 0.16);
    --ll-card: rgba(255, 255, 255, 0.92);
    --ll-wash: #f4f7ff;
    --ll-radius: 28px;
    --ll-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
  }

  .home-main {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    color: var(--ll-text);
    background:
      radial-gradient(circle at 20% 0%, rgba(17, 85, 245, 0.08), transparent 32rem),
      linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
  }

  .home-shell {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .hero-section {
    position: relative;
    isolation: isolate;
    padding: clamp(2.4rem, 7vw, 5.2rem) 0 clamp(2.2rem, 6vw, 4.8rem);
    text-align: center;
    background: #fff;
    border-bottom: 1px solid var(--ll-border);
  }

  .hero-section::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: '';
    background:
      radial-gradient(ellipse at 14% 20%, transparent 0 24%, rgba(15, 23, 42, 0.10) 24.3% 24.8%, transparent 25.1% 100%),
      radial-gradient(ellipse at 80% 12%, transparent 0 21%, rgba(15, 23, 42, 0.10) 21.3% 21.8%, transparent 22.1% 100%),
      radial-gradient(ellipse at 52% 78%, transparent 0 28%, rgba(15, 23, 42, 0.09) 28.3% 28.8%, transparent 29.1% 100%);
    background-size: 420px 260px, 520px 300px, 620px 360px;
    opacity: 0.72;
  }

  .hero-section::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: '';
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.94));
  }

  .hero-inner {
    max-width: 900px;
  }

  .eyebrow {
    margin: 0 0 0.55rem;
    color: var(--ll-blue);
    font-size: clamp(0.78rem, 1.9vw, 0.95rem);
    font-weight: 900;
    letter-spacing: 0.16em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .hero-eyebrow {
    margin-bottom: 0.4rem;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    margin: 0;
    color: var(--ll-ink);
    font-size: clamp(3.1rem, 11.5vw, 6.5rem);
    font-weight: 950;
    letter-spacing: -0.08em;
    line-height: 0.9;
  }

  h2 {
    margin: 0;
    color: var(--ll-ink);
    font-size: clamp(2rem, 5vw, 3.3rem);
    font-weight: 900;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  h3 {
    margin: 0;
    color: var(--ll-ink);
    font-size: clamp(1.16rem, 2.4vw, 1.45rem);
    font-weight: 850;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .hero-kicker {
    max-width: 760px;
    margin: 1.25rem auto 0;
    color: var(--ll-ink);
    font-size: clamp(1.55rem, 5.6vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1.04;
  }

  .hero-copy {
    max-width: 720px;
    margin: 1.2rem auto 0;
    color: var(--ll-text);
    font-size: clamp(1.05rem, 3.5vw, 1.42rem);
    line-height: 1.55;
  }

  .privacy-note {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 520px;
    min-height: 3.05rem;
    margin: 1.45rem auto 0;
    padding: 0.72rem 1.2rem;
    color: #172033;
    font-size: clamp(0.98rem, 3.4vw, 1.12rem);
    font-weight: 800;
    line-height: 1.25;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--ll-soft-border);
    border-radius: 1.4rem;
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(8px);
  }

  .hero-actions,
  .why-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.4rem;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    padding: 0.76rem 1.2rem;
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.1;
    text-align: center;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover,
  .link-card:hover,
  .featured-post:hover,
  .text-link:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    color: #fff;
    background: var(--ll-blue);
    box-shadow: 0 14px 34px rgba(17, 85, 245, 0.25);
  }

  .button-primary:hover {
    background: var(--ll-blue-dark);
  }

  .button-secondary {
    color: var(--ll-blue);
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(17, 85, 245, 0.22);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
  }

  .section {
    padding: clamp(3rem, 7vw, 5.4rem) 0;
  }

  .section-first {
    padding-top: clamp(1.6rem, 5vw, 3.2rem);
  }

  .section-muted {
    background:
      radial-gradient(circle at 85% 10%, rgba(17, 85, 245, 0.06), transparent 26rem),
      var(--ll-wash);
    border-block: 1px solid rgba(15, 23, 42, 0.06);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: clamp(1.35rem, 4vw, 2.2rem);
  }

  .section-heading p:not(.eyebrow),
  .preview-copy > p,
  .why-copy > p {
    margin: 0.95rem 0 0;
    color: var(--ll-text);
    font-size: clamp(1.02rem, 2.5vw, 1.22rem);
    line-height: 1.6;
  }

  .section-heading-split {
    display: grid;
    max-width: none;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.74fr);
    gap: 1.4rem;
    align-items: end;
  }

  .section-heading-split > p {
    margin: 0;
  }

  .system-preview-card,
  .why-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
    overflow: hidden;
    background: var(--ll-card);
    border: 1px solid var(--ll-border);
    border-radius: var(--ll-radius);
    box-shadow: var(--ll-shadow);
  }

  .preview-media {
    min-height: 100%;
    background: #eef2f8;
  }

  .preview-media img,
  .why-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-copy,
  .why-copy {
    padding: clamp(1.25rem, 4vw, 2.2rem);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 1.25rem;
  }

  .proof-item {
    min-width: 0;
    padding: 0.85rem;
    background: rgba(17, 85, 245, 0.06);
    border: 1px solid rgba(17, 85, 245, 0.12);
    border-radius: 18px;
  }

  .proof-item strong,
  .proof-item span {
    display: block;
  }

  .proof-item strong {
    color: var(--ll-blue);
    font-size: clamp(1.2rem, 4vw, 1.65rem);
    font-weight: 950;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .proof-item span {
    margin-top: 0.35rem;
    color: var(--ll-text);
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .card-grid-four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card-grid-three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .link-card {
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex-direction: column;
    gap: 0.7rem;
    padding: clamp(1rem, 2vw, 1.25rem);
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--ll-border);
    border-radius: 24px;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .link-card:hover {
    border-color: rgba(17, 85, 245, 0.35);
    box-shadow: 0 18px 44px rgba(17, 85, 245, 0.10);
  }

  .card-eyebrow {
    width: fit-content;
    padding: 0.28rem 0.62rem;
    color: var(--ll-blue);
    font-size: 0.73rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    line-height: 1;
    text-transform: uppercase;
    background: rgba(17, 85, 245, 0.08);
    border: 1px solid rgba(17, 85, 245, 0.13);
    border-radius: 999px;
  }

  .link-card p {
    flex: 1;
    margin: 0;
    color: var(--ll-text);
    font-size: 0.98rem;
    line-height: 1.52;
  }

  .card-cta,
  .text-link {
    color: var(--ll-blue);
    font-weight: 900;
    text-decoration: none;
  }

  .card-cta {
    margin-top: 0.25rem;
    font-size: 0.95rem;
  }

  .featured-list {
    display: grid;
    gap: 0.85rem;
  }

  .featured-post {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: clamp(1rem, 2.5vw, 1.25rem);
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid var(--ll-border);
    border-radius: 22px;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .featured-post:hover {
    border-color: rgba(17, 85, 245, 0.3);
    box-shadow: 0 16px 38px rgba(17, 85, 245, 0.08);
  }

  .featured-post h3 {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
  }

  .featured-post p {
    margin: 0.35rem 0 0;
    color: var(--ll-muted);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .featured-post time {
    color: var(--ll-muted);
    font-size: 0.9rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .why-section {
    background: #fff;
  }

  .why-grid {
    align-items: stretch;
  }

  .why-image-card {
    position: relative;
    min-height: 360px;
    margin: 0;
    overflow: hidden;
    background: #eef2f8;
  }

  .why-image-card figcaption {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    left: 1rem;
    padding: 0.72rem 0.9rem;
    color: #fff;
    font-weight: 850;
    line-height: 1.2;
    background: rgba(7, 11, 20, 0.72);
    border-radius: 16px;
    backdrop-filter: blur(8px);
  }

  .why-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .why-actions {
    justify-content: flex-start;
  }

  @media (max-width: 980px) {
    .card-grid-four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .system-preview-card,
    .why-grid {
      grid-template-columns: 1fr;
    }

    .preview-media {
      max-height: 420px;
    }

    .section-heading-split {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      align-items: start;
    }
  }

  @media (max-width: 720px) {
    .home-shell {
      width: min(100% - 24px, 560px);
    }

    .hero-section {
      padding: 1.9rem 0 2rem;
    }

    .hero-inner {
      max-width: 100%;
    }

    .hero-kicker {
      margin-top: 1rem;
      line-height: 1.06;
    }

    .hero-copy {
      margin-top: 1rem;
      line-height: 1.52;
    }


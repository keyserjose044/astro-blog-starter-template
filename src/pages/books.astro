---
// src/pages/books.astro
// Revision: responsive Quilt/List toggle, publication period filter, and Age sorting — July 12, 2026
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoBg from '../components/VideoBg.astro';
import { SITE_TITLE } from '../consts';
import { fetchAllRaindrops } from '../utils/raindrop';

const RAINDROP_TOKEN = import.meta.env.RAINDROP_TOKEN;
const COLLECTION_ID = import.meta.env.RAINDROP_COLLECTION_BOOKS_ID || '54514877';

const books = await fetchAllRaindrops({
  token: RAINDROP_TOKEN,
  collectionId: COLLECTION_ID,
  label: 'books',
  placeholder: '/images_webp/books-placeholder.webp',
});

const getBookMeta = (note?: string | null) => {
  const parts = String(note || '')
    .split('·')
    .map((part) => part.trim());

  return {
    dateFinished: parts[0] || '',
    author: parts[2] || '',
    yearPublished: parts[3] || '',
    genre: parts[4] || '',
    length: parts[9] || '',
  };
};

const getFinishedYear = (dateFinished?: string | null) => {
  const raw = String(dateFinished || '').trim();

  // Raindrop completion dates are commonly stored as M/D/YY, such as 5/26/26.
  const numericDate = raw.match(/\b\d{1,2}[\/-]\d{1,2}[\/-](\d{2}|\d{4})\b/);
  if (numericDate) {
    const year = numericDate[1];
    return year.length === 2 ? String(2000 + Number(year)) : year;
  }

  // Also support notes that already contain a four-digit year in another date format.
  return raw.match(/\b(?:19|20)\d{2}\b/)?.[0] || '';
};

const getOrdinal = (value: number) => {
  const mod100 = value % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${value}th`;

  const mod10 = value % 10;
  if (mod10 === 1) return `${value}st`;
  if (mod10 === 2) return `${value}nd`;
  if (mod10 === 3) return `${value}rd`;
  return `${value}th`;
};

const getPublicationYear = (yearPublished?: string | null): number | null => {
  const raw = String(yearPublished || '').trim();
  const normalized = raw.toLowerCase().replace(/,/g, '');

  if (!normalized) return null;

  // Also support values written as 600 BC / BCE before parsing unsigned numbers.
  const bceMatch = normalized.match(/\b(\d{1,4})\s*(?:bc|bce)\b/);
  if (bceMatch) return -Number(bceMatch[1]);

  // AD / CE years remain positive.
  const ceMatch = normalized.match(/\b(\d{1,4})\s*(?:ad|ce)\b/);
  if (ceMatch) return Number(ceMatch[1]);

  // Raindrop stores BCE years as negative numbers, such as -600 or -1700.
  const signedYearMatch = normalized.match(/(?:^|\s)(-?\d{1,4})(?=\s|$|\b)/);
  if (signedYearMatch) {
    const year = Number(signedYearMatch[1]);
    return Number.isFinite(year) ? year : null;
  }

  return null;
};

const getPublicationPeriod = (yearPublished?: string | null) => {
  const raw = String(yearPublished || '').trim();
  const normalized = raw.toLowerCase().replace(/,/g, '');

  if (!normalized) {
    return { key: 'unknown', label: 'Unknown date', order: 400 };
  }

  const isBce = /\b(?:bc|bce)\b/.test(normalized);
  const centuryMatch = normalized.match(/\b(\d{1,2})(?:st|nd|rd|th)\s+century\b/);

  if (centuryMatch) {
    const century = Number(centuryMatch[1]);

    if (isBce || century <= 5) {
      return { key: 'ancient', label: 'Ancient (before 500)', order: 300 };
    }

    if (century <= 14) {
      return { key: 'medieval', label: 'Medieval (500–1400)', order: 200 };
    }

    return {
      key: `century-${century}`,
      label: `${getOrdinal(century)} century`,
      order: 100 - century,
    };
  }

  const year = getPublicationYear(yearPublished);
  if (year === null) {
    return { key: 'unknown', label: 'Unknown date', order: 400 };
  }

  // Any negative year is BCE and therefore Ancient.
  if (year < 500) {
    return { key: 'ancient', label: 'Ancient (before 500)', order: 300 };
  }

  if (year <= 1400) {
    return { key: 'medieval', label: 'Medieval (500–1400)', order: 200 };
  }

  const century = Math.ceil(year / 100);

  return {
    key: `century-${century}`,
    label: `${getOrdinal(century)} century`,
    order: 100 - century,
  };
};
---

<BaseHead
  title={`${SITE_TITLE} — books`}
  description="books gallery powered by Raindrop, auto-updated from my collection."
/>

<style>
  :root{--gap:22px;--ink:#0e121b;--muted:#5e6573;--border:#e6e9ef;--surface:#fff}
  *{box-sizing:border-box}
  .wrap{margin:0 auto;padding-block:28px 48px;padding-inline:clamp(16px,3vw,48px);max-width:100%}
  .wrap--wide{width:100dvw;margin-left:calc(50% - 50dvw);margin-right:calc(50% - 50dvw);padding-inline:0}
  .intro{max-width:920px;margin:0 auto 24px;text-align:center;padding-inline:clamp(16px,3vw,48px)}
  h1{margin:0 0 12px;font-weight:800;letter-spacing:-.02em;display:flex;gap:.6rem;align-items:center;justify-content:center}
  .hint{color:var(--muted);margin:6px 0 20px}
  .toolbar{display:flex;align-items:center;justify-content:center;gap:8px;margin:6px 0 14px;flex-wrap:wrap}
  .toolbar input[type="search"]{flex:1 1 220px;width:100%;max-width:260px;margin-inline:0;padding:12px 14px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.95rem;box-shadow:0 1px 2px rgba(0,0,0,.03);}
  .toolbar select{flex:0 1 135px;min-width:120px;padding:10px 12px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.9rem;box-shadow:0 1px 2px rgba(0,0,0,.03);}
  .toolbar #genre-filter{flex-basis:145px}
  .toolbar #year-filter{flex-basis:96px;min-width:92px}
  .toolbar #period-filter{flex-basis:135px}
  .toolbar #sort-books{flex-basis:140px}

  .info-toggle{
    width:40px;height:40px;border-radius:999px;border:1px solid #838796;background:#a8adbd;
    display:inline-flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;
    box-shadow:0 1px 2px rgba(0,0,0,.04);
    transition:background .15s ease, box-shadow .15s ease, transform .08s ease, border-color .15s ease, color .15s ease;
  }
  .info-toggle span{position:relative;top:-1px;font-weight:600}
  .info-toggle:hover{background:#f0f2ff;box-shadow:0 4px 10px rgba(0,0,0,.08);transform:translateY(-1px)}
  .info-toggle[aria-pressed="true"]{background:#405cf5;color:#fff;border-color:#405cf5}
  .info-panel{
    max-width:920px;margin:0 auto 24px;padding:16px 18px 14px;border-radius:14px;
    background:rgba(255,255,255,.9);border:1px solid var(--border);
    box-shadow:0 10px 24px rgba(15,23,42,.04);font-size:.94rem;line-height:1.5;
    color:var(--muted);text-align:left;display:none;
  }
  .info-panel--visible{display:block}
  .info-panel h2{font-size:1.02rem;margin:0 0 .4rem;font-weight:700;color:var(--ink)}
  .info-panel p{margin:.35rem 0}
  .info-panel a{color:#314bd8;font-weight:700;text-underline-offset:2px}
  .grid{display:grid;gap:var(--gap);align-items:start;max-width:100%}
  .grid[data-book-view="quilt"]{grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}
  @media (min-width:1800px){.grid[data-book-view="quilt"]{grid-template-columns:repeat(auto-fit,minmax(150px,1fr))}}
  .fullbleed{width:100%;margin:0;padding-inline:clamp(16px,3vw,48px)}
  .card{position:relative;display:flex;flex-direction:column;gap:8px;text-decoration:none;color:inherit;border-radius:12px}
  .thumb{
    width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:12px;
    box-shadow:0 10px 24px rgba(0,0,0,.12);background:#f0f2f7;border:1px solid var(--border);
  }
  .title{font-weight:700;font-size:.98rem;line-height:1.3}
  .external-link-cue{display:inline-block;margin-left:.2em;color:var(--muted);font-size:.8em;font-weight:700;vertical-align:.08em}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .card:focus-visible{outline:2px solid #405cf5;outline-offset:4px;border-radius:12px}
  .note-bubble{
    position:absolute;left:50%;top:-10px;transform:translate(calc(-50% + var(--shift,0px)),-100%);
    width:max-content;max-width:min(600px,90vw);white-space:normal;background:rgba(20,23,31,.96);
    color:#fff;font-size:.9rem;line-height:1.35;padding:10px 12px;border-radius:10px;
    box-shadow:0 10px 24px rgba(0,0,0,.25);z-index:10;pointer-events:none;opacity:0;
    visibility:hidden;transition:opacity .15s ease,visibility .15s ease;
    text-align:left;text-wrap:pretty;hyphens:auto;word-break:break-word;
  }
  .note-bubble::after{
    content:"";position:absolute;left:50%;top:100%;transform:translateX(-50%);
    border:8px solid transparent;border-top-color:rgba(20,23,31,.96);
  }
  .card:hover .note-bubble,
  .card:focus-within .note-bubble,
  .card.show-note .note-bubble{opacity:1;visibility:visible}
  @media (max-width:700px){
    .note-bubble{
      top:auto;bottom:-10px;transform:translate(calc(-50% + var(--shift,0px)),100%);
    }
    .note-bubble::after{
      top:auto;bottom:100%;border-top-color:transparent;border-bottom-color:rgba(20,23,31,.96);
    }
  }
  .empty{text-align:center;color:var(--muted);padding:40px 0 24px}

  .card-meta{display:none}

  .view-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    margin: 0 auto 18px;
    padding: 3px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 6px 16px rgba(15,23,42,.06);
  }

  .view-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 36px;
    padding: 7px 12px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
  }

  .view-button[aria-pressed="true"] {
    background: #405cf5;
    color: #fff;
    box-shadow: 0 5px 12px rgba(64,92,245,.22);
  }

  .view-button:focus-visible {
    outline: 2px solid #405cf5;
    outline-offset: 2px;
  }

  /* Desktop List view becomes a responsive grid of equal-height detail cards. */
  @media (min-width: 901px) {
    .grid[data-book-view="list"] {
      width: 100%;
      max-width: 1700px;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      grid-auto-rows: 176px;
      gap: 16px;
      margin-inline: auto;
    }

    .grid[data-book-view="list"] .card {
      display: grid;
      width: 100%;
      height: 100%;
      min-width: 0;
      grid-template-columns: 104px minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      gap: 7px 14px;
      align-items: start;
      overflow: hidden;
      padding: 10px;
      border: 1px solid rgba(230,233,239,.95);
      border-radius: 14px;
      background: rgba(255,255,255,.9);
      box-shadow: 0 8px 20px rgba(15,23,42,.07);
      transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }

    .grid[data-book-view="list"] .card:hover {
      transform: translateY(-2px);
      border-color: rgba(64,92,245,.28);
      box-shadow: 0 12px 28px rgba(15,23,42,.11);
    }

    .grid[data-book-view="list"] .thumb {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 104px;
      height: 156px;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      border-radius: 9px;
      box-shadow: 0 6px 15px rgba(0,0,0,.13);
    }

    .grid[data-book-view="list"] .title {
      grid-column: 2;
      grid-row: 1;
      display: -webkit-box;
      min-height: 2.6em;
      overflow: hidden;
      margin-top: 2px;
      font-size: 1rem;
      line-height: 1.3;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .grid[data-book-view="list"] .card-meta {
      display: flex;
      grid-column: 2;
      grid-row: 2;
      flex-direction: column;
      gap: 5px;
      min-width: 0;
      color: var(--muted);
      font-size: .82rem;
      line-height: 1.35;
    }

    .grid[data-book-view="list"] .card-meta span {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .grid[data-book-view="list"] .note-bubble {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .wrap {
      padding-block: 18px 36px;
    }

    .intro {
      margin-bottom: 14px;
      padding-inline: 12px;
    }

    h1 {
      margin-bottom: 6px;
      font-size: 2rem;
    }

    .hint {
      max-width: 36ch;
      margin: 4px auto 12px;
      font-size: 0.86rem;
      line-height: 1.42;
    }

    .toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 40px 40px;
      gap: 7px;
      margin-bottom: 10px;
    }

    .toolbar input[type="search"] {
      grid-column: 1 / -1;
      max-width: none;
      padding: 10px 12px;
      font-size: 0.88rem;
    }

    .toolbar select {
      width: 100%;
      min-width: 0;
      padding: 9px 8px;
      font-size: 0.8rem;
    }

    #genre-filter {
      grid-column: 1;
      grid-row: 2;
    }

    #year-filter {
      grid-column: 2;
      grid-row: 2;
    }

    #period-filter {
      grid-column: 1;
      grid-row: 3;
    }

    #sort-books {
      grid-column: 2;
      grid-row: 3;
    }

    #info-toggle {
      grid-column: 3;
      grid-row: 3;
    }

    .toolbar > a.info-toggle {
      grid-column: 4;
      grid-row: 3;
    }

    .view-toggle {
      margin-bottom: 14px;
    }

    .fullbleed {
      padding-inline: 10px;
    }

    /* Quilt remains available as the visual browsing option. */
    .grid[data-book-view="quilt"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px 10px;
    }

    .grid[data-book-view="quilt"] .card {
      min-width: 0;
      gap: 5px;
    }

    .grid[data-book-view="quilt"] .thumb {
      aspect-ratio: 2 / 3;
      border-radius: 9px;
      box-shadow: 0 6px 14px rgba(0,0,0,.12);
    }

    .grid[data-book-view="quilt"] .title {
      display: -webkit-box;
      overflow: hidden;
      font-size: 0.78rem;
      line-height: 1.24;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    /* List keeps one book per row without making each cover enormous. */
    .grid[data-book-view="list"] {
      width: 100%;
      max-width: 680px;
      grid-template-columns: minmax(0, 1fr);
      grid-auto-rows: 158px;
      gap: 10px;
      margin-inline: auto;
    }

    .grid[data-book-view="list"] .card {
      display: grid;
      width: 100%;
      max-width: none;
      height: 100%;
      min-width: 0;
      min-height: 0;
      grid-template-columns: 88px minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      gap: 6px 12px;
      align-items: start;
      justify-self: stretch;
      align-self: stretch;
      overflow: hidden;
      padding: 10px;
      border: 1px solid rgba(230,233,239,.95);
      border-radius: 14px;
      background: rgba(255,255,255,.9);
      box-shadow: 0 7px 18px rgba(15,23,42,.06);
    }

    .grid[data-book-view="list"] .thumb {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 88px;
      height: 132px;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 5px 12px rgba(0,0,0,.12);
    }

    .grid[data-book-view="list"] .title {
      grid-column: 2;
      grid-row: 1;
      display: -webkit-box;
      min-height: 2.35em;
      overflow: hidden;
      margin-top: 1px;
      font-size: 0.94rem;
      line-height: 1.25;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .grid[data-book-view="list"] .card-meta {
      display: flex;
      grid-column: 2;
      grid-row: 2;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
      color: var(--muted);
      font-size: 0.76rem;
      line-height: 1.3;
    }

    .grid[data-book-view="list"] .card-meta span {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Metadata is already visible in list view, so no floating tooltip is needed. */
    .grid[data-book-view="list"] .note-bubble {
      display: none;
    }

    .note-bubble {
      max-width: min(310px, 88vw);
      padding: 8px 10px;
      font-size: 0.78rem;
      line-height: 1.32;
    }

    .info-panel {
      margin-bottom: 16px;
      padding: 13px;
      font-size: 0.84rem;
    }
  }

  @media (min-width: 560px) and (max-width: 900px) {
    .grid[data-book-view="quilt"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px 12px;
    }

    .grid[data-book-view="quilt"] .title {
      font-size: 0.84rem;
    }
  }
</style>

<VideoBg>
  <Header />
  <main class="wrap wrap--wide">
    <div class="intro" role="region" aria-label="books header">
      <h1>📚 Books</h1>
      <p class="hint">
        {(books.length).toLocaleString('en-US')} audiobooks since February 9, 2023—mostly while
        driving, running, washing, or doing other routine tasks.
      </p>

      <div class="toolbar">
        <input id="q" type="search" placeholder="Search title or note…" aria-label="Filter books" />
        <select id="genre-filter" aria-label="Filter by genre">
          <option value="">All genres</option>
          <!-- Options will be filled in by JS -->
        </select>
        <select id="year-filter" aria-label="Filter by year finished">
          <option value="">All years</option>
          <!-- Current and future years are generated automatically by JS. -->
        </select>
        <select id="period-filter" aria-label="Filter by publication period">
          <option value="">All periods</option>
          <!-- Period options are generated from the publication metadata. -->
        </select>
        <select id="sort-books" aria-label="Sort books">
          <option value="date-desc">Newest finished</option>
          <option value="date-asc">Oldest finished</option>
          <option value="title-asc">Title A–Z</option>
          <option value="author-asc">Author A–Z</option>
          <option value="publication-desc">Age (newest first)</option>
          <option value="length-desc">Longest</option>
          <option value="length-asc">Shortest</option>
        </select>
        <button
          type="button"
          id="info-toggle"
          class="info-toggle"
          aria-label="About my reading"
          aria-expanded="false"
          aria-pressed="false"
        >
          <span>?</span>
        </button>
        
        <a
          href="/stats/?metric=audiobooks&year=current#graphs"
          class="info-toggle"
          aria-label="View reading stats"
          title="View reading stats"
        >
          📊
        </a>
      </div>

      {books.length > 0 ? (
        <div
          id="book-view-toggle"
          class="view-toggle"
          role="group"
          aria-label="Choose book layout"
        >
          <button
            type="button"
            class="view-button"
            data-book-view="list"
            aria-pressed="true"
          >
            <span aria-hidden="true">▤</span>
            <span>List</span>
          </button>
          <button
            type="button"
            class="view-button"
            data-book-view="quilt"
            aria-pressed="false"
          >
            <span aria-hidden="true">▦</span>
            <span>Quilt</span>
          </button>
        </div>
      ) : null}

      <section id="reading-info" class="info-panel" hidden>
        <h2>Why I Listen to Audiobooks</h2>
        <p>
          I don’t watch TV, movies, videos, or scroll social media. Audiobooks are how I get my
          mental stimulation while I drive, wash, run, or do any repetitive task. They turn
          otherwise empty hours into something meaningful.
        </p>

        <h2>What I Read</h2>
        <p>
          I almost never follow a strict plan. Over the past few years I’ve wandered through
          classics, philosophy, history, psychology, fantasy, religion, and anything that sparks
          curiosity in the moment. My favorite genres are simply the ones with the most entries.
        </p>

        <h2>The Numbers</h2>
        <p>
          Since <strong>February 9, 2023</strong>, I’ve listened to
          <strong>{books.length.toLocaleString('en-US')} audiobooks</strong> and logged more than
          <strong>2,000 hours</strong> of listening, weaving books into otherwise ordinary parts
          of everyday life.
        </p>

        <h2>Notes</h2>
        <p>In Quilt view on desktop, hover over any book cover to see this complete structure:</p>

        <p>
          <strong>
            Date Finished · Title · Author · Year Published · Genre · Subgenre · Form · Language ·
            Country · Length
          </strong>
        </p>

        <p>
          In Quilt view on a phone, tap once to see these details and tap again to open Goodreads.
          In List view on any screen, the key details are already visible and one click or tap opens the book.
        </p>

        <p>
          <a href="/stats/?metric=audiobooks&amp;year=current#graphs">View my audiobook statistics</a>
          for listening hours, yearly totals, records, and trends powered by my Google Sheets logs.
        </p>
      </section>
    </div>

    {books.length === 0 ? (
      <div class="empty">No books found in this collection.</div>
    ) : (
      <>
        <p id="filter-empty" class="empty" aria-live="polite" hidden>
          No books match these filters.
        </p>
        <div class="grid fullbleed" id="grid" role="list" data-book-view="list">
        {books.map((a, index) => {
          const meta = getBookMeta(a.note);
          const finishedYear = getFinishedYear(meta.dateFinished);
          const publicationYear = getPublicationYear(meta.yearPublished);
          const publicationPeriod = getPublicationPeriod(meta.yearPublished);

          return (
            <a
              class="card"
              role="listitem"
              href={a.href}
              target="_blank"
              rel="noopener noreferrer"
              title={`${a.title} — opens in a new tab`}
              data-title={a.title.toLowerCase()}
              data-author={meta.author.toLowerCase()}
              data-date-finished={meta.dateFinished}
              data-finished-year={finishedYear}
              data-publication-year={publicationYear ?? ''}
              data-publication-period={publicationPeriod.key}
              data-publication-period-label={publicationPeriod.label}
              data-publication-period-order={publicationPeriod.order}
              data-length={meta.length}
              data-original-index={index}
              data-note={(a.note || '').toLowerCase()}
              data-note-raw={a.note || ''}
            >
              <img
                class="thumb"
                src={a.cover}
                alt={a.title}
                loading="lazy"
                decoding="async"
                sizes="(max-width: 559px) 46vw, (max-width: 900px) 31vw, (min-width: 1800px) 300px, 25vw"
              />
              <div class="title">
                {a.title}<span class="external-link-cue" aria-hidden="true">↗</span>
                <span class="sr-only"> (opens in a new tab)</span>
              </div>
              <div class="card-meta">
                {meta.author ? <span><strong>{meta.author}</strong></span> : null}
                {meta.genre ? <span>{meta.genre}{meta.yearPublished ? ` · ${meta.yearPublished}` : ''}</span> : null}
                {meta.dateFinished ? <span>Finished {meta.dateFinished}{meta.length ? ` · ${meta.length}` : ''}</span> : null}
              </div>
              {a.note ? <div class="note-bubble" role="tooltip">{a.note}</div> : null}
            </a>
          );
        })}
        </div>
      </>
    )}
  </main>
  <Footer />
</VideoBg>

<script>
  (function(){
    const $ = (sel,root=document)=>root.querySelector(sel);
    const $$ = (sel,root=document)=>Array.from(root.querySelectorAll(sel));
    const debounce = (fn,ms)=>{let t;return (...a)=>{clearTimeout(t);t=setTimeout(()=>fn(...a),ms);};};
    const norm = s => (s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');

    const grid = $('#grid'),
          input = $('#q'),
          genreSelect = $('#genre-filter'),
          yearSelect = $('#year-filter'),
          periodSelect = $('#period-filter'),
          sortSelect = $('#sort-books'),
          filterEmpty = $('#filter-empty');

    if (!grid || !input) return;

    const cards = $$('.card', grid);

    // Quilt/List layout switcher with separate defaults and saved choices by screen size.
    const MOBILE_VIEW_QUERY = window.matchMedia('(max-width: 900px)');
    const VIEW_STORAGE_KEYS = {
      mobile: 'lifeloggerz-books-mobile-view',
      desktop: 'lifeloggerz-books-desktop-view',
    };
    const viewButtons = $$('[data-book-view]');

    function viewMode(){
      return MOBILE_VIEW_QUERY.matches ? 'mobile' : 'desktop';
    }

    function defaultView(){
      return viewMode() === 'mobile' ? 'list' : 'quilt';
    }

    function setBookView(view, persist = true){
      const nextView = view === 'list' ? 'list' : 'quilt';
      grid.dataset.bookView = nextView;

      viewButtons.forEach(button => {
        const isActive = button.dataset.bookView === nextView;
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      cards.forEach(card => card.classList.remove('show-note'));

      if (persist){
        try {
          localStorage.setItem(VIEW_STORAGE_KEYS[viewMode()], nextView);
        } catch (_err) {
          // The chosen view still works for this visit when storage is unavailable.
        }
      }
    }

    function restoreViewForCurrentScreen(){
      let savedView = defaultView();
      try {
        savedView = localStorage.getItem(VIEW_STORAGE_KEYS[viewMode()]) || defaultView();
      } catch (_err) {
        savedView = defaultView();
      }
      setBookView(savedView, false);
    }

    restoreViewForCurrentScreen();

    viewButtons.forEach(button => {
      button.addEventListener('click', () => {
        setBookView(button.dataset.bookView);
      });
    });

    if (typeof MOBILE_VIEW_QUERY.addEventListener === 'function') {
      MOBILE_VIEW_QUERY.addEventListener('change', restoreViewForCurrentScreen);
    } else {
      MOBILE_VIEW_QUERY.addListener(restoreViewForCurrentScreen);
    }

    // Build search haystack (already there)
    const haystack = new Map(
      cards.map(c => [c, norm((c.dataset.title||'')+' '+(c.dataset.note||''))])
    );

    // 🔹 Canonical genre list (order is important)
    const CANONICAL_GENRES = [
      'Psychological Fiction',
      'Science Fiction',
      'Satire/Comedy',
      'Gothic Fiction',
      'Adventure',
      'Political/Philosophical',
      'Crime/Mystery',
      'Self-Help',
      'Romantic Fiction',
      "Children's Literature",
      'Poetry',
      'Coming of Age',
      'Biography',
      'Fantasy',
      'War Fiction',
      'Nonfiction',
      'History',
    ];
  
    // 🔹 Handle messy / alternate labels from Raindrop
    const GENRE_ALIAS_MAP = {};
    GENRE_ALIAS_MAP[norm('Coming-of-Age')] = 'Coming of Age';
    GENRE_ALIAS_MAP[norm('Coming-of Age')] = 'Coming of Age';
    GENRE_ALIAS_MAP[norm('Self-Help & Nonfiction')] = 'Self-Help';
    GENRE_ALIAS_MAP[norm('Self-Help and Nonfiction')] = 'Self-Help';
    GENRE_ALIAS_MAP[norm('Satire')] = 'Satire/Comedy';
    GENRE_ALIAS_MAP[norm('Comedy')] = 'Satire/Comedy';
    GENRE_ALIAS_MAP[norm('Politics/Philosophy')] = 'Political/Philosophical';
    GENRE_ALIAS_MAP[norm('Politics & Philosophy')] = 'Political/Philosophical';
    GENRE_ALIAS_MAP[norm("Children’s Literature")] = "Children's Literature";
  
    const genresInUse = new Set();
  
    // 🔹 Extract genres from note structure and attach to each card
    // note format:
    // Date · Title · Author · Year · Genre · Subgenre · Form · Language · Country · Length
    cards.forEach(c => {
      const raw = c.dataset.noteRaw || '';
      const parts = raw.split('·').map(s => s.trim());
      if (parts.length < 5) return;
  
      const rawGenre = parts[4];
      const rawNorm = norm(rawGenre);
  
      // Try exact canonical match first
      let canonical = CANONICAL_GENRES.find(g => norm(g) === rawNorm);
  
      // Fall back to alias map
      if (!canonical && GENRE_ALIAS_MAP[rawNorm]) {
        canonical = GENRE_ALIAS_MAP[rawNorm];
      }
  
      if (!canonical) return; // ignore weird/temporary genres
  
      const genreKey = norm(canonical);
      c.dataset.genre = canonical;
      c.dataset.genreKey = genreKey;
      genresInUse.add(canonical);
    });
  
    // 🔹 Populate the dropdown using canonical order, but only for genres actually present
    if (genreSelect) {
      const genres = CANONICAL_GENRES.filter(g => genresInUse.has(g));
      genres.forEach(g => {
        const opt = document.createElement('option');
        opt.value = g;
        opt.textContent = g;
        genreSelect.appendChild(opt);
      });
    }


    // Generate completion-year options from the tracking start year through the visitor's current year.
    // On January 1, a new year appears automatically without a code change or rebuild.
    if (yearSelect) {
      const TRACKING_START_YEAR = 2023;
      const currentYear = Math.max(new Date().getFullYear(), TRACKING_START_YEAR);

      for (let year = currentYear; year >= TRACKING_START_YEAR; year -= 1) {
        const opt = document.createElement('option');
        opt.value = String(year);
        opt.textContent = String(year);
        yearSelect.appendChild(opt);
      }
    }

    // Populate only publication periods represented in the current Raindrop collection.
    // This avoids dead filter options while still supporting ancient, medieval, and future centuries.
    if (periodSelect) {
      const periodsInUse = new Map();

      cards.forEach(card => {
        const key = card.dataset.publicationPeriod || 'unknown';
        const label = card.dataset.publicationPeriodLabel || 'Unknown date';
        const order = Number(card.dataset.publicationPeriodOrder || 400);

        if (!periodsInUse.has(key)) {
          periodsInUse.set(key, { key, label, order });
        }
      });

      [...periodsInUse.values()]
        .sort((a, b) => a.order - b.order || a.label.localeCompare(b.label))
        .forEach(period => {
          const opt = document.createElement('option');
          opt.value = period.key;
          opt.textContent = period.label;
          periodSelect.appendChild(opt);
        });
    }

    const collator = new Intl.Collator(undefined, { sensitivity: 'base', numeric: true });

    function parseFinishedDate(value){
      const cleaned = String(value || '')
        .replace(/(\d)(st|nd|rd|th)\b/gi, '$1')
        .trim();

      // Parse Raindrop's M/D/YY and M/D/YYYY formats explicitly.
      const numericDate = cleaned.match(/^\s*(\d{1,2})[\/-](\d{1,2})[\/-](\d{2}|\d{4})\s*$/);
      if (numericDate){
        const month = Number(numericDate[1]);
        const day = Number(numericDate[2]);
        const rawYear = numericDate[3];
        const year = rawYear.length === 2 ? 2000 + Number(rawYear) : Number(rawYear);
        const timestamp = Date.UTC(year, month - 1, day);
        return Number.isNaN(timestamp) ? null : timestamp;
      }

      const timestamp = Date.parse(cleaned);
      return Number.isNaN(timestamp) ? null : timestamp;
    }

    function parseLengthMinutes(value){
      const raw = String(value || '').toLowerCase().trim();
      if (!raw) return null;

      const colonMatch = raw.match(/^(\d+):(\d{1,2})(?::(\d{1,2}))?$/);
      if (colonMatch){
        const first = Number(colonMatch[1]);
        const second = Number(colonMatch[2]);
        const third = colonMatch[3] ? Number(colonMatch[3]) : null;
        return third === null ? first * 60 + second : first * 60 + second + third / 60;
      }

      const hoursMatch = raw.match(/([\d.]+)\s*(?:h|hr|hrs|hour|hours)\b/);
      const minutesMatch = raw.match(/([\d.]+)\s*(?:m|min|mins|minute|minutes)\b/);
      if (hoursMatch || minutesMatch){
        return (hoursMatch ? Number(hoursMatch[1]) * 60 : 0) +
          (minutesMatch ? Number(minutesMatch[1]) : 0);
      }

      const numeric = Number.parseFloat(raw.replace(/[^\d.]/g, ''));
      return Number.isFinite(numeric) ? numeric * 60 : null;
    }

    function compareNullableNumbers(a, b, direction){
      const aMissing = a === null;
      const bMissing = b === null;
      if (aMissing && bMissing) return 0;
      if (aMissing) return 1;
      if (bMissing) return -1;
      return direction === 'asc' ? a - b : b - a;
    }

    function sortBooks(){
      const mode = sortSelect ? sortSelect.value : 'date-desc';
      const orderedCards = [...cards].sort((a, b) => {
        let comparison = 0;

        if (mode === 'date-desc' || mode === 'date-asc'){
          comparison = compareNullableNumbers(
            parseFinishedDate(a.dataset.dateFinished),
            parseFinishedDate(b.dataset.dateFinished),
            mode === 'date-asc' ? 'asc' : 'desc'
          );
        } else if (mode === 'title-asc'){
          comparison = collator.compare(a.dataset.title || '', b.dataset.title || '');
        } else if (mode === 'author-asc'){
          comparison = collator.compare(a.dataset.author || '', b.dataset.author || '');
        } else if (mode === 'publication-desc'){
          const aYear = a.dataset.publicationYear === '' ? null : Number(a.dataset.publicationYear);
          const bYear = b.dataset.publicationYear === '' ? null : Number(b.dataset.publicationYear);
          comparison = compareNullableNumbers(
            Number.isFinite(aYear) ? aYear : null,
            Number.isFinite(bYear) ? bYear : null,
            'desc'
          );
        } else if (mode === 'length-desc' || mode === 'length-asc'){
          comparison = compareNullableNumbers(
            parseLengthMinutes(a.dataset.length),
            parseLengthMinutes(b.dataset.length),
            mode === 'length-asc' ? 'asc' : 'desc'
          );
        }

        if (comparison !== 0) return comparison;
        return Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0);
      });

      orderedCards.forEach(card => grid.appendChild(card));
    }

    function filter(){
      const s = norm(input.value.trim());
      const words = s ? s.split(/\s+/) : [];
      const selectedGenre = genreSelect ? genreSelect.value : '';
      const selectedKey = norm(selectedGenre);
      const selectedYear = yearSelect ? yearSelect.value : '';
      const selectedPeriod = periodSelect ? periodSelect.value : '';
      let visibleCount = 0;

      cards.forEach(c => {
        const textMatches = !words.length || words.every(w => haystack.get(c).includes(w));
        const genreMatches =
          !selectedGenre || (c.dataset.genreKey && c.dataset.genreKey === selectedKey);
        const yearMatches = !selectedYear || c.dataset.finishedYear === selectedYear;
        const periodMatches =
          !selectedPeriod || c.dataset.publicationPeriod === selectedPeriod;
        const isVisible = textMatches && genreMatches && yearMatches && periodMatches;
        c.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount += 1;
      });

      if (filterEmpty) filterEmpty.hidden = visibleCount !== 0;
    }

    input.addEventListener('input', debounce(filter, 80));
    if (genreSelect) genreSelect.addEventListener('change', filter);
    if (yearSelect) yearSelect.addEventListener('change', filter);
    if (periodSelect) periodSelect.addEventListener('change', filter);
    if (sortSelect) sortSelect.addEventListener('change', sortBooks);

    // Keyboard shortcuts (unchanged)
    window.addEventListener('keydown', e=>{
      if (e.key==='Escape'){
        input.value='';
        if (genreSelect) genreSelect.value = '';
        if (yearSelect) yearSelect.value = '';
        if (periodSelect) periodSelect.value = '';
        if (sortSelect) sortSelect.value = 'date-desc';
        sortBooks();
        filter();
        input.focus();
      } else if (e.key==='/' && e.target===document.body){
        e.preventDefault(); input.focus();
      }
    });

    sortBooks();
    filter();

    // Tooltip positioning (unchanged)
    function adjust(bubble){
      if (!bubble) return;
      bubble.style.setProperty('--shift','0px');
      const r = bubble.getBoundingClientRect(), m = 8;
      let shift = 0;
      if (r.left < m) shift = m - r.left;
      else if (r.right > innerWidth - m) shift = (innerWidth - m) - r.right;
      if (shift) bubble.style.setProperty('--shift', `${shift}px`);
    }

    grid.addEventListener('mouseenter', e=>{
      const b = e.target.closest('.card')?.querySelector('.note-bubble'); if (!b) return;
      requestAnimationFrame(()=>adjust(b));
    }, true);

    grid.addEventListener('focusin', e=>{
      const b = e.target.closest('.card')?.querySelector('.note-bubble'); if (!b) return;
      requestAnimationFrame(()=>adjust(b));
    });

    addEventListener('resize', ()=> $$('.note-bubble').forEach(adjust));

    // Mobile click-to-show tooltip (unchanged)
    document.addEventListener('click', e=>{
      const card = e.target.closest('.card');
      if (!card){
        cards.forEach(c=>c.classList.remove('show-note'));
        return;
      }
      if (!card.querySelector('.note-bubble')) return;

      const isMobileQuiltView =
        MOBILE_VIEW_QUERY.matches && grid.dataset.bookView === 'quilt';

      if (!isMobileQuiltView) return;
      if (card.classList.contains('show-note')) return;
      e.preventDefault();
      cards.forEach(c=>c.classList.remove('show-note'));
      card.classList.add('show-note');
      requestAnimationFrame(()=>adjust(card.querySelector('.note-bubble')));
      setTimeout(()=>card.classList.remove('show-note'), 2500);
    }, true);

    // Info panel toggle (unchanged)
    const infoBtn = $('#info-toggle');
    const infoPanel = $('#reading-info');
    if (infoBtn && infoPanel){
      infoBtn.addEventListener('click', ()=>{
        const isOpen = infoPanel.classList.toggle('info-panel--visible');
        infoPanel.hidden = !isOpen;
        infoBtn.setAttribute('aria-pressed', isOpen ? 'true' : 'false');
        infoBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        if (isOpen) infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }
  })();
</script>

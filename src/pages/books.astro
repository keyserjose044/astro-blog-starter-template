---
// src/pages/books.astro
// Revision: restored reliable page styling, unified filters, and five-line metadata — July 22, 2026
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoBg from '../components/VideoBg.astro';
import { SITE_TITLE } from '../consts';
import { fetchAllRaindrops } from '../utils/raindrop';

const RAINDROP_TOKEN = import.meta.env.RAINDROP_TOKEN;
const COLLECTION_ID = import.meta.env.RAINDROP_COLLECTION_BOOKS_ID || '54514877';

const books = await fetchAllRaindrops({
  token: RAINDROP_TOKEN,
  collectionId: COLLECTION_ID,
  label: 'books',
  placeholder: '/images_webp/books-placeholder.webp',
});

const getBookMeta = (note?: string | null) => {
  const parts = String(note || '')
    .split('·')
    .map((part) => part.trim());

  return {
    dateFinished: parts[0] || '',
    author: parts[2] || '',
    yearPublished: parts[3] || '',
    genre: parts[4] || '',
    subgenre: parts[5] || '',
    language: parts[7] || '',
    country: parts[8] || '',
    length: parts[9] || '',
  };
};

const parseBookLengthMinutes = (value?: string | null): number => {
  const raw = String(value || '').toLowerCase().trim();
  if (!raw) return 0;

  const colonMatch = raw.match(/^(\d+):(\d{1,2})(?::(\d{1,2}))?$/);
  if (colonMatch) {
    const first = Number(colonMatch[1]);
    const second = Number(colonMatch[2]);
    const third = colonMatch[3] ? Number(colonMatch[3]) : null;
    return third === null ? first * 60 + second : first * 60 + second + third / 60;
  }

  const hoursMatch = raw.match(/([\d.]+)\s*(?:h|hr|hrs|hour|hours)\b/);
  const minutesMatch = raw.match(/([\d.]+)\s*(?:m|min|mins|minute|minutes)\b/);
  if (hoursMatch || minutesMatch) {
    return (hoursMatch ? Number(hoursMatch[1]) * 60 : 0) +
      (minutesMatch ? Number(minutesMatch[1]) : 0);
  }

  const numeric = Number.parseFloat(raw.replace(/[^\d.]/g, ''));
  return Number.isFinite(numeric) ? numeric * 60 : 0;
};

const totalListeningMinutes = books.reduce((sum, book) => {
  const { length } = getBookMeta(book.note);
  return sum + parseBookLengthMinutes(length);
}, 0);
const totalListeningHours = Math.round(totalListeningMinutes / 60);

const getFinishedYear = (dateFinished?: string | null) => {
  const raw = String(dateFinished || '').trim();

  // Raindrop completion dates are commonly stored as M/D/YY, such as 5/26/26.
  const numericDate = raw.match(/\b\d{1,2}[\/-]\d{1,2}[\/-](\d{2}|\d{4})\b/);
  if (numericDate) {
    const year = numericDate[1];
    return year.length === 2 ? String(2000 + Number(year)) : year;
  }

  // Also support notes that already contain a four-digit year in another date format.
  return raw.match(/\b(?:19|20)\d{2}\b/)?.[0] || '';
};

const getOrdinal = (value: number) => {
  const mod100 = value % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${value}th`;

  const mod10 = value % 10;
  if (mod10 === 1) return `${value}st`;
  if (mod10 === 2) return `${value}nd`;
  if (mod10 === 3) return `${value}rd`;
  return `${value}th`;
};

const getPublicationYear = (yearPublished?: string | null): number | null => {
  const raw = String(yearPublished || '').trim();
  const normalized = raw.toLowerCase().replace(/,/g, '');

  if (!normalized) return null;

  // Also support values written as 600 BC / BCE before parsing unsigned numbers.
  const bceMatch = normalized.match(/\b(\d{1,4})\s*(?:bc|bce)\b/);
  if (bceMatch) return -Number(bceMatch[1]);

  // AD / CE years remain positive.
  const ceMatch = normalized.match(/\b(\d{1,4})\s*(?:ad|ce)\b/);
  if (ceMatch) return Number(ceMatch[1]);

  // Raindrop stores BCE years as negative numbers, such as -600 or -1700.
  const signedYearMatch = normalized.match(/(?:^|\s)(-?\d{1,4})(?=\s|$|\b)/);
  if (signedYearMatch) {
    const year = Number(signedYearMatch[1]);
    return Number.isFinite(year) ? year : null;
  }

  return null;
};

const getPublicationPeriod = (yearPublished?: string | null) => {
  const raw = String(yearPublished || '').trim();
  const normalized = raw.toLowerCase().replace(/,/g, '');

  if (!normalized) {
    return { key: 'unknown', label: 'Unknown date', order: 400 };
  }

  const isBce = /\b(?:bc|bce)\b/.test(normalized);
  const centuryMatch = normalized.match(/\b(\d{1,2})(?:st|nd|rd|th)\s+century\b/);

  if (centuryMatch) {
    const century = Number(centuryMatch[1]);

    if (isBce || century <= 5) {
      return { key: 'ancient', label: 'Ancient (before 500)', order: 300 };
    }

    if (century <= 14) {
      return { key: 'medieval', label: 'Medieval (500–1400)', order: 200 };
    }

    return {
      key: `century-${century}`,
      label: `${getOrdinal(century)} century`,
      order: 100 - century,
    };
  }

  const year = getPublicationYear(yearPublished);
  if (year === null) {
    return { key: 'unknown', label: 'Unknown date', order: 400 };
  }

  // Any negative year is BCE and therefore Ancient.
  if (year < 500) {
    return { key: 'ancient', label: 'Ancient (before 500)', order: 300 };
  }

  if (year <= 1400) {
    return { key: 'medieval', label: 'Medieval (500–1400)', order: 200 };
  }

  const century = Math.ceil(year / 100);

  return {
    key: `century-${century}`,
    label: `${getOrdinal(century)} century`,
    order: 100 - century,
  };
};
---

<BaseHead
  title={`${SITE_TITLE} — books`}
  description="books gallery powered by Raindrop, auto-updated from my collection."
/>

<style is:inline>
  :root{--gap:22px;--ink:#0e121b;--muted:#5e6573;--border:#e6e9ef;--surface:#fff}
  *{box-sizing:border-box}
  .wrap{margin:0 auto;padding-block:28px 48px;padding-inline:clamp(16px,3vw,48px);max-width:100%}
  .wrap--wide{width:100dvw;margin-left:calc(50% - 50dvw);margin-right:calc(50% - 50dvw);padding-inline:0}
  .intro{max-width:920px;margin:0 auto 24px;text-align:center;padding-inline:clamp(16px,3vw,48px)}
  h1{margin:0 0 12px;font-weight:800;letter-spacing:-.02em;display:flex;gap:.6rem;align-items:center;justify-content:center}
  .hint{color:var(--muted);margin:6px 0 20px}
  .toolbar{display:flex;align-items:center;justify-content:center;gap:8px;margin:6px 0 14px;flex-wrap:wrap}
  .toolbar input[type="search"]{flex:1 1 260px;width:100%;max-width:340px;margin-inline:0;padding:12px 14px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.95rem;box-shadow:0 1px 2px rgba(0,0,0,.03);}
  .toolbar #sort-books{flex:0 1 155px;min-width:145px;padding:10px 12px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--ink);font-size:.9rem;box-shadow:0 1px 2px rgba(0,0,0,.03);}

  .filters-toggle{
    min-height:40px;padding:9px 13px;border-radius:12px;border:1px solid var(--border);
    background:rgba(255,255,255,.94);color:var(--ink);font:inherit;font-size:.86rem;
    font-weight:700;line-height:1;cursor:pointer;display:inline-flex;align-items:center;
    justify-content:center;gap:7px;white-space:nowrap;box-shadow:0 1px 2px rgba(0,0,0,.03);
    transition:background .15s ease,border-color .15s ease,box-shadow .15s ease,transform .08s ease;
  }
  .filters-toggle:hover{
    background:#f6f7ff;border-color:rgba(64,92,245,.35);
    box-shadow:0 4px 10px rgba(15,23,42,.07);transform:translateY(-1px)
  }
  .filters-toggle[aria-expanded="true"]{
    background:#f1f3ff;border-color:rgba(64,92,245,.45);color:#263ebd;
  }
  .filters-toggle.has-active-filters{
    background:#f1f3ff;border-color:#405cf5;color:#263ebd;
  }
  .filters-toggle:focus-visible{outline:2px solid #405cf5;outline-offset:2px}
  .filters-count{
    min-width:19px;height:19px;padding:0 5px;border-radius:999px;background:#405cf5;color:#fff;
    display:inline-flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;
  }
  .filters-chevron{font-size:.72rem;transition:transform .15s ease}
  .filters-toggle[aria-expanded="true"] .filters-chevron{transform:rotate(180deg)}
  .filters-panel{
    width:min(1080px,calc(100% - 32px));margin:-4px auto 18px;padding:12px;
    border:1px solid var(--border);border-radius:14px;background:rgba(255,255,255,.94);
    box-shadow:0 8px 20px rgba(15,23,42,.06);display:grid;
    grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;text-align:left;
  }
  .filters-panel[hidden]{display:none}
  .filter-field{display:flex;flex-direction:column;gap:6px;min-width:0}
  .filter-field span{font-size:.76rem;font-weight:700;color:var(--muted)}
  .filter-field select{
    width:100%;min-width:0;padding:10px 12px;border-radius:10px;border:1px solid var(--border);
    background:var(--surface);color:var(--ink);font:inherit;font-size:.86rem;
  }

  @media (min-width:901px){
    .intro{max-width:1120px;padding-inline:20px}
    .toolbar{flex-wrap:nowrap}
    .toolbar > .info-toggle{flex:0 0 40px}
    .toolbar > .filters-toggle{flex:0 0 104px}
  }

  .info-toggle{
    width:40px;height:40px;border-radius:999px;border:1px solid #838796;background:#a8adbd;
    display:inline-flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;
    box-shadow:0 1px 2px rgba(0,0,0,.04);
    transition:background .15s ease, box-shadow .15s ease, transform .08s ease, border-color .15s ease, color .15s ease;
  }
  .info-toggle span{position:relative;top:-1px;font-weight:600}
  .info-toggle:hover{background:#f0f2ff;box-shadow:0 4px 10px rgba(0,0,0,.08);transform:translateY(-1px)}
  .info-toggle[aria-pressed="true"]{background:#405cf5;color:#fff;border-color:#405cf5}
  .info-panel{
    max-width:920px;margin:0 auto 24px;padding:16px 18px 14px;border-radius:14px;
    background:rgba(255,255,255,.9);border:1px solid var(--border);
    box-shadow:0 10px 24px rgba(15,23,42,.04);font-size:.94rem;line-height:1.5;
    color:var(--muted);text-align:left;display:none;
  }
  .info-panel--visible{display:block}
  .info-panel h2{font-size:1.02rem;margin:0 0 .4rem;font-weight:700;color:var(--ink)}
  .info-panel p{margin:.35rem 0}
  .info-panel a{color:#314bd8;font-weight:700;text-underline-offset:2px}
  .grid{display:grid;gap:var(--gap);align-items:start;max-width:100%}
  .grid[data-book-view="quilt"]{grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}
  @media (min-width:1800px){.grid[data-book-view="quilt"]{grid-template-columns:repeat(auto-fit,minmax(150px,1fr))}}
  .fullbleed{width:100%;margin:0;padding-inline:clamp(16px,3vw,48px)}
  .card{position:relative;display:flex;flex-direction:column;gap:8px;text-decoration:none;color:inherit;border-radius:12px}
  .thumb{
    width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:12px;
    box-shadow:0 10px 24px rgba(0,0,0,.12);background:#f0f2f7;border:1px solid var(--border);
  }
  .title{font-weight:700;font-size:.98rem;line-height:1.3}
  .external-link-cue{display:inline-block;margin-left:.2em;color:var(--muted);font-size:.8em;font-weight:700;vertical-align:.08em}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .card:focus-visible{outline:2px solid #405cf5;outline-offset:4px;border-radius:12px}
  .note-bubble{
    position:absolute;left:50%;top:-10px;transform:translate(calc(-50% + var(--shift,0px)),-100%);
    width:max-content;max-width:min(600px,90vw);white-space:normal;background:rgba(20,23,31,.96);
    color:#fff;font-size:.9rem;line-height:1.35;padding:10px 12px;border-radius:10px;
    box-shadow:0 10px 24px rgba(0,0,0,.25);z-index:10;pointer-events:none;opacity:0;
    visibility:hidden;transition:opacity .15s ease,visibility .15s ease;
    text-align:left;text-wrap:pretty;hyphens:auto;word-break:break-word;
  }
  .note-bubble::after{
    content:"";position:absolute;left:50%;top:100%;transform:translateX(-50%);
    border:8px solid transparent;border-top-color:rgba(20,23,31,.96);
  }
  .card:hover .note-bubble,
  .card:focus-within .note-bubble,
  .card.show-note .note-bubble{opacity:1;visibility:visible}
  @media (max-width:700px){
    .note-bubble{
      top:auto;bottom:-10px;transform:translate(calc(-50% + var(--shift,0px)),100%);
    }
    .note-bubble::after{
      top:auto;bottom:100%;border-top-color:transparent;border-bottom-color:rgba(20,23,31,.96);
    }
  }
  .empty{text-align:center;color:var(--muted);padding:40px 0 24px}

  .results-row{
    display:flex;align-items:center;justify-content:center;gap:10px;
    min-height:32px;margin:-6px auto 18px;color:var(--muted);font-size:.86rem;
  }
  .results-count{margin:0}
  .clear-filters{
    border:1px solid var(--border);border-radius:999px;background:rgba(255,255,255,.92);
    color:#314bd8;padding:6px 10px;font:inherit;font-size:.8rem;font-weight:700;
    line-height:1;cursor:pointer;box-shadow:0 3px 10px rgba(15,23,42,.05);
  }
  .clear-filters:hover{border-color:rgba(64,92,245,.35);background:#f6f7ff}
  .clear-filters:focus-visible{outline:2px solid #405cf5;outline-offset:2px}

  .card-meta{display:none}

  .view-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    margin: 0 auto 18px;
    padding: 3px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 6px 16px rgba(15,23,42,.06);
  }

  .view-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 36px;
    padding: 7px 12px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
  }

  .view-button[aria-pressed="true"] {
    background: #405cf5;
    color: #fff;
    box-shadow: 0 5px 12px rgba(64,92,245,.22);
  }

  .view-button:focus-visible {
    outline: 2px solid #405cf5;
    outline-offset: 2px;
  }

  /* Desktop List view becomes a responsive grid of equal-height detail cards. */
  @media (min-width: 901px) {
    .grid[data-book-view="list"] {
      width: 100%;
      max-width: 1700px;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      grid-auto-rows: 184px;
      gap: 16px;
      margin-inline: auto;
    }

    .grid[data-book-view="list"] .card {
      display: grid;
      width: 100%;
      height: 100%;
      min-height: 184px;
      min-width: 0;
      grid-template-columns: 104px minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      gap: 7px 14px;
      align-items: start;
      overflow: hidden;
      padding: 10px;
      border: 1px solid rgba(230,233,239,.95);
      border-radius: 14px;
      background: rgba(255,255,255,.9);
      box-shadow: 0 8px 20px rgba(15,23,42,.07);
      transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }

    .grid[data-book-view="list"] .card:hover {
      transform: translateY(-2px);
      border-color: rgba(64,92,245,.28);
      box-shadow: 0 12px 28px rgba(15,23,42,.11);
    }

    .grid[data-book-view="list"] .thumb {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 104px;
      height: 156px;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      border-radius: 9px;
      box-shadow: 0 6px 15px rgba(0,0,0,.13);
    }

    .grid[data-book-view="list"] .title {
      grid-column: 2;
      grid-row: 1;
      display: -webkit-box;
      min-height: 2.6em;
      overflow: hidden;
      margin-top: 2px;
      font-size: 1rem;
      line-height: 1.3;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .grid[data-book-view="list"] .card-meta {
      display: flex;
      grid-column: 2;
      grid-row: 2;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
      color: var(--muted);
      font-size: .82rem;
      line-height: 1.35;
    }

    .grid[data-book-view="list"] .card-meta span {
      display: block;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .grid[data-book-view="list"] .note-bubble {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .wrap {
      padding-block: 18px 36px;
    }

    .intro {
      margin-bottom: 14px;
      padding-inline: 12px;
    }

    h1 {
      margin-bottom: 6px;
      font-size: 2rem;
    }

    .hint {
      max-width: 36ch;
      margin: 4px auto 12px;
      font-size: 0.86rem;
      line-height: 1.42;
    }

    .toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 40px 40px;
      gap: 7px;
      margin-bottom: 10px;
    }

    .toolbar input[type="search"] {
      grid-column: 1 / -1;
      max-width: none;
      padding: 10px 12px;
      font-size: 0.88rem;
    }

    #filters-toggle {
      grid-column: 1;
      grid-row: 2;
      width: 100%;
    }

    #sort-books {
      grid-column: 2;
      grid-row: 2;
      width: 100%;
      min-width: 0;
      padding: 9px 8px;
      font-size: 0.8rem;
    }

    #info-toggle {
      grid-column: 3;
      grid-row: 2;
    }

    .toolbar > a.info-toggle {
      grid-column: 4;
      grid-row: 2;
    }

    .filters-panel {
      width: calc(100% - 20px);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: -2px;
      margin-bottom: 14px;
      padding: 10px;
    }

    .filters-panel .filter-field:last-child {
      grid-column: 1 / -1;
    }

    .view-toggle {
      margin-bottom: 14px;
    }

    .results-row {
      margin-top: -4px;
      margin-bottom: 14px;
      font-size: .8rem;
    }

    .clear-filters {
      padding: 6px 9px;
      font-size: .76rem;
    }

    .fullbleed {
      padding-inline: 10px;
    }

    /* Quilt remains available as the visual browsing option. */
    .grid[data-book-view="quilt"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px 10px;
    }

    .grid[data-book-view="quilt"] .card {
      min-width: 0;
      gap: 5px;
    }

    .grid[data-book-view="quilt"] .thumb {
      aspect-ratio: 2 / 3;
      border-radius: 9px;
      box-shadow: 0 6px 14px rgba(0,0,0,.12);
    }

    .grid[data-book-view="quilt"] .title {
      display: -webkit-box;
      overflow: hidden;
      font-size: 0.78rem;
      line-height: 1.24;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    /* List keeps one book per row without making each cover enormous. */
    .grid[data-book-view="list"] {
      width: 100%;
      max-width: 680px;
      grid-template-columns: minmax(0, 1fr);
      grid-auto-rows: 176px;
      gap: 10px;
      margin-inline: auto;
    }

    .grid[data-book-view="list"] .card {
      display: grid;
      width: 100%;
      max-width: none;
      height: 100%;
      min-width: 0;
      min-height: 176px;
      grid-template-columns: 92px minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      gap: 6px 12px;
      align-items: start;
      justify-self: stretch;
      align-self: stretch;
      overflow: hidden;
      padding: 10px;
      border: 1px solid rgba(230,233,239,.95);
      border-radius: 14px;
      background: rgba(255,255,255,.9);
      box-shadow: 0 7px 18px rgba(15,23,42,.06);
    }

    .grid[data-book-view="list"] .thumb {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 92px;
      height: 138px;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 5px 12px rgba(0,0,0,.12);
    }

    .grid[data-book-view="list"] .title {
      grid-column: 2;
      grid-row: 1;
      display: -webkit-box;
      min-height: 2.35em;
      overflow: hidden;
      margin-top: 1px;
      font-size: 0.94rem;
      line-height: 1.25;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .grid[data-book-view="list"] .card-meta {
      display: flex;
      grid-column: 2;
      grid-row: 2;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
      color: var(--muted);
      font-size: 0.76rem;
      line-height: 1.3;
    }

    .grid[data-book-view="list"] .card-meta span {
      display: block;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Metadata is already visible in list view, so no floating tooltip is needed. */
    .grid[data-book-view="list"] .note-bubble {
      display: none;
    }

    .note-bubble {
      max-width: min(310px, 88vw);
      padding: 8px 10px;
      font-size: 0.78rem;
      line-height: 1.32;
    }

    .info-panel {
      margin-bottom: 16px;
      padding: 13px;
      font-size: 0.84rem;
    }
  }

  @media (min-width: 560px) and (max-width: 900px) {
    .grid[data-book-view="quilt"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px 12px;
    }

    .grid[data-book-view="quilt"] .title {
      font-size: 0.84rem;
    }
  }
</style>


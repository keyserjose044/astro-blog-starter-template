---
// src/pages/faq.astro
import AboutLayout from '../layouts/AboutLayout.astro';

type FaqLink = {
  href: string;
  label: string;
};

type FaqQuestion = {
  id: string;
  question: string;
  answer: string;
  link?: FaqLink;
  popular?: boolean;
};

type FaqGroup = {
  id: string;
  icon: string;
  label: string;
  title: string;
  description: string;
  questions: FaqQuestion[];
};

const faqGroups: FaqGroup[] = [
  {
    id: 'getting-started',
    icon: '🚀',
    label: 'Begin simply',
    title: 'Getting Started',
    description: 'Start small, build consistency, and shape a system that fits your life.',
    questions: [
      {
        id: 'who-is-lifeloggerz-for',
        question: 'Who is LifeLoggerz for?',
        answer:
          'LifeLoggerz is for anyone who wants to understand how they spend their time and make more intentional decisions from it. That includes students, researchers, builders, creatives, and curious people who want a clearer record of their days.',
        popular: true,
      },
      {
        id: 'what-should-i-track-first',
        question: 'What should I track first if I’m just starting out?',
        answer:
          'Begin with three things that genuinely matter to you: usually sleep, work or study time, and one habit you want to strengthen. A small system you maintain is far more useful than an ambitious system you abandon.',
        link: { href: '/templates', label: 'Browse the starter templates' },
        popular: true,
      },
      {
        id: 'how-long-does-logging-take',
        question: 'How long does logging take each day?',
        answer:
          'The basic logs take about five minutes. Longer reflection is optional. I automate repetitive steps whenever possible so that the system records life without constantly interrupting it.',
      },
      {
        id: 'what-if-i-miss-days',
        question: 'What happens if I miss days or fall behind?',
        answer:
          'I simplify instead of quitting. I may reconstruct a few basic details from calendars, messages, or memory, but I do not chase perfect completeness. The goal is a useful long-term record, not an unbroken performance streak.',
      },
      {
        id: 'do-i-need-to-track-as-much',
        question: 'Do I need to track as much as you do?',
        answer:
          'No. My system reflects my own curiosity and has expanded over several years. Your version should only include information that helps you remember, decide, create, or understand something important.',
      },
    ],
  },
  {
    id: 'what-i-track',
    icon: '📊',
    label: 'See the record',
    title: 'What I Track & Why',
    description: 'A mix of numbers, notes, milestones, media, habits, and ordinary daily life.',
    questions: [
      {
        id: 'what-kinds-of-things',
        question: 'What kinds of things do you track?',
        answer:
          'I track sleep, work sessions, habits, reading, hobbies, movement, social time, places, projects, and short reflections. Some records are quantitative, while others preserve context that a number could never capture.',
        link: { href: '/stats', label: 'Explore the statistics' },
      },
      {
        id: 'do-you-review-the-data',
        question: 'Do you actually review all this data?',
        answer:
          'I review broad trends monthly and yearly rather than rereading every entry. The detailed archive becomes valuable when I want to answer a specific question about the past, compare periods, or recover a memory that would otherwise be lost.',
      },
      {
        id: 'why-track-so-many-things',
        question: 'Why do you track so many things?',
        answer:
          'Small decisions accumulate into seasons of life. Tracking makes those patterns visible: where time went, what improved, what disappeared, what returned, and which habits or circumstances moved together.',
      },
      {
        id: 'habit-tracker-difference',
        question: 'How is LifeLoggerz different from a normal habit tracker?',
        answer:
          'A habit tracker usually asks whether you completed a behavior. LifeLoggerz is broader: it combines habits with time, experiences, media, projects, reflections, and archives so that individual entries become part of a searchable life record.',
        popular: true,
      },
      {
        id: 'what-can-tracking-reveal',
        question: 'What can tracking reveal that memory cannot?',
        answer:
          'Memory preserves highlights but compresses repetition, timing, and gradual change. A record can show when something began, how long it lasted, what else was happening, and whether the story I remember matches the evidence.',
      },
    ],
  },
  {
    id: 'tools-templates',
    icon: '🛠️',
    label: 'Build your version',
    title: 'Tools, Templates & Systems',
    description: 'Use the simple pieces first. Automation and customization can come later.',
    questions: [
      {
        id: 'need-coding-experience',
        question: 'Do I need coding or Google Sheets experience?',
        answer:
          'No. The core templates can be used without coding. Scripts and automation are optional layers for people who want to reduce manual work or connect several logs together.',
      },
      {
        id: 'use-without-automation',
        question: 'Can I use the system without automation?',
        answer:
          'Absolutely. A clear manual log is better than a complicated automated system you do not understand. Automation should remove friction after the underlying habit already works.',
      },
      {
        id: 'modify-templates',
        question: 'Can I modify your templates for personal use?',
        answer:
          'Yes. Change the categories, wording, colors, formulas, and frequency until the system fits your life. If you share a close adaptation publicly, a small credit to LifeLoggerz is appreciated.',
        link: { href: '/templates', label: 'Open the templates' },
      },
      {
        id: 'why-google-sheets',
        question: 'Why do you use Google Sheets instead of Excel or Notion?',
        answer:
          'Google Sheets is flexible, cloud-backed, easy to access from different devices, and compatible with Apps Script. It gives me enough structure for analysis without forcing every kind of record into the same interface.',
      },
      {
        id: 'more-tools-coming',
        question: 'Will you release more templates and tools?',
        answer:
          'Yes. I am gradually turning more parts of the system into public-safe templates, explanations, and demonstrations. Useful suggestions help determine what gets developed next.',
        link: {
          href: 'mailto:lifeloggerz.official@gmail.com',
          label: 'Suggest what I should build next',
        },
      },
    ],
  },
  {
    id: 'privacy-data',
    icon: '🔒',
    label: 'Protect the archive',
    title: 'Privacy, Data & Backups',
    description: 'The structure can be public even when the underlying life remains private.',
    questions: [
      {
        id: 'share-real-personal-data',
        question: 'Do you share your real personal data?',
        answer:
          'I share selected statistics, public-safe examples, system architecture, and lessons learned. Private diary entries, sensitive records, and identifying details are not published simply because they exist in the archive.',
      },
      {
        id: 'protect-and-back-up',
        question: 'How do you protect and back up your logs?',
        answer:
          'Important records are kept in cloud storage and copied offline, with periodic exports of files that would be difficult to recreate. If something matters enough to preserve, it should not depend on one account, device, or format.',
      },
      {
        id: 'public-parts-of-data',
        question: 'What parts of the data are shown publicly?',
        answer:
          'The public site emphasizes totals, trends, systems, collections, and carefully selected examples. The goal is to demonstrate what personal data can become without turning the website into an unrestricted window into my private life.',
      },
    ],
  },
  {
    id: 'philosophy-purpose',
    icon: '🌱',
    label: 'Understand the purpose',
    title: 'Philosophy & Purpose',
    description: 'Tracking is a tool for attention and memory—not the point of life itself.',
    questions: [
      {
        id: 'is-tracking-excessive',
        question: 'Isn’t this level of tracking excessive?',
        answer:
          'It could be excessive for someone else. My rule is that tracking must create more clarity than friction. When a log stops being useful or starts feeling burdensome, I simplify, automate, or remove it.',
        popular: true,
      },
      {
        id: 'avoid-obsessive-tracking',
        question: 'How do you avoid becoming obsessive about tracking?',
        answer:
          'I treat the record as an aid, not a judge. Missing data is allowed, imperfect estimates are labeled honestly, and no metric is permitted to replace common sense or the experience it was meant to describe.',
      },
      {
        id: 'systems-and-creativity',
        question: 'Do systems limit creativity or increase it?',
        answer:
          'For me, they increase it. A dependable structure clears mental clutter, preserves unfinished ideas, and makes it easier to return to meaningful work instead of repeatedly rebuilding context.',
      },
      {
        id: 'ultimate-goal',
        question: 'What are you ultimately working toward?',
        answer:
          'A clearer, more intentional, and better-remembered life. The spreadsheets, scripts, graphs, and archives are only tools for noticing what matters and acting on it.',
        link: { href: '/about', label: 'Read the full LifeLoggerz story' },
      },
    ],
  },
  {
    id: 'contact-collaboration',
    icon: '📬',
    label: 'Continue the conversation',
    title: 'Contact & Collaboration',
    description: 'Questions, thoughtful criticism, adaptations, and ambitious ideas are welcome.',
    questions: [
      {
        id: 'how-to-contact',
        question: 'How can I contact you?',
        answer:
          'You can email me at lifeloggerz.official@gmail.com. Tell me what you are building, which part of LifeLoggerz interested you, or where the site could be clearer.',
        link: {
          href: 'mailto:lifeloggerz.official@gmail.com',
          label: 'Email LifeLoggerz',
        },
      },
      {
        id: 'suggest-or-collaborate',
        question: 'Can I suggest a template, feature, or collaboration?',
        answer:
          'Yes. Some of the best directions come from people who try the ideas, notice a missing step, or imagine a use I had not considered. Specific suggestions are especially helpful.',
        link: {
          href: 'mailto:lifeloggerz.official@gmail.com',
          label: 'Start a conversation',
        },
      },
    ],
  },
];

const allQuestions = faqGroups.flatMap((group) =>
  group.questions.map((question) => ({ ...question, groupTitle: group.title })),
);

const popularQuestions = allQuestions.filter((question) => question.popular).slice(0, 4);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<AboutLayout
  title="Frequently Asked Questions"
  description="How LifeLoggerz works, what to track first, and how to adapt the system for your own life."
  pubDate="2026-07-15"
  wide={true}
  showViews={false}
  heroImage="/images_webp/faq-movie.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="faq-page" id="faq-top">
    <section class="faq-intro" aria-labelledby="faq-intro-title">
      <p class="eyebrow">A practical guide to LifeLoggerz</p>
      <h2 id="faq-intro-title">Find the part of the system that matters to you.</h2>
      <p class="intro-copy">
        LifeLoggerz is an experiment in turning everyday records into memory, perspective,
        and better decisions. Start with a path below, search for a question, or browse the
        complete guide.
      </p>

      <div class="intro-meta" aria-label="FAQ overview">
        <span><strong>{allQuestions.length}</strong> answers</span>
        <span><strong>{faqGroups.length}</strong> topics</span>
        <span><strong>5 min</strong> to explore</span>
      </div>
    </section>

    <section class="start-here" aria-labelledby="start-here-title">
      <div class="section-heading compact">
        <div>
          <p class="eyebrow">Choose a path</p>
          <h2 id="start-here-title">Where would you like to begin?</h2>
        </div>
      </div>

      <div class="path-grid">
        <a class="path-card" href="#getting-started">
          <span class="path-icon" aria-hidden="true">🌱</span>
          <span>
            <strong>I’m new to tracking</strong>
            <small>Build a useful system without overcomplicating it.</small>
          </span>
          <span class="path-arrow" aria-hidden="true">→</span>
        </a>

        <a class="path-card" href="#what-i-track">
          <span class="path-icon" aria-hidden="true">🔎</span>
          <span>
            <strong>Show me what you track</strong>
            <small>See how scattered details become a life archive.</small>
          </span>
          <span class="path-arrow" aria-hidden="true">→</span>
        </a>

        <a class="path-card" href="#tools-templates">
          <span class="path-icon" aria-hidden="true">🧰</span>
          <span>
            <strong>I want to build my own</strong>
            <small>Explore templates, tools, and optional automation.</small>
          </span>
          <span class="path-arrow" aria-hidden="true">→</span>
        </a>

        <a class="path-card" href="#philosophy-purpose">
          <span class="path-icon" aria-hidden="true">🧭</span>
          <span>
            <strong>Why do any of this?</strong>
            <small>Understand the philosophy, limits, and larger purpose.</small>
          </span>
          <span class="path-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <section class="faq-tools" aria-label="Search and expand FAQ answers">
      <div class="search-wrap">
        <label class="sr-only" for="faq-search">Search frequently asked questions</label>
        <span class="search-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <path d="m21 21-4.35-4.35m2.35-5.65a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"></path>
          </svg>
        </span>
        <input
          id="faq-search"
          type="search"
          placeholder="Search questions, tools, privacy, habits…"
          autocomplete="off"
        />
        <kbd id="search-shortcut" aria-hidden="true">Ctrl K</kbd>
      </div>

      <div class="tool-actions">
        <span id="faq-result-count" class="result-count" aria-live="polite">
          {allQuestions.length} questions
        </span>
        <button id="toggle-all" class="quiet-button" type="button">Open all</button>
      </div>
    </section>

    <section class="popular-section" aria-labelledby="popular-title">
      <div class="section-heading compact">
        <div>
          <p class="eyebrow">Popular questions</p>
          <h2 id="popular-title">The questions most people ask first</h2>
        </div>
      </div>

      <div class="popular-grid">
        {
          popularQuestions.map((item, index) => (
            <a class="popular-link" href={`#${item.id}`} data-open-question={item.id}>
              <span class="popular-number" aria-hidden="true">
                0{index + 1}
              </span>
              <span>
                <strong>{item.question}</strong>
                <small>{item.groupTitle}</small>
              </span>
              <span class="popular-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </section>

    <div class="faq-shell">
      <aside class="faq-sidebar" aria-label="FAQ categories">
        <div class="sidebar-card">
          <p class="sidebar-label">Browse by topic</p>
          <nav class="category-nav">
            {
              faqGroups.map((group, index) => (
                <a href={`#${group.id}`} data-nav-target={group.id} class:list={{ 'is-active': index === 0 }}>
                  <span aria-hidden="true">{group.icon}</span>
                  <span>{group.title}</span>
                  <small>{group.questions.length}</small>
                </a>
              ))
            }
          </nav>

          <div class="sidebar-note">
            <strong>Still deciding where to begin?</strong>
            <p>Start with only three useful logs and earn complexity over time.</p>
            <a href="/templates">View starter templates →</a>
          </div>
        </div>
      </aside>

      <div class="faq-content">
        {
          faqGroups.map((group, groupIndex) => (
            <section
              class="faq-group"
              id={group.id}
              data-group={group.id}
              aria-labelledby={`${group.id}-title`}
            >
              <header class="group-header">
                <div class="group-icon" aria-hidden="true">{group.icon}</div>
                <div>
                  <p class="group-label">{group.label}</p>
                  <h2 id={`${group.id}-title`}>{group.title}</h2>
                  <p>{group.description}</p>
                </div>
                <span class="group-count">
                  {group.questions.length} {group.questions.length === 1 ? 'answer' : 'answers'}
                </span>
              </header>

              <div class="faq-list">
                {group.questions.map((item, questionIndex) => {
                  const sequence = String(
                    faqGroups
                      .slice(0, groupIndex)
                      .reduce((sum, currentGroup) => sum + currentGroup.questions.length, 0) +
                      questionIndex +
                      1,
                  ).padStart(2, '0');

                  return (
                    <details
                      class="faq-item"
                      id={item.id}
                      data-search={`${item.question} ${item.answer} ${group.title}`}
                    >
                      <summary>
                        <span class="question-number" aria-hidden="true">{sequence}</span>
                        <span class="question-text">{item.question}</span>
                        <span class="question-toggle" aria-hidden="true"></span>
                      </summary>
                      <div class="faq-answer">
                        <p>{item.answer}</p>
                        {item.link && (
                          <a class="answer-link" href={item.link.href}>
                            {item.link.label}
                            <span aria-hidden="true">→</span>
                          </a>
                        )}
                      </div>
                    </details>
                  );
                })}
              </div>
            </section>
          ))
        }

        <div id="faq-no-results" class="no-results" hidden>
          <span aria-hidden="true">🔍</span>
          <h2>No matching questions</h2>
          <p>Try a broader word, or clear the search and browse by topic.</p>
          <button id="clear-search" class="primary-button" type="button">Clear search</button>
        </div>
      </div>
    </div>

    <section class="faq-cta" aria-labelledby="faq-cta-title">
      <div>
        <p class="eyebrow">Keep exploring</p>
        <h2 id="faq-cta-title">A life can become searchable without becoming mechanical.</h2>
        <p>
          See the complete story, adapt the public templates, or send a question that this page
          should answer next.
        </p>
      </div>
      <div class="cta-actions">
        <a class="primary-button" href="/about">Read the story</a>
        <a class="secondary-button" href="/templates">Browse templates</a>
        <a class="text-link" href="mailto:lifeloggerz.official@gmail.com">Ask a question →</a>
      </div>
    </section>
  </main>

  <script>
    const searchInput = document.getElementById('faq-search');
    const resultCount = document.getElementById('faq-result-count');
    const toggleAllButton = document.getElementById('toggle-all');
    const searchShortcut = document.getElementById('search-shortcut');
    const clearSearchButton = document.getElementById('clear-search');
    const noResults = document.getElementById('faq-no-results');
    const items = Array.from(document.querySelectorAll<HTMLDetailsElement>('.faq-item'));
    const groups = Array.from(document.querySelectorAll<HTMLElement>('.faq-group'));
    const popularLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-open-question]'),
    );

    if (searchShortcut && /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      searchShortcut.textContent = '⌘ K';
    }

    const normalizeText = (value) =>
      value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .trim();

    const getVisibleItems = () => items.filter((item) => !item.hidden);

    const updateToggleLabel = () => {
      const visibleItems = getVisibleItems();
      const allOpen = visibleItems.length > 0 && visibleItems.every((item) => item.open);
      if (toggleAllButton) toggleAllButton.textContent = allOpen ? 'Close all' : 'Open all';
    };

    const filterQuestions = () => {
      if (!(searchInput instanceof HTMLInputElement)) return;

      const query = normalizeText(searchInput.value);
      let visibleCount = 0;

      items.forEach((item) => {
        const searchableText = normalizeText(item.dataset.search || item.textContent || '');
        const isMatch = !query || searchableText.includes(query);
        item.hidden = !isMatch;

        if (isMatch) {
          visibleCount += 1;
          if (query) item.open = true;
        }
      });

      groups.forEach((group) => {
        const visibleInGroup = Array.from(group.querySelectorAll<HTMLDetailsElement>('.faq-item')).some(
          (item) => !item.hidden,
        );
        group.hidden = !visibleInGroup;
      });

      if (resultCount) {
        resultCount.textContent = `${visibleCount} ${visibleCount === 1 ? 'question' : 'questions'}`;
      }

      if (noResults) noResults.hidden = visibleCount !== 0;
      updateToggleLabel();
    };

    searchInput?.addEventListener('input', filterQuestions);

    clearSearchButton?.addEventListener('click', () => {
      if (!(searchInput instanceof HTMLInputElement)) return;
      searchInput.value = '';
      filterQuestions();
      searchInput.focus();
    });

    toggleAllButton?.addEventListener('click', () => {
      const visibleItems = getVisibleItems();
      const shouldOpen = !visibleItems.every((item) => item.open);
      visibleItems.forEach((item) => {
        item.open = shouldOpen;
      });
      updateToggleLabel();
    });

    items.forEach((item) => item.addEventListener('toggle', updateToggleLabel));

    popularLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const id = link.dataset.openQuestion;
        if (!id) return;
        const target = document.getElementById(id);
        if (target instanceof HTMLDetailsElement) target.open = true;
      });
    });

    document.addEventListener('keydown', (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        searchInput?.focus();
      }

      if (event.key === 'Escape' && document.activeElement === searchInput) {
        if (searchInput instanceof HTMLInputElement && searchInput.value) {
          searchInput.value = '';
          filterQuestions();
        } else if (searchInput instanceof HTMLElement) {
          searchInput.blur();
        }
      }
    });

    if ('IntersectionObserver' in window) {
      const navLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>('[data-nav-target]'),
      );
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (!visibleEntry) return;
          navLinks.forEach((link) => {
            link.classList.toggle('is-active', link.dataset.navTarget === visibleEntry.target.id);
          });
        },
        { rootMargin: '-18% 0px -68% 0px', threshold: [0.05, 0.2, 0.5] },
      );

      groups.forEach((group) => observer.observe(group));
    }
  </script>

  <style>
    :global(html) {
      scroll-behavior: smooth;
    }

    :global(body) {
      overflow-x: clip;
    }

    .faq-page {
      --faq-accent: var(--accent-color, #7c3aed);
      --faq-accent-strong: var(--accent-color-dark, #5b21b6);
      --faq-border: rgba(17, 24, 39, 0.18);
      --faq-border-strong: rgba(17, 24, 39, 0.3);
      --faq-surface: rgba(255, 255, 255, 0.84);
      --faq-surface-strong: rgba(255, 255, 255, 0.96);
      --faq-muted: #303038;
      position: relative;
      left: 50%;
      width: min(1380px, calc(100vw - 3rem));
      max-width: none;
      margin: 0;
      padding: clamp(1.75rem, 3vw, 3.25rem) clamp(1.25rem, 3vw, 2.5rem) 5rem;
      box-sizing: border-box;
      color: #09090b;
      scroll-behavior: smooth;
      transform: translateX(-50%);
    }

    .faq-page *,
    .faq-page *::before,
    .faq-page *::after {
      box-sizing: border-box;
    }

    .faq-intro {
      max-width: 790px;
      margin-bottom: clamp(2.75rem, 6vw, 5.5rem);
    }

    .eyebrow,
    .group-label,
    .sidebar-label {
      margin: 0 0 0.55rem;
      color: var(--faq-accent);
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .faq-intro h2,
    .section-heading h2,
    .faq-cta h2 {
      margin: 0;
      font-size: clamp(1.8rem, 4vw, 3.35rem);
      line-height: 1.05;
      letter-spacing: -0.045em;
      text-wrap: balance;
    }

    .intro-copy {
      max-width: 720px;
      margin: 1.15rem 0 0;
      color: var(--faq-muted);
      font-size: clamp(1rem, 1.7vw, 1.18rem);
      line-height: 1.75;
    }

    .faq-intro h2,
    .section-heading h2,
    .group-header h2,
    .faq-cta h2,
    .question-text,
    .path-card strong,
    .popular-link strong,
    .quiet-button,
    .secondary-button {
      color: #09090b;
    }

    .intro-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-top: 1.5rem;
    }

    .intro-meta span {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      min-height: 2.35rem;
      padding: 0.45rem 0.8rem;
      border: 1px solid var(--faq-border);
      border-radius: 999px;
      background: var(--faq-surface);
      color: var(--faq-muted);
      font-size: 0.83rem;
    }

    .intro-meta strong {
      color: currentColor;
      font-size: 0.92rem;
    }

    .start-here,
    .popular-section {
      margin-bottom: clamp(2.5rem, 6vw, 4.75rem);
    }

    .section-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.35rem;
    }

    .section-heading.compact h2 {
      font-size: clamp(1.35rem, 3vw, 2rem);
      letter-spacing: -0.03em;
    }

    .path-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .path-card {
      position: relative;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: start;
      gap: 0.8rem;
      min-height: 150px;
      padding: 1.15rem;
      overflow: hidden;
      border: 1px solid var(--faq-border);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.86);
      color: #09090b;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background 180ms ease,
        box-shadow 180ms ease;
    }

    .path-card::after {
      position: absolute;
      right: -2.5rem;
      bottom: -3rem;
      width: 8rem;
      height: 8rem;
      border-radius: 50%;
      background: color-mix(in srgb, var(--faq-accent) 13%, transparent);
      content: '';
      transition: transform 220ms ease;
    }

    .path-card:hover,
    .path-card:focus-visible {
      z-index: 1;
      border-color: color-mix(in srgb, var(--faq-accent) 55%, transparent);
      background: color-mix(in srgb, var(--faq-accent) 8%, var(--faq-surface));
      box-shadow: 0 18px 40px color-mix(in srgb, #000 13%, transparent);
      transform: translateY(-4px);
    }

    .path-card:hover::after,
    .path-card:focus-visible::after {
      transform: scale(1.2);
    }

    .path-icon {
      display: grid;
      width: 2.65rem;
      height: 2.65rem;
      place-items: center;
      border: 1px solid var(--faq-border);
      border-radius: 12px;
      background: color-mix(in srgb, currentColor 5%, transparent);
      font-size: 1.2rem;
    }

    .path-card strong,
    .popular-link strong {
      display: block;
      margin-top: 0.15rem;
      font-size: 0.98rem;
      line-height: 1.3;
    }

    .path-card small,
    .popular-link small {
      display: block;
      margin-top: 0.45rem;
      color: var(--faq-muted);
      font-size: 0.78rem;
      line-height: 1.5;
    }

    .path-arrow {
      position: relative;
      z-index: 1;
      align-self: end;
      color: var(--faq-accent);
      font-size: 1.15rem;
      font-weight: 800;
    }

    .faq-tools {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
      padding: 0.75rem;
      border: 1px solid var(--faq-border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 12px 30px color-mix(in srgb, #000 7%, transparent);
    }

    .search-wrap {
      position: relative;
      flex: 1 1 28rem;
    }

    .search-wrap input {
      width: 100%;
      min-height: 3.25rem;
      padding: 0.75rem 4.25rem 0.75rem 3rem;
      border: 1px solid transparent;
      border-radius: 13px;
      outline: none;
      background: color-mix(in srgb, currentColor 5%, transparent);
      color: inherit;
      font: inherit;
      font-size: 0.95rem;
      transition:
        border-color 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease;
    }

    .search-wrap input::placeholder {
      color: var(--faq-muted);
    }

    .search-wrap input:focus {
      border-color: color-mix(in srgb, var(--faq-accent) 65%, transparent);
      background: color-mix(in srgb, currentColor 2%, transparent);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--faq-accent) 14%, transparent);
    }

    .search-icon {
      position: absolute;
      top: 50%;
      left: 1rem;
      z-index: 1;
      display: grid;
      width: 1.15rem;
      height: 1.15rem;
      place-items: center;
      color: var(--faq-muted);
      pointer-events: none;
      transform: translateY(-50%);
    }

    .search-icon svg {
      width: 100%;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-width: 1.9;
    }

    .search-wrap kbd {
      position: absolute;
      top: 50%;
      right: 0.75rem;
      padding: 0.25rem 0.45rem;
      border: 1px solid var(--faq-border);
      border-radius: 6px;
      background: var(--faq-surface-strong);
      color: var(--faq-muted);
      font: inherit;
      font-size: 0.7rem;
      transform: translateY(-50%);
    }

    .tool-actions {
      display: flex;
      flex: 0 0 auto;
      align-items: center;
      gap: 0.65rem;
    }

    .result-count {
      min-width: 6.3rem;
      color: var(--faq-muted);
      font-size: 0.8rem;
      text-align: right;
    }

    .quiet-button {
      min-height: 2.75rem;
      padding: 0.6rem 0.9rem;
      border: 1px solid var(--faq-border);
      border-radius: 10px;
      background: transparent;
      color: inherit;
      cursor: pointer;
      font: inherit;
      font-size: 0.82rem;
      font-weight: 750;
      transition:
        border-color 160ms ease,
        background 160ms ease;
    }

    .quiet-button:hover,
    .quiet-button:focus-visible {
      border-color: color-mix(in srgb, var(--faq-accent) 55%, transparent);
      background: color-mix(in srgb, var(--faq-accent) 9%, transparent);
    }

    .popular-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      border: 1px solid var(--faq-border);
      border-radius: 18px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.88);
    }

    .popular-link {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      min-height: 118px;
      padding: 1rem;
      border-right: 1px solid var(--faq-border);
      color: inherit;
      text-decoration: none;
      transition: background 160ms ease;
    }

    .popular-link:last-child {
      border-right: 0;
    }

    .popular-link:hover,
    .popular-link:focus-visible {
      background: color-mix(in srgb, var(--faq-accent) 9%, transparent);
    }

    .popular-number {
      color: var(--faq-accent);
      font-size: 0.72rem;
      font-weight: 850;
      letter-spacing: 0.08em;
    }

    .popular-arrow {
      color: var(--faq-muted);
      font-size: 0.9rem;
    }

    .faq-shell {
      display: grid;
      grid-template-columns: minmax(220px, 260px) minmax(0, 1fr);
      align-items: start;
      gap: clamp(1.75rem, 3vw, 3rem);
      width: 100%;
    }

    .faq-sidebar {
      position: sticky;
      top: 1.5rem;
    }

    .sidebar-card {
      padding: 0.85rem;
      border: 1px solid var(--faq-border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.9);
    }

    .sidebar-label {
      padding: 0.45rem 0.55rem 0.6rem;
    }

    .category-nav {
      display: grid;
      gap: 0.25rem;
    }

    .category-nav a {
      display: grid;
      grid-template-columns: 1.4rem minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.55rem;
      min-height: 2.75rem;
      padding: 0.6rem 0.65rem;
      border-radius: 10px;
      color: var(--faq-muted);
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      transition:
        background 150ms ease,
        color 150ms ease,
        transform 150ms ease;
    }

    .category-nav a:hover,
    .category-nav a:focus-visible,
    .category-nav a.is-active {
      background: color-mix(in srgb, var(--faq-accent) 11%, transparent);
      color: inherit;
      transform: translateX(2px);
    }

    .category-nav a.is-active {
      box-shadow: inset 3px 0 0 var(--faq-accent);
    }

    .category-nav small {
      display: grid;
      min-width: 1.5rem;
      height: 1.5rem;
      place-items: center;
      border-radius: 999px;
      background: color-mix(in srgb, currentColor 8%, transparent);
      font-size: 0.68rem;
    }

    .sidebar-note {
      margin-top: 0.8rem;
      padding: 1rem;
      border: 1px solid color-mix(in srgb, var(--faq-accent) 24%, transparent);
      border-radius: 13px;
      background: color-mix(in srgb, var(--faq-accent) 8%, transparent);
    }

    .sidebar-note strong {
      display: block;
      font-size: 0.82rem;
      line-height: 1.4;
    }

    .sidebar-note p {
      margin: 0.45rem 0 0.7rem;
      color: var(--faq-muted);
      font-size: 0.75rem;
      line-height: 1.5;
    }

    .sidebar-note a,
    .answer-link,
    .text-link {
      color: var(--faq-accent);
      font-size: 0.77rem;
      font-weight: 800;
      text-decoration: none;
    }

    .sidebar-note a:hover,
    .answer-link:hover,
    .text-link:hover {
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }

    .faq-content {
      min-width: 0;
    }

    .faq-group {
      scroll-margin-top: 1.5rem;
      margin-bottom: clamp(3rem, 7vw, 5.5rem);
    }

    .group-header {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: start;
      gap: 1rem;
      margin-bottom: 1.15rem;
      padding-bottom: 1.15rem;
      border-bottom: 1px solid var(--faq-border);
    }

    .group-icon {
      display: grid;
      width: 3rem;
      height: 3rem;
      place-items: center;
      border: 1px solid var(--faq-border);
      border-radius: 13px;
      background: var(--faq-surface);
      font-size: 1.35rem;
    }

    .group-header h2 {
      margin: 0;
      font-size: clamp(1.35rem, 2.5vw, 1.85rem);
      line-height: 1.15;
      letter-spacing: -0.025em;
    }

    .group-header p:last-child {
      max-width: 650px;
      margin: 0.5rem 0 0;
      color: var(--faq-muted);
      font-size: 0.88rem;
      line-height: 1.55;
    }

    .group-count {
      align-self: center;
      padding: 0.4rem 0.6rem;
      border: 1px solid var(--faq-border);
      border-radius: 999px;
      color: var(--faq-muted);
      font-size: 0.7rem;
      white-space: nowrap;
    }

    .faq-list {
      display: grid;
      gap: 0.7rem;
    }

    .faq-item {
      scroll-margin-top: 2rem;
      overflow: clip;
      border: 1px solid var(--faq-border);
      border-radius: 15px;
      background: rgba(255, 255, 255, 0.86);
      color: #09090b;
      transition:
        border-color 170ms ease,
        background 170ms ease,
        box-shadow 170ms ease;
    }

    .faq-item:hover {
      border-color: var(--faq-border-strong);
    }

    .faq-item[open] {
      border-color: color-mix(in srgb, var(--faq-accent) 45%, transparent);
      background: rgba(248, 245, 255, 0.92);
      box-shadow: 0 14px 35px color-mix(in srgb, #000 8%, transparent);
    }

    .faq-item summary {
      display: grid;
      grid-template-columns: 2.2rem minmax(0, 1fr) 2.25rem;
      align-items: center;
      gap: 0.75rem;
      min-height: 4rem;
      padding: 0.85rem 1rem;
      cursor: pointer;
      list-style: none;
      outline: none;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-item summary:focus-visible {
      box-shadow: inset 0 0 0 3px color-mix(in srgb, var(--faq-accent) 35%, transparent);
    }

    .question-number {
      color: var(--faq-accent);
      font-size: 0.7rem;
      font-weight: 850;
      letter-spacing: 0.08em;
    }

    .question-text {
      font-size: clamp(0.94rem, 1.5vw, 1.03rem);
      font-weight: 760;
      line-height: 1.4;
    }

    .question-toggle {
      position: relative;
      display: grid;
      width: 2rem;
      height: 2rem;
      place-items: center;
      justify-self: end;
      border: 1px solid var(--faq-border);
      border-radius: 50%;
      background: color-mix(in srgb, currentColor 4%, transparent);
      transition:
        border-color 160ms ease,
        background 160ms ease,
        transform 180ms ease;
    }

    .question-toggle::before,
    .question-toggle::after {
      position: absolute;
      width: 0.72rem;
      height: 1.5px;
      border-radius: 999px;
      background: currentColor;
      content: '';
      transition: transform 180ms ease;
    }

    .question-toggle::after {
      transform: rotate(90deg);
    }

    .faq-item[open] .question-toggle {
      border-color: color-mix(in srgb, var(--faq-accent) 45%, transparent);
      background: color-mix(in srgb, var(--faq-accent) 12%, transparent);
      color: var(--faq-accent);
      transform: rotate(90deg);
    }

    .faq-item[open] .question-toggle::after {
      transform: rotate(0deg);
    }

    .faq-answer {
      margin: 0 1rem 1rem 3.95rem;
      padding: 0.95rem 1rem 0.15rem 0;
      border-top: 1px solid var(--faq-border);
    }

    .faq-answer p {
      max-width: 820px;
      margin: 0;
      color: #202026;
      font-size: 0.94rem;
      line-height: 1.75;
    }

    .answer-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: 0.9rem;
      font-size: 0.82rem;
    }

    .no-results {
      padding: clamp(2.5rem, 7vw, 5rem) 1.5rem;
      border: 1px dashed var(--faq-border-strong);
      border-radius: 20px;
      background: var(--faq-surface);
      text-align: center;
    }

    .no-results > span {
      display: block;
      margin-bottom: 0.8rem;
      font-size: 2rem;
    }

    .no-results h2 {
      margin: 0;
      font-size: 1.4rem;
    }

    .no-results p {
      margin: 0.6rem 0 1.1rem;
      color: var(--faq-muted);
      font-size: 0.9rem;
    }

    .faq-cta {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.6fr);
      align-items: end;
      gap: clamp(1.5rem, 5vw, 4rem);
      margin-top: clamp(3.5rem, 8vw, 6rem);
      padding: clamp(1.5rem, 5vw, 3.5rem);
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--faq-accent) 30%, transparent);
      border-radius: 26px;
      background:
        radial-gradient(
          circle at 92% 8%,
          color-mix(in srgb, var(--faq-accent) 20%, transparent),
          transparent 32%
        ),
        rgba(247, 243, 255, 0.9);
    }

    .faq-cta h2 {
      max-width: 760px;
      font-size: clamp(1.65rem, 3.5vw, 2.75rem);
    }

    .faq-cta p:not(.eyebrow) {
      max-width: 680px;
      margin: 1rem 0 0;
      color: var(--faq-muted);
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .cta-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      gap: 0.7rem;
    }

    .primary-button,
    .secondary-button {
      display: inline-flex;
      min-height: 2.85rem;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1rem;
      border-radius: 11px;
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
      transition:
        transform 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease;
    }

    .primary-button {
      border: 1px solid var(--faq-accent);
      background: var(--faq-accent);
      color: #fff;
      cursor: pointer;
    }

    .primary-button:hover,
    .primary-button:focus-visible {
      background: var(--faq-accent-strong);
      box-shadow: 0 10px 24px color-mix(in srgb, var(--faq-accent) 26%, transparent);
      transform: translateY(-2px);
    }

    .secondary-button {
      border: 1px solid var(--faq-border-strong);
      background: color-mix(in srgb, currentColor 4%, transparent);
      color: inherit;
    }

    .secondary-button:hover,
    .secondary-button:focus-visible {
      background: color-mix(in srgb, currentColor 8%, transparent);
      transform: translateY(-2px);
    }

    .text-link {
      padding: 0.6rem 0.25rem;
      font-size: 0.82rem;
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    [hidden] {
      display: none !important;
    }

    @media (min-width: 1200px) {
      .faq-page {
        width: min(1420px, calc(100vw - 4rem));
      }

      .path-card {
        min-height: 165px;
        padding: 1.25rem;
      }

      .popular-link {
        padding: 1.1rem;
      }

      .faq-answer {
        margin-right: 1.35rem;
      }
    }

    @media (max-width: 980px) {
      .path-grid,
      .popular-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .popular-link:nth-child(2) {
        border-right: 0;
      }

      .popular-link:nth-child(-n + 2) {
        border-bottom: 1px solid var(--faq-border);
      }

      .faq-shell {
        grid-template-columns: 200px minmax(0, 1fr);
        gap: 1.5rem;
      }

      .faq-cta {
        grid-template-columns: 1fr;
      }

      .cta-actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 760px), (hover: none) and (pointer: coarse) and (max-width: 1100px) {
      :global(body) {
        overflow-x: clip;
      }

      .faq-page {
        /* Force a true full-viewport layout even inside AboutLayout's article column. */
        position: relative;
        left: 50%;
        width: 100dvw !important;
        max-width: none !important;
        margin: 0 !important;
        padding:
          1.25rem max(1rem, env(safe-area-inset-right))
          3.5rem max(1rem, env(safe-area-inset-left));
        box-sizing: border-box;
        color: #09090b;
        transform: translateX(-50%);
        --faq-border: rgba(17, 24, 39, 0.18);
        --faq-border-strong: rgba(17, 24, 39, 0.3);
        --faq-surface: rgba(255, 255, 255, 0.82);
        --faq-surface-strong: rgba(255, 255, 255, 0.95);
        --faq-muted: #303038;
      }

      .faq-page > *,
      .faq-intro,
      .start-here,
      .faq-tools,
      .popular-section,
      .faq-shell,
      .faq-content,
      .faq-group,
      .faq-cta {
        width: 100% !important;
        max-width: none !important;
        margin-right: 0 !important;
        margin-left: 0 !important;
      }

      .faq-page *,
      .faq-page *::before,
      .faq-page *::after {
        box-sizing: border-box;
      }

      .faq-intro {
        margin-bottom: 3rem !important;
      }

      .section-heading,
      .group-header {
        width: 100%;
      }

      .intro-meta {
        gap: 0.45rem;
      }

      .intro-meta span {
        min-height: 2.1rem;
        padding: 0.35rem 0.65rem;
        font-size: 0.75rem;
      }

      .path-grid,
      .popular-grid {
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }

      .popular-link,
      .popular-link:nth-child(2),
      .popular-link:nth-child(-n + 2) {
        min-height: 0;
        border-right: 0;
        border-bottom: 1px solid var(--faq-border);
      }

      .popular-link:last-child {
        border-bottom: 0;
      }

      .path-card {
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        min-height: 0;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.78);
      }

      .path-card > span:nth-child(2) {
        min-width: 0;
      }

      .path-card strong {
        margin-top: 0;
        color: #09090b;
        font-size: 0.98rem;
      }

      .path-card small {
        margin-top: 0.3rem;
        color: #303038;
        font-size: 0.8rem;
        line-height: 1.45;
      }

      .path-icon {
        width: 2.5rem;
        height: 2.5rem;
      }

      .path-arrow {
        position: relative;
        right: auto;
        bottom: auto;
        align-self: center;
      }

      .faq-tools {
        align-items: stretch;
        flex-direction: column;
        padding: 0.65rem;
      }

      .search-wrap {
        flex-basis: auto;
      }

      .search-wrap kbd {
        display: none;
      }

      .search-wrap input {
        min-height: 3.15rem;
        padding-right: 1rem;
        font-size: 16px;
      }

      .tool-actions {
        justify-content: space-between;
        padding: 0 0.15rem;
      }

      .result-count {
        min-width: 0;
        text-align: left;
      }

      .faq-shell {
        display: block;
      }

      .faq-sidebar {
        position: static;
        margin-bottom: 2.75rem;
      }

      .sidebar-card {
        padding: 0.55rem;
        overflow: hidden;
        border-radius: 15px;
      }

      .sidebar-label,
      .sidebar-note {
        display: none;
      }

      .category-nav {
        display: flex;
        gap: 0.45rem;
        padding-bottom: 0.1rem;
        overflow-x: auto;
        overscroll-behavior-inline: contain;
